---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'white';
  size?: 'sm' | 'md' | 'lg' | 'wide';
  target?: '_blank' | '_self';
  type?: 'button' | 'submit';
  class?: string;
  paddingX?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  target = '_self',
  type = 'button',
  class: className,
  paddingX,
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  target={href ? target : undefined}
  rel={href && target === '_blank' ? 'noopener noreferrer' : undefined}
  type={!href ? type : undefined}
  class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
  style={paddingX ? `--btn-px: ${paddingX}` : undefined}
>
  <slot />
</Tag>

<style>
  .btn {
    @apply inline-flex items-center justify-center no-underline uppercase;
    position: relative;
    overflow: hidden;
    width: fit-content;
    min-height: 3.125rem;
    border: 1px solid transparent;
    font-family: var(--font-body);
    font-size: var(--text-button);
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0.06em;
    transition:
      background-size 360ms ease-in-out,
      background-color var(--transition-base),
      border-color var(--transition-base),
      color var(--transition-base);
  }

  .btn:hover {
    text-decoration: none;
  }

  .btn--primary {
    border-color: var(--color-primary);
    background: var(--color-primary);
    background-image: radial-gradient(circle at center, #ffffff 0%, #ffffff 54%, transparent 55%);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 0% 0%;
    color: var(--color-text-light);
  }

  .btn--primary:hover {
    background-size: 260% 260%;
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .btn--secondary {
    border-color: rgba(255, 255, 255, 0.75);
    background: transparent;
    background-image: radial-gradient(circle at center, #ffffff 0%, #ffffff 54%, transparent 55%);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 0% 0%;
    color: var(--color-text-light);
  }

  .btn--secondary:hover {
    background-size: 260% 260%;
    border-color: #ffffff;
    color: #000000;
  }

  .btn--outline {
    border-color: var(--color-primary);
    background: transparent;
    color: var(--color-primary);
  }

  .btn--outline:hover {
    background: var(--color-primary);
    color: var(--color-text-light);
  }

  .btn--ghost {
    border-color: transparent;
    background: transparent;
    color: currentColor;
  }

  .btn--white {
    border-color: #ffffff;
    background: #ffffff;
    background-image: radial-gradient(circle at center, var(--color-primary) 0%, var(--color-primary) 54%, transparent 55%);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 0% 0%;
    color: #0a0a0a;
  }

  .btn--white:hover {
    background-size: 260% 260%;
    border-color: var(--color-primary);
    color: #ffffff;
  }

  .btn--sm {
    min-height: 2.625rem;
    padding: 0.75rem var(--btn-px, 1.25rem);
  }

  .btn--md {
    min-height: 3.125rem;
    padding: 0.875rem var(--btn-px, 1.25rem);
  }

  .btn--lg {
    min-height: 3.25rem;
    padding: 0.95rem var(--btn-px, 2rem);
  }

  .btn--wide {
    min-height: 3.125rem;
    padding: 0.875rem var(--btn-px, 3.5rem);
  }
  @media (min-width: 768px) {
    .btn--md {
      padding: 0.875rem var(--btn-px, 1.65rem);
    }
  }
</style>
