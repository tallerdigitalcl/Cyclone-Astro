---
import { sanityClient } from '../../lib/sanity';

const modelosQuery = `*[_type == "moto" && defined(slug.current)] | order(_createdAt asc) { "label": nombre, "href": "/motos/" + slug.current }`;
const modeloLinks: { label: string; href: string }[] = await sanityClient.fetch(modelosQuery);

const worldLinks = [
  { label: 'Descubre más' },
  { label: 'Concesionarios' },
  { label: 'Protección de datos' },
];

interface FooterWorldLink {
  label: string;
  href: string;
  blank?: boolean;
}

interface FooterSettings {
  nuestroMundoTitulo?: string;
  nuestroMundoLinks?: FooterWorldLink[];
}

const footerSettingsQuery = `*[_type == "footerSettings"] | order(_updatedAt desc)[0] {
  nuestroMundoTitulo,
  nuestroMundoLinks[] {
    label,
    href,
    blank
  }
}`;

const fallbackWorldTitle = 'Nuestro mundo';
const fallbackWorldLinks: FooterWorldLink[] = [
  { label: 'Descubre más', href: '/descubre-mas' },
  { label: 'Concesionarios', href: '/concesionarios' },
  { label: 'Protección de datos', href: '/proteccion-de-datos' },
];

let footerSettings: FooterSettings | null = null;

try {
  footerSettings = await sanityClient.fetch<FooterSettings | null>(footerSettingsQuery);
} catch (error) {
  console.error('[Footer] Error fetching Sanity content:', error);
}

const footerWorldTitle = footerSettings?.nuestroMundoTitulo || fallbackWorldTitle;
const footerWorldLinks = footerSettings?.nuestroMundoLinks?.filter((link) => link.label && link.href) || fallbackWorldLinks;
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <h2 class="footer__sr-only">Footer del sitio</h2>

  <div class="footer__container">
    <section class="footer__social-bar" aria-label="Redes sociales">
      <p class="footer__social-copy">Síguenos en nuestras redes sociales</p>

      <ul class="footer__social-list" aria-label="Canales sociales">
        <li class="footer__social-item">
          <a href="https://www.facebook.com/Cyclonemotoschile/" target="_blank" rel="noreferrer noopener" class="footer__social-link" aria-label="Facebook de Cyclone Motos">
            <svg viewBox="0 0 24 24" aria-hidden="true" class="footer__social-icon">
              <path d="M13.5 21v-7h2.35l.35-2.74H13.5V9.51c0-.79.22-1.33 1.35-1.33h1.44V5.73c-.25-.03-1.1-.11-2.08-.11-2.06 0-3.47 1.26-3.47 3.57v2.07H8.4V14h2.34v7h2.76Z" fill="currentColor" />
            </svg>
          </a>
        </li>
        <li class="footer__social-item">
          <a href="https://www.instagram.com/cyclonemotos.chile/" target="_blank" rel="noreferrer noopener" class="footer__social-link" aria-label="Instagram de Cyclone Motos">
            <svg viewBox="0 0 24 24" aria-hidden="true" class="footer__social-icon">
              <path d="M7.75 3h8.5A4.75 4.75 0 0 1 21 7.75v8.5A4.75 4.75 0 0 1 16.25 21h-8.5A4.75 4.75 0 0 1 3 16.25v-8.5A4.75 4.75 0 0 1 7.75 3Zm0 1.8A2.95 2.95 0 0 0 4.8 7.75v8.5a2.95 2.95 0 0 0 2.95 2.95h8.5a2.95 2.95 0 0 0 2.95-2.95v-8.5a2.95 2.95 0 0 0-2.95-2.95h-8.5Zm8.9 1.35a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7.6A4.4 4.4 0 1 1 7.6 12 4.4 4.4 0 0 1 12 7.6Zm0 1.8A2.6 2.6 0 1 0 14.6 12 2.6 2.6 0 0 0 12 9.4Z" fill="currentColor" />
            </svg>
          </a>
        </li>
      </ul>
    </section>

    <div class="footer__main">
      <section class="footer__brand" aria-label="Marca">
        <a href="/" class="footer__logo" aria-label="Ir al inicio de Cyclone Motos">
          <img src="/footer/logo_footer.webp" alt="Cyclone Motos" width="160" height="36" loading="lazy" decoding="async" />
        </a>
        <a href="https://promobility.cl/" target="_blank" rel="noreferrer noopener" class="footer__logo" aria-label="Ir al inicio de Promobility">
          <img src="/footer/Logo-cpromobility.webp" alt="Promobility" width="160" height="36" loading="lazy" decoding="async" />
        </a>
      </section>

      <nav class="footer__nav" aria-labelledby="footer-modelos-title">
        <h3 id="footer-modelos-title" class="footer__title">Modelos</h3>
        <ul class="footer__link-list">
          {modeloLinks.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <nav class="footer__nav" aria-labelledby="footer-world-title">
        <h3 id="footer-world-title" class="footer__title">{footerWorldTitle}</h3>
        <ul class="footer__link-list">
          {footerWorldLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="footer__link"
                target={link.blank ? '_blank' : undefined}
                rel={link.blank ? 'noreferrer noopener' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- <section class="footer__newsletter" aria-labelledby="footer-newsletter-title">
        <h3 id="footer-newsletter-title" class="footer__title">Newsletter</h3>
        <p class="footer__newsletter-copy">
          Suscríbete para recibir lanzamientos exclusivos.
        </p>

        <form class="footer__newsletter-form" aria-label="Suscripción al newsletter">
          <label class="footer__sr-only" for="footer-email">Correo electrónico</label>
          <input
            id="footer-email"
            name="email"
            type="email"
            class="footer__newsletter-input"
            placeholder="Email"
            autocomplete="email"
            inputmode="email"
          />
          <button type="button" class="footer__newsletter-button" aria-label="Suscribirse al newsletter">
            <svg viewBox="0 0 24 24" aria-hidden="true" class="footer__newsletter-icon">
              <path d="M5 12h11.17l-3.58-3.59L14 7l6 6-6 6-1.41-1.41L16.17 14H5v-2Z" fill="currentColor" />
            </svg>
          </button>
        </form>
      </section> -->
    </div>

    <div class="footer__bottom">
      <p class="footer__legal">© {currentYear} Cyclone Motos. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    @apply bg-white text-text;
    border-top: 1px solid var(--color-border);
  }

  .footer__container {
    @apply mx-auto;
    max-width: var(--container-max);
    padding: 1.75rem var(--container-padding) 2rem;
  }

  .footer__sr-only {
    @apply absolute w-px h-px p-0 -m-px overflow-hidden whitespace-nowrap border-0;
    clip: rect(0, 0, 0, 0);
  }

  .footer__social-bar {
    @apply flex flex-row justify-between gap-24 mt-6;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .footer__social-copy {
    @apply font-body text-body text-muted;
  }

  .footer__social-list {
    @apply flex items-center gap-2 self-end;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__social-item {
    @apply flex;
  }

  .footer__social-link {
    @apply inline-flex items-center justify-center rounded-full;
    overflow: hidden;
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--color-primary);
    background-color: var(--color-primary);
    background-image: radial-gradient(circle at center, #ffffff 0%, #ffffff 54%, transparent 55%);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 0% 0%;
    color: var(--color-text-light);
    transition:
      background-size 360ms ease-in-out,
      color var(--transition-base),
      transform var(--transition-base);
  }

  .footer__social-link:hover {
    transform: translateY(-1px);
    background-size: 260% 260%;
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .footer__social-icon {
    width: 1rem;
    height: 1rem;
  }

  .footer__main {
    @apply grid;
    gap: 2rem;
    padding: 2rem 0 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .footer__brand {
    @apply flex flex-col gap-6;
  }

  .footer__logo {
    @apply inline-flex items-center;
    max-width: 10rem;
  }

  .footer__logo:hover {
    text-decoration: none;
  }

  .footer__brand-tag {
    @apply font-heading uppercase;
    width: fit-content;
    font-size: var(--text-body-sm);
    letter-spacing: 0.18em;
    color: var(--color-primary);
  }

  .footer__nav,
  .footer__newsletter {
    @apply flex flex-col;
    gap: 1rem;
  }

  .footer__title {
    @apply font-heading;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .footer__link-list {
    @apply flex flex-col;
    gap: 0.85rem;
    list-style: none;
  }

  .footer__link {
    @apply relative inline-flex w-fit font-body text-body transition-colors duration-200;
    color: var(--color-text-muted);
  }

  .footer__link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.18rem;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer__link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .footer__link:hover::after {
    transform: scaleX(1);
  }

  .footer__link--muted {
    cursor: default;
  }

  .footer__newsletter-copy {
    @apply font-body text-body;
    max-width: 20rem;
    color: var(--color-text-muted);
  }

  .footer__newsletter-form {
    @apply flex items-center;
    max-width: 24rem;
    gap: 0.35rem;
  }

  .footer__newsletter-input {
    @apply w-full font-body text-body;
    height: 2.75rem;
    padding: 0 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background-color: var(--color-bg);
    color: var(--color-text);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .footer__newsletter-input::placeholder {
    color: var(--color-text-muted);
  }

  .footer__newsletter-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(214, 0, 15, 0.12);
  }

  .footer__newsletter-button {
    @apply inline-flex items-center justify-center shrink-0 rounded-md;
    overflow: hidden;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid var(--color-primary);
    background-color: var(--color-primary);
    background-image: radial-gradient(circle at center, #ffffff 0%, #ffffff 54%, transparent 55%);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 0% 0%;
    color: var(--color-text-light);
    transition:
      background-size 360ms ease-in-out,
      color var(--transition-base);
  }

  .footer__newsletter-button:hover {
    background-size: 260% 260%;
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .footer__newsletter-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .footer__bottom {
    @apply flex flex-col gap-3;
    padding-top: 1rem;
  }

  .footer__legal {
    @apply font-body text-body-sm;
    color: var(--color-text-muted);
  }

  @media (min-width: 640px) {
    .footer__social-bar {
      @apply flex-row items-center justify-between;
    }

    .footer__social-list {
      @apply self-auto;
    }
  }

  @media (min-width: 1024px) {
    .footer__main {
      grid-template-columns: minmax(13rem, 1.2fr) minmax(10rem, 0.9fr) minmax(10rem, 0.9fr);
      gap: 2.5rem;
      align-items: start;
    }
  }
</style>
