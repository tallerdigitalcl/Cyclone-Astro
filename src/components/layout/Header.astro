---
const navLinks = [
  { label: 'Modelos', href: '/motos', hasDropdown: true },
  { label: 'Concesionarios', href: '/concesionarios' },
  { label: 'Escuela de manejo', href: '/escuela' },
  { label: 'Noticias', href: '/noticia' },
];
---

<header class="header">
  <div class="header__inner">

    <!-- Logo -->
    <a href="/" class="header__logo">
      <img src="/header/cyclone-logo.webp" alt="Cyclone Motos" width="160" height="36" />
    </a>

    <!-- Navegación central (desktop) -->
    <nav class="header__nav">
      <!-- Dropdown Modelos -->
      <div class="nav__dropdown group">
        <button class="nav__link nav__link--dropdown">
          Modelos
          <svg xmlns="http://www.w3.org/2000/svg" class="nav__arrow" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="nav__dropdown-panel">
          <a href="/motos" class="nav__dropdown-item">Ver todos los modelos</a>
          <!-- Agrega más subcategorías aquí -->
        </div>
      </div>

      <!-- Links restantes -->
      {navLinks.filter(l => !l.hasDropdown).map(link => (
        <a href={link.href} class="nav__link">{link.label}</a>
      ))}
    </nav>

    <!-- Acciones derecha (desktop) -->
    <div class="header__actions">
      <a href="/concesionarios" class="nav__link">Concesionarios más cercanos</a>
      <button aria-label="Buscar" class="header__search-btn">
        <svg xmlns="http://www.w3.org/2000/svg" class="header__search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
        </svg>
      </button>
    </div>

    <!-- Hamburguesa (móvil) -->
    <button id="menu-toggle" aria-label="Abrir menú" class="header__hamburger">
      <svg xmlns="http://www.w3.org/2000/svg" class="header__hamburger-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Línea separadora -->
  <div class="header__divider"></div>

  <!-- Menú móvil -->
  <nav id="mobile-menu" class="mobile-menu">
    <!-- Dropdown Modelos en móvil -->
    <div>
      <button id="mobile-modelos-toggle" class="mobile-menu__dropdown-btn">
        Modelos
        <svg id="mobile-modelos-icon" xmlns="http://www.w3.org/2000/svg" class="nav__arrow" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </button>
      <div id="mobile-modelos-menu" class="mobile-menu__submenu hidden">
        <a href="/motos" class="mobile-menu__subitem">Ver todos los modelos</a>
        <!-- Agrega más subcategorías aquí -->
      </div>
    </div>

    {navLinks.filter(l => !l.hasDropdown).map(link => (
      <a href={link.href} class="mobile-menu__item">{link.label}</a>
    ))}
    <a href="/concesionarios" class="mobile-menu__item">Concesionarios más cercanos</a>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });

  const modelosToggle = document.getElementById('mobile-modelos-toggle');
  const modelosMenu = document.getElementById('mobile-modelos-menu');
  const modelosIcon = document.getElementById('mobile-modelos-icon');
  modelosToggle?.addEventListener('click', () => {
    modelosMenu?.classList.toggle('hidden');
    modelosMenu?.classList.toggle('flex');
    modelosIcon?.classList.toggle('rotate-180');
  });
</script>

<style>
  /* ---- Header base ---- */
  .header {
    @apply w-full fixed top-0 left-0 right-0 z-50;
    background: linear-gradient(180deg,rgba(0,0,0,0.66) 0%,rgba(0,0,0,0.5) 0%,rgba(0,0,0,0) 100%)
  }

  .header__inner {
    @apply max-w-container mx-auto px-6 flex items-center justify-between h-[80px] border-b border-white/90;
  }

  .header__logo img {
    @apply h-9 w-auto object-contain flex-shrink-0;
  }

  .header__divider {
    @apply h-px;
  }

  /* ---- Nav desktop ---- */
  .header__nav {
    @apply hidden lg:flex items-center gap-8;
  }

  .header__actions {
    @apply hidden lg:flex items-center gap-4;
  }

  .nav__link {
    @apply flex items-center gap-1 text-sm font-medium text-white/90 hover:text-white transition-colors duration-200 tracking-wide;
  }

  .nav__link--dropdown {
    @apply bg-transparent border-none cursor-pointer;
  }

  .nav__arrow {
    @apply w-3.5 h-3.5 opacity-70 transition-transform duration-200;
  }

  /* ---- Dropdown desktop ---- */
  .nav__dropdown {
    @apply relative;
  }

  .nav__dropdown-panel {
    @apply absolute top-full left-1/2 -translate-x-1/2 mt-3 w-48 rounded-md shadow-lg border border-white/10 py-1;
    @apply opacity-0 invisible translate-y-1 transition-all duration-200;
    background: #2c2c24;
  }

  .group:hover .nav__dropdown-panel {
    @apply opacity-100 visible translate-y-0;
  }

  .group:hover .nav__arrow {
    @apply rotate-180;
  }

  .nav__dropdown-item {
    @apply block px-4 py-2.5 text-sm text-white/80 hover:text-white hover:bg-white/10 transition-colors;
  }

  /* ---- Búsqueda ---- */
  .header__search-btn {
    @apply bg-transparent border-none cursor-pointer text-white/80 hover:text-white transition-colors duration-200;
  }

  .header__search-icon {
    @apply w-5 h-5;
  }

  /* ---- Hamburguesa ---- */
  .header__hamburger {
    @apply lg:hidden bg-transparent border-none cursor-pointer text-white;
  }

  .header__hamburger-icon {
    @apply w-6 h-6;
  }

  /* ---- Menú móvil ---- */
  .mobile-menu {
    @apply hidden flex-col bg-[#2c2c24] px-6 py-4 gap-4;
  }

  .mobile-menu__item {
    @apply text-sm font-medium text-white/90 hover:text-white py-2 border-b border-white/10 transition-colors;
  }

  .mobile-menu__dropdown-btn {
    @apply w-full flex items-center justify-between text-sm font-medium text-white/90 hover:text-white py-2 border-b border-white/10 bg-transparent cursor-pointer transition-colors;
  }

  .mobile-menu__submenu {
    @apply flex-col pl-4 mt-1 gap-1;
  }

  .mobile-menu__subitem {
    @apply text-sm text-white/70 hover:text-white py-2 border-b border-white/10 transition-colors;
  }
</style>
