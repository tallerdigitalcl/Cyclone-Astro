---
import { sanityClient, urlFor } from '../../lib/sanity';
import { motoNavQuery } from '../../lib/queries';
import type { Moto } from '../../lib/types';

type MotoNav = Pick<Moto, 'nombre' | 'slug' | 'fotoHeader'>;
const motos = await sanityClient.fetch<MotoNav[]>(motoNavQuery);

const navLinks = [
  { label: 'Concesionarios', href: '/concesionarios' },
  { label: 'Noticias', href: '/noticia' },
];
---

<header class="header">
  <div class="header__inner">

    <!-- Logo (blanco por defecto, rojo cuando el mega menú está abierto) -->
    <a href="/" class="header__logo">
      <img src="/header/cyclone-logo.webp" class="header__logo-img header__logo-img--default" alt="Cyclone Motos" width="160" height="36" />
      <img src="/footer/logo_footer.webp" class="header__logo-img header__logo-img--mega" alt="Cyclone Motos" width="160" height="36" />
    </a>

    <!-- Navegación central (desktop) -->
    <nav class="header__nav">
      <!-- Mega menú Modelos -->
      <div class="nav__dropdown" id="nav-modelos">
        <button class="nav__link nav__link--dropdown" aria-expanded="false" aria-controls="mega-panel">
          Modelos
          <svg xmlns="http://www.w3.org/2000/svg" class="nav__arrow" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>

      <!-- Links restantes -->
      {navLinks.map(link => (
        <a href={link.href} class="nav__link">{link.label}</a>
      ))}
    </nav>

    <!-- Acciones derecha (desktop) -->
    <div class="header__actions">
      <a href="/concesionarios" class="nav__link">Concesionarios más cercanos</a>
      <button aria-label="Buscar" class="header__search-btn">
        <svg xmlns="http://www.w3.org/2000/svg" class="header__search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
        </svg>
      </button>
    </div>

    <!-- Hamburguesa (móvil) -->
    <button id="menu-toggle" aria-label="Abrir menú" class="header__hamburger">
      <svg xmlns="http://www.w3.org/2000/svg" class="header__hamburger-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Línea separadora -->
  <div class="header__divider"></div>

  <!-- ── MEGA MENÚ MODELOS ──────────────────────────────────────── -->
  <div id="mega-panel" class="nav__mega-panel" role="region" aria-label="Modelos de motos">
    <div class="nav__mega-inner">
      <!-- Sidebar izquierdo -->
      <div class="nav__mega-sidebar">
        <a href="/motos" class="nav__mega-all">Todos los modelos</a>
      </div>

      <!-- Divisor -->
      <div class="nav__mega-divider" aria-hidden="true"></div>

      <!-- Grid de motos -->
      <ul class="nav__mega-grid" role="list">
        {motos.map(moto => {
          const imgUrl = moto.fotoHeader?.asset?.url
            ? urlFor(moto.fotoHeader).width(360).fit('fill').auto('format').quality(85).url()
            : null;
          if (!imgUrl) return null;
          return (
            <li>
              <a href={`/motos/${moto.slug}`} class="nav__mega-card">
                <div class="nav__mega-card-media">
                  <img
                    src={imgUrl}
                    alt={moto.fotoHeader?.alt || moto.nombre}
                    width="360"
                    height="220"
                    loading="eager"
                    decoding="async"
                  />
                </div>
                <span class="nav__mega-card-name">{moto.nombre}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>

  <!-- Menú móvil -->
  <nav id="mobile-menu" class="mobile-menu">
    <!-- Dropdown Modelos en móvil -->
    <div>
      <button id="mobile-modelos-toggle" class="mobile-menu__dropdown-btn">
        Modelos
        <svg id="mobile-modelos-icon" xmlns="http://www.w3.org/2000/svg" class="nav__arrow" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </button>
      <div id="mobile-modelos-menu" class="mobile-menu__submenu hidden">
        <a href="/motos" class="mobile-menu__subitem">Ver todos los modelos</a>
        {motos.map(moto => (
          <a href={`/motos/${moto.slug}`} class="mobile-menu__subitem">{moto.nombre}</a>
        ))}
      </div>
    </div>

    {navLinks.map(link => (
      <a href={link.href} class="mobile-menu__item">{link.label}</a>
    ))}
    <a href="/concesionarios" class="mobile-menu__item">Concesionarios más cercanos</a>
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>('.header');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });

  const modelosToggle = document.getElementById('mobile-modelos-toggle');
  const modelosMenu = document.getElementById('mobile-modelos-menu');
  const modelosIcon = document.getElementById('mobile-modelos-icon');
  modelosToggle?.addEventListener('click', () => {
    modelosMenu?.classList.toggle('hidden');
    modelosMenu?.classList.toggle('flex');
    modelosIcon?.classList.toggle('rotate-180');
  });

  // Mega menú desktop
  const navModelos = document.getElementById('nav-modelos');
  const megaPanel = document.getElementById('mega-panel');
  const megaBtn = navModelos?.querySelector('button');

  const openMega = () => {
    header?.classList.add('header--mega-open');
    megaPanel?.classList.add('is-open');
    megaBtn?.setAttribute('aria-expanded', 'true');
  };
  const closeMega = () => {
    header?.classList.remove('header--mega-open');
    megaPanel?.classList.remove('is-open');
    megaBtn?.setAttribute('aria-expanded', 'false');
  };

  navModelos?.addEventListener('mouseenter', openMega);
  navModelos?.addEventListener('mouseleave', closeMega);
  megaPanel?.addEventListener('mouseenter', openMega);
  megaPanel?.addEventListener('mouseleave', closeMega);

  let ticking = false;
  let blurTimer: number | undefined;

  const updateHeaderState = () => {
    const currentScrollY = window.scrollY;
    const isAtPageTop = currentScrollY <= 4;

    if (isAtPageTop) {
      window.clearTimeout(blurTimer);
      blurTimer = undefined;
      header?.classList.remove('header--blurred');
      header?.classList.remove('header--line-hidden');
    } else {
      header?.classList.add('header--line-hidden');

      if (!header?.classList.contains('header--blurred') && blurTimer === undefined) {
        blurTimer = window.setTimeout(() => {
          header?.classList.add('header--blurred');
          blurTimer = undefined;
        }, 980);
      }
    }

    ticking = false;
  };

  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        window.requestAnimationFrame(updateHeaderState);
        ticking = true;
      }
    },
    { passive: true }
  );
</script>

<style>
  /* ---- Header base ---- */
  .header {
    @apply w-full fixed top-0 left-0 right-0 z-50;
    background: linear-gradient(180deg,rgba(0,0,0,0.8) 0%,rgba(0,0,0,0.7) 0%,rgba(0,0,0,0) 100%);
    transition: background 350ms ease, backdrop-filter 900ms ease;
  }

  .header--blurred {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.62) 0%, rgba(0, 0, 0, 0.48) 100%);
    backdrop-filter: blur(4px);
  }

  .header__inner {
    @apply relative max-w-container mx-auto px-6 flex justify-between items-center gap-28 h-[80px];
  }

  .header__inner::after {
    content: '';
    position: absolute;
    left: 1.5rem;
    right: 1.5rem;
    bottom: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.9);
    transform: scaleX(1);
    transform-origin: center;
    transition: transform 1100ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header--line-hidden .header__inner::after {
    transform: scaleX(0);
  }

  /* ---- Logo ---- */
  .header__logo {
    position: relative;
    display: block;
    flex-shrink: 0;
  }

  .header__logo-img {
    @apply h-9 w-auto object-contain;
    transition: opacity 350ms ease;
  }

  .header__logo-img--mega {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    object-fit: contain;
    opacity: 0;
    pointer-events: none;
  }

  .header--mega-open .header__logo-img--default {
    opacity: 0;
  }

  .header--mega-open .header__logo-img--mega {
    opacity: 1;
    pointer-events: auto;
  }

  /* ---- Header cuando mega está abierto ---- */
  .header--mega-open {
    background: white;
    backdrop-filter: none;
  }

  .header--mega-open .nav__link,
  .header--mega-open .header__search-btn {
    color: #1a1c1c;
    transition: color 350ms ease;
  }

  .header--mega-open .header__inner::after {
    background: rgba(26, 28, 28, 0.15);
    transform: scaleX(1);
  }

  /* ---- Dropdown nav (solo el botón) ---- */
  .nav__dropdown {
    @apply relative;
  }

  .nav__dropdown-panel {
    display: none; /* eliminado, reemplazado por mega panel */
  }

  /* ---- Mega panel (full-width, debajo del header) ---- */
  .nav__mega-panel {
    position: fixed;
    top: var(--header-height, 80px);
    left: 0;
    right: 0;
    background: white;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
    border-top: 1px solid var(--color-primary);
    padding: 2rem 0 2.5rem;
    opacity: 0;
    visibility: hidden;
    clip-path: inset(0 0 100% 0);
    transition: clip-path 380ms cubic-bezier(0.16, 1, 0.3, 1), opacity 200ms ease, visibility 0ms 380ms;
    z-index: 49;
  }

  .nav__mega-panel.is-open {
    opacity: 1;
    visibility: visible;
    clip-path: inset(0 0 0% 0);
    transition: clip-path 380ms cubic-bezier(0.16, 1, 0.3, 1), opacity 200ms ease, visibility 0ms 0ms;
  }

  .nav__mega-inner {
    max-width: var(--container-max, 80rem);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 2.5rem;
  }

  /* Sidebar izquierdo */
  .nav__mega-sidebar {
    flex-shrink: 0;
    width: 11rem;
    padding-top: 0.25rem;
  }

  .nav__mega-all {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1c1c;
    text-decoration: none;
    padding: 0.4rem 0;
    border-bottom: 2px solid var(--color-primary);
    transition: color 180ms ease;
    letter-spacing: 0.02em;
  }

  .nav__mega-all:hover {
    color: var(--color-primary);
  }

  /* Divisor vertical */
  .nav__mega-divider {
    width: 1px;
    min-height: 6rem;
    align-self: stretch;
    background: var(--color-primary);
    flex-shrink: 0;
    margin-top: -2rem;
    margin-bottom: -2.5rem;
  }

  /* Grid de motos */
  .nav__mega-grid {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 1.5rem;
    flex: 1;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Tarjeta de moto */
  .nav__mega-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    width: 17rem;
    cursor: pointer;
  }

  .nav__mega-card-media {
    width: 100%;
    overflow: hidden;
    border-radius: 2px;
  }

  .nav__mega-card-media img {
    display: block;
    width: 100%;
    height: auto;
    transform: scale(0.90);
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav__mega-card:hover .nav__mega-card-media img {
    transform: scale(1.0);
  }

  .nav__mega-card-name {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    color: #1a1c1c;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    text-align: center;
  }

  .header__divider {
    @apply h-px;
  }

  /* ---- Nav desktop ---- */
  .header__nav {
    @apply hidden lg:flex items-center gap-10;
  }

  .header__actions {
    @apply hidden lg:flex items-center gap-4 ml-auto;
  }

  .nav__link {
    @apply relative flex items-center gap-1 text-sm font-medium text-white/90 hover:text-white transition-colors duration-200 tracking-wide no-underline;
  }

  .nav__link:hover {
    text-decoration: none;
  }

  .nav__link:not(.nav__link--dropdown)::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.18rem;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav__link:not(.nav__link--dropdown):hover::after {
    transform: scaleX(1);
  }

  .nav__link--dropdown {
    @apply bg-transparent border-none cursor-pointer;
  }

  .nav__arrow {
    @apply w-3.5 h-3.5 opacity-70 transition-transform duration-200;
  }

  /* Puente invisible entre el botón de Modelos y el mega panel */
  .nav__dropdown::after {
    content: '';
    position: absolute;
    top: 100%;
    left: -2rem;
    right: -2rem;
    height: 1.5rem; /* cubre el gap entre el header y el panel */
    background: transparent;
  }

  /* ---- Búsqueda ---- */
  .header__search-btn {
    @apply bg-transparent border-none cursor-pointer text-white/80 hover:text-white transition-colors duration-200;
  }

  .header__search-icon {
    @apply w-5 h-5;
  }

  /* ---- Hamburguesa ---- */
  .header__hamburger {
    @apply lg:hidden bg-transparent border-none cursor-pointer text-white;
  }

  .header__hamburger-icon {
    @apply w-6 h-6;
  }

  /* ---- Menú móvil ---- */
  .mobile-menu {
    @apply hidden flex-col bg-[#2c2c24] px-6 py-4 gap-4;
  }

  .mobile-menu__item {
    @apply text-sm font-medium text-white/90 hover:text-white py-2 border-b border-white/10 transition-colors;
  }

  .mobile-menu__dropdown-btn {
    @apply w-full flex items-center justify-between text-sm font-medium text-white/90 hover:text-white py-2 border-b border-white/10 bg-transparent cursor-pointer transition-colors;
  }

  .mobile-menu__submenu {
    @apply flex-col pl-4 mt-1 gap-1;
  }

  .mobile-menu__subitem {
    @apply text-sm text-white/70 hover:text-white py-2 border-b border-white/10 transition-colors;
  }
</style>
