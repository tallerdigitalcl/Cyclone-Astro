---
import { sanityClient, urlFor } from '../../lib/sanity';
import { motoNavQuery } from '../../lib/queries';
import type { Moto } from '../../lib/types';

type MotoNav = Pick<Moto, 'nombre' | 'slug' | 'fotoHeader'>;
const motos = await sanityClient.fetch<MotoNav[]>(motoNavQuery);

const navLinks = [
  { label: 'Concesionarios', href: '/concesionarios' },
  { label: 'Noticias', href: '/noticia' },
];
---

<header class="header">
  <div class="header__inner">

    <!-- Logo (blanco por defecto, rojo cuando el mega menú está abierto) -->
    <a href="/" class="header__logo">
      <img src="/header/cyclone-logo.webp" class="header__logo-img header__logo-img--default" alt="Cyclone Motos" width="160" height="36" />
      <img src="/footer/logo_footer.webp" class="header__logo-img header__logo-img--mega" alt="Cyclone Motos" width="160" height="36" />
    </a>

    <!-- Navegación central (desktop) -->
    <nav class="header__nav">
      <!-- Mega menú Modelos -->
      <div class="nav__dropdown" id="nav-modelos">
        <button class="nav__link nav__link--dropdown" aria-expanded="false" aria-controls="mega-panel">
          Modelos
          <svg xmlns="http://www.w3.org/2000/svg" class="nav__arrow" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>

      <!-- Links restantes -->
      {navLinks.map(link => (
        <a href={link.href} class="nav__link">{link.label}</a>
      ))}
    </nav>

    <!-- Acciones derecha (desktop) -->
    <div class="header__actions">
      <button data-open-dealers class="nav__link nav__link--btn">Concesionarios más cercanos</button>
      <button aria-label="Buscar" class="header__search-btn">
        <svg xmlns="http://www.w3.org/2000/svg" class="header__search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
        </svg>
      </button>
    </div>

    <!-- Hamburguesa (móvil) -->
    <button id="menu-toggle" aria-label="Abrir menú" class="header__hamburger">
      <svg xmlns="http://www.w3.org/2000/svg" class="header__hamburger-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Línea separadora -->
  <div class="header__divider"></div>

  <!-- ── MEGA MENÚ MODELOS ──────────────────────────────────────── -->
  <div id="mega-panel" class="nav__mega-panel" role="region" aria-label="Modelos de motos">
    <div class="nav__mega-inner">
      <!-- Sidebar izquierdo -->
      <div class="nav__mega-sidebar">
        <a href="/motos" class="nav__mega-all">Todos los modelos</a>
      </div>

      <!-- Divisor -->
      <div class="nav__mega-divider" aria-hidden="true"></div>

      <!-- Grid de motos -->
      <ul class="nav__mega-grid" role="list" >
        {motos.map(moto => {
          const imgUrl = moto.fotoHeader?.asset?.url
            ? urlFor(moto.fotoHeader).width(272).fit('fill').auto('format').quality(100).url()
            : null;
          if (!imgUrl) return null;
          return (
            <li>
              <a href={`/motos/${moto.slug}`} class="nav__mega-card">
                <div class="nav__mega-card-media">
                  <img
                    src={imgUrl}
                    alt={moto.fotoHeader?.alt || moto.nombre}
                    width="360"
                    height="220"
                    loading="eager"
                    decoding="async"
                  />
                </div>
                <span class="nav__mega-card-name">{moto.nombre}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>

</header>

<!-- Menú móvil FUERA del header — evita que backdrop-filter lo atrape como containing block -->
<div id="mobile-menu" class="mobile-menu" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Menú de navegación">
  <!-- Barra superior -->
  <div class="mobile-menu__bar">
    <a href="/" class="mobile-menu__bar-logo">
      <img src="/footer/logo_footer.webp" alt="Cyclone Motos" width="140" height="32" />
    </a>
    <button id="menu-close" class="mobile-menu__close-btn" aria-label="Cerrar menú">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Contenedor deslizante -->
  <div class="mobile-menu__slider-wrap">
    <div class="mobile-menu__slider" id="mobile-slider">

      <!-- Panel principal -->
      <div class="mobile-menu__panel">
        <button id="mobile-modelos-btn" class="mobile-menu__link mobile-menu__link--sub" type="button">
          <span>Modelos</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="mobile-menu__chevron">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
        {navLinks.map(link => (
          <a href={link.href} class="mobile-menu__link">{link.label}</a>
        ))}
        <button data-open-dealers class="mobile-menu__link mobile-menu__link--btn">Concesionarios más cercanos</button>
      </div>

      <!-- Panel Modelos -->
      <div class="mobile-menu__panel">
        <div class="mobile-menu__sub-header">
          <button id="mobile-back-btn" class="mobile-menu__back-btn" type="button" aria-label="Volver">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <a href="/motos" class="mobile-menu__sub-title">Todos los modelos</a>
        </div>
        <ul class="mobile-menu__moto-list">
          {motos.map(moto => {
            const mobileImgUrl = moto.fotoHeader?.asset?.url
              ? urlFor(moto.fotoHeader).width(410).fit('fill').auto('format').quality(80).url()
              : null;
            return (
              <li>
                <a href={`/motos/${moto.slug}`} class="mobile-menu__moto-link">
                  <div class="mobile-menu__moto-img-wrap">
                    {mobileImgUrl && (
                      <img src={mobileImgUrl} alt={moto.fotoHeader?.alt || moto.nombre} width="100" height="65" loading="lazy" />
                    )}
                  </div>
                  <span class="mobile-menu__moto-name">{moto.nombre}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>

    </div>
  </div>
</div>

<script>
  const header = document.querySelector<HTMLElement>('.header');

  // Mobile menu overlay
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileSlider = document.getElementById('mobile-slider');
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const mobileModelosBtn = document.getElementById('mobile-modelos-btn');
  const mobileBackBtn = document.getElementById('mobile-back-btn');

  const openMobileMenu = () => {
    mobileMenu?.classList.add('is-open');
    mobileMenu?.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
  };

  const closeMobileMenu = () => {
    mobileMenu?.classList.remove('is-open');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTimeout(() => { mobileSlider?.classList.remove('show-sub'); }, 300);
  };

  menuToggle?.addEventListener('click', openMobileMenu);
  menuClose?.addEventListener('click', closeMobileMenu);
  mobileModelosBtn?.addEventListener('click', () => { mobileSlider?.classList.add('show-sub'); });
  mobileBackBtn?.addEventListener('click', () => { mobileSlider?.classList.remove('show-sub'); });

  // Mega menú desktop
  const navModelos = document.getElementById('nav-modelos');
  const megaPanel = document.getElementById('mega-panel');
  const megaBtn = navModelos?.querySelector('button');

  const openMega = () => {
    header?.classList.add('header--mega-open');
    megaPanel?.classList.add('is-open');
    megaBtn?.setAttribute('aria-expanded', 'true');
  };
  const closeMega = () => {
    header?.classList.remove('header--mega-open');
    megaPanel?.classList.remove('is-open');
    megaBtn?.setAttribute('aria-expanded', 'false');
  };

  navModelos?.addEventListener('mouseenter', openMega);
  navModelos?.addEventListener('mouseleave', closeMega);
  megaPanel?.addEventListener('mouseenter', openMega);
  megaPanel?.addEventListener('mouseleave', closeMega);

  let ticking = false;
  let blurTimer: number | undefined;

  const updateHeaderState = () => {
    const currentScrollY = window.scrollY;
    const isAtPageTop = currentScrollY <= 4;

    if (isAtPageTop) {
      window.clearTimeout(blurTimer);
      blurTimer = undefined;
      header?.classList.remove('header--blurred');
      header?.classList.remove('header--line-hidden');
    } else {
      header?.classList.add('header--line-hidden');

      if (!header?.classList.contains('header--blurred') && blurTimer === undefined) {
        blurTimer = window.setTimeout(() => {
          header?.classList.add('header--blurred');
          blurTimer = undefined;
        }, 980);
      }
    }

    ticking = false;
  };

  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        window.requestAnimationFrame(updateHeaderState);
        ticking = true;
      }
    },
    { passive: true }
  );
</script>

<style>
  /* ---- Header base ---- */
  .header {
    @apply w-full fixed top-0 left-0 right-0 z-[9999];
    background: linear-gradient(180deg,rgba(0,0,0,0.8) 0%,rgba(0,0,0,0.7) 0%,rgba(0,0,0,0) 100%);
    transition: background 350ms ease, backdrop-filter 900ms ease;
  }

  .header--blurred {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.62) 0%, rgba(0, 0, 0, 0.48) 100%);
    backdrop-filter: blur(4px);
  }

  .header__inner {
    @apply relative max-w-container mx-auto px-6 flex justify-between items-center gap-28 h-[80px];
  }

  .header__inner::after {
    content: '';
    position: absolute;
    left: 1.5rem;
    right: 1.5rem;
    bottom: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.9);
    transform: scaleX(1);
    transform-origin: center;
    transition: transform 1100ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header--line-hidden .header__inner::after {
    transform: scaleX(0);
  }

  /* ---- Logo ---- */
  .header__logo {
    position: relative;
    display: block;
    flex-shrink: 0;
  }

  .header__logo-img {
    @apply h-9 w-auto object-contain;
    transition: opacity 350ms ease;
  }

  .header__logo-img--mega {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    object-fit: contain;
    opacity: 0;
    pointer-events: none;
  }

  .header--mega-open .header__logo-img--default {
    opacity: 0;
  }

  .header--mega-open .header__logo-img--mega {
    opacity: 1;
    pointer-events: auto;
  }

  /* ---- Header cuando mega está abierto ---- */
  .header--mega-open {
    background: white;
    backdrop-filter: none;
  }

  .header--mega-open .nav__link,
  .header--mega-open .header__search-btn {
    color: #1a1c1c;
    transition: color 350ms ease;
  }

  .header--mega-open .header__inner::after {
    background: rgba(26, 28, 28, 0.15);
    transform: scaleX(1);
  }

  /* ---- Dropdown nav (solo el botón) ---- */
  .nav__dropdown {
    @apply relative;
  }

  .nav__dropdown-panel {
    display: none; /* eliminado, reemplazado por mega panel */
  }

  /* ---- Mega panel (full-width, debajo del header) ---- */
  .nav__mega-panel {
    position: fixed;
    top: var(--header-height, 80px);
    left: 0;
    right: 0;
    background: white;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
    border-top: 1px solid var(--color-primary);
    padding: 2rem 0 2.5rem;
    opacity: 0;
    visibility: hidden;
    clip-path: inset(0 0 100% 0);
    transition: clip-path 380ms cubic-bezier(0.16, 1, 0.3, 1), opacity 200ms ease, visibility 0ms 380ms;
    z-index: 9998;
  }

  .nav__mega-panel.is-open {
    opacity: 1;
    visibility: visible;
    clip-path: inset(0 0 0% 0);
    transition: clip-path 380ms cubic-bezier(0.16, 1, 0.3, 1), opacity 200ms ease, visibility 0ms 0ms;
  }

  .nav__mega-inner {
    max-width: var(--container-max, 80rem);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 2.5rem;
  }

  /* Sidebar izquierdo */
  .nav__mega-sidebar {
    flex-shrink: 0;
    width: 11rem;
    padding-top: 0.25rem;
  }

  .nav__mega-all {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1c1c;
    text-decoration: none;
    padding: 0.4rem 0;
    border-bottom: 2px solid var(--color-primary);
    transition: color 180ms ease;
    letter-spacing: 0.02em;
  }

  .nav__mega-all:hover {
    color: var(--color-primary);
  }

  /* Divisor vertical */
  .nav__mega-divider {
    width: 1px;
    min-height: 6rem;
    align-self: stretch;
    background: var(--color-primary);
    flex-shrink: 0;
    margin-top: -2rem;
    margin-bottom: -2.5rem;
  }

  /* Grid de motos */
  .nav__mega-grid {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 1.5rem;
    flex: 1;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Tarjeta de moto */
  .nav__mega-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    width: 17rem;
    cursor: pointer;
  }

  .nav__mega-card-media {
    width: 100%;
    overflow: hidden;
    border-radius: 2px;
  }

  .nav__mega-card-media img {
    display: block;
    width: 100%;
    height: auto;
    transform: scale(0.90);
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav__mega-card:hover .nav__mega-card-media img {
    transform: scale(1.0);
  }

  .nav__mega-card-name {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    color: #1a1c1c;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    text-align: center;
  }

  .header__divider {
    @apply h-px;
  }

  /* ---- Nav desktop ---- */
  .header__nav {
    @apply hidden lg:flex items-center gap-10;
  }

  .header__actions {
    @apply hidden lg:flex items-center gap-4 ml-auto;
  }

  .nav__link {
    @apply relative flex items-center gap-1 text-sm font-medium text-white/90 hover:text-white transition-colors duration-200 tracking-wide no-underline;
  }

  .nav__link:hover {
    text-decoration: none;
  }

  .nav__link:not(.nav__link--dropdown)::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.18rem;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav__link:not(.nav__link--dropdown):hover::after {
    transform: scaleX(1);
  }

  .nav__link--dropdown {
    @apply bg-transparent border-none cursor-pointer;
  }

  /* button reset for data-open-dealers trigger */
  .nav__link--btn {
    @apply bg-transparent border-none cursor-pointer;
  }

  .nav__arrow {
    @apply w-3.5 h-3.5 opacity-70 transition-transform duration-200;
  }

  /* Puente invisible entre el botón de Modelos y el mega panel */
  .nav__dropdown::after {
    content: '';
    position: absolute;
    top: 100%;
    left: -2rem;
    right: -2rem;
    height: 1.5rem; /* cubre el gap entre el header y el panel */
    background: transparent;
  }

  /* ---- Búsqueda ---- */
  .header__search-btn {
    @apply bg-transparent border-none cursor-pointer text-white/80 hover:text-white transition-colors duration-200;
  }

  .header__search-icon {
    @apply w-5 h-5;
  }

  /* ---- Hamburguesa ---- */
  .header__hamburger {
    @apply lg:hidden bg-transparent border-none cursor-pointer text-white;
  }

  .header__hamburger-icon {
    @apply w-6 h-6;
  }

  /* ---- Menú móvil (overlay) ---- */
  .mobile-menu {
    position: fixed;
    inset: 0;
    background: #fff;
    z-index: 10000;
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 280ms ease, transform 280ms ease;
    overflow: hidden;
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  @media (min-width: 1024px) {
    .mobile-menu { display: none !important; }
  }

  .mobile-menu__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    height: 80px;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .mobile-menu__bar-logo img {
    height: 2rem;
    width: auto;
    object-fit: contain;
  }

  .mobile-menu__close-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: #1a1c1c;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-menu__close-btn svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .mobile-menu__slider-wrap {
    flex: 1;
    overflow: hidden;
  }

  .mobile-menu__slider {
    display: flex;
    width: 200%;
    height: 100%;
    transition: transform 360ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu__slider.show-sub {
    transform: translateX(-50%);
  }

  .mobile-menu__panel {
    width: 50%;
    overflow-y: auto;
    padding: 0 1.5rem 2rem;
  }

  .mobile-menu__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: #1a1c1c;
    border-top: none;
    border-left: none;
    border-right: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    text-decoration: none;
    width: 100%;
    background: none;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
  }

  .mobile-menu__link--sub {
    /* inherits .mobile-menu__link */ 
  }

  .mobile-menu__chevron {
    width: 1.1rem;
    height: 1.1rem;
    color: #999;
    flex-shrink: 0;
  }

  .mobile-menu__sub-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    margin-bottom: 0.25rem;
  }

  .mobile-menu__back-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    color: #1a1c1c;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .mobile-menu__back-btn svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .mobile-menu__sub-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1a1c1c;
    text-decoration: none;
  }

  .mobile-menu__moto-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-menu__moto-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    text-decoration: none;
  }

  .mobile-menu__moto-img-wrap {
    width: 70%;
    flex-shrink: 0;
  }

  .mobile-menu__moto-img-wrap img {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .mobile-menu__moto-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1a1c1c;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    font-family: var(--font-heading);
  }
</style>
