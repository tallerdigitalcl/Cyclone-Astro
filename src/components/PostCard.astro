---
import type { Post } from '../lib/types';
import { urlFor } from '../lib/sanity';

interface Props {
  post: Post;
}

const { post } = Astro.props;

const formattedDate = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('es-CL', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const image = post.homeImage;
const mobileImage = image?.mobileImage;
const desktopImageUrl = image ? urlFor(image).width(900).quality(88).auto('format').url() : null;
const desktopImageUrl2x = image ? urlFor(image).width(1400).quality(84).auto('format').url() : null;
const mobileImageUrl = mobileImage?.asset?._ref
  ? urlFor(mobileImage).width(720).quality(86).auto('format').url()
  : desktopImageUrl;
const mobileImageUrl2x = mobileImage?.asset?._ref
  ? urlFor(mobileImage).width(1080).quality(82).auto('format').url()
  : desktopImageUrl2x;

const categoryLabels: Record<string, string> = {
  tips: 'Tips',
  eventos: 'Eventos',
  nuevo: 'Nuevo',
};

const categoryLabel = post.category ? categoryLabels[post.category] || post.category : null;
---

<article class="post-card">
  {image && desktopImageUrl && (
    <a href={`/noticia/${post.slug}`} class="post-card__image-link" tabindex="-1" aria-hidden="true">
      <picture>
        <source
          media="(max-width: 767px)"
          srcset={mobileImageUrl2x ? `${mobileImageUrl} 720w, ${mobileImageUrl2x} 1080w` : mobileImageUrl || undefined}
          sizes="(max-width: 767px) 100vw, 33vw"
        />
        <img
          src={desktopImageUrl}
          srcset={desktopImageUrl2x ? `${desktopImageUrl} 900w, ${desktopImageUrl2x} 1400w` : undefined}
          sizes="(max-width: 767px) 100vw, (max-width: 1279px) 50vw, 33vw"
          alt={mobileImage?.alt || image.alt || post.title}
          width="900"
          height="540"
          loading="lazy"
          decoding="async"
        />
      </picture>
    </a>
  )}
  <div class="post-card__body">
    {categoryLabel && <p class="post-card__category">{categoryLabel}</p>}
    {formattedDate && (
      <time datetime={post.publishedAt} class="post-card__date">{formattedDate}</time>
    )}
    <h2 class="post-card__title">
      <a href={`/noticia/${post.slug}`}>{post.title}</a>
    </h2>
    {post.excerpt && <p class="post-card__excerpt">{post.excerpt}</p>}
  </div>
</article>

<style>
  .post-card {
    @apply bg-white overflow-hidden;
    border: 1px solid rgba(26, 28, 28, 0.08);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .post-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .post-card__image-link {
    display: block;
    overflow: hidden;
  }

  .post-card img {
    width: 100%;
    aspect-ratio: 5 / 3;
    height: auto;
    object-fit: cover;
  }

  .post-card__body {
    @apply flex flex-col;
    gap: 0.7rem;
    padding: 1.25rem 1.4rem 1.4rem;
  }

  .post-card__category {
    @apply font-body uppercase;
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
  }

  .post-card__date {
    @apply font-body;
    color: var(--color-muted);
    display: block;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-card__title {
    @apply font-heading;
    font-size: 1.3rem;
    line-height: 1.1;
    font-weight: 700;
  }

  .post-card__title a {
    color: var(--color-text);
    transition: color 0.15s;
  }

  .post-card__title a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .post-card__excerpt {
    @apply font-body text-body;
    color: var(--color-muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.5;
  }

</style>
