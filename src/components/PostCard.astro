---
import type { Post } from '../lib/types';
import { urlFor } from '../lib/sanity';

interface Props {
  post: Post;
}

const { post } = Astro.props;

const formattedDate = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('es-CL', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<article class="post-card">
  {post.mainImage && (
    <a href={`/blog/${post.slug}`} class="post-card__image-link" tabindex="-1" aria-hidden="true">
      <img
        src={urlFor(post.mainImage).width(800).height(450).auto('format').url()}
        alt={post.mainImage.alt ?? post.title}
        width="800"
        height="450"
        loading="lazy"
        decoding="async"
      />
    </a>
  )}
  <div class="post-card__body">
    {formattedDate && (
      <time datetime={post.publishedAt} class="post-card__date">{formattedDate}</time>
    )}
    <h2 class="post-card__title">
      <a href={`/blog/${post.slug}`}>{post.title}</a>
    </h2>
    {post.excerpt && <p class="post-card__excerpt">{post.excerpt}</p>}
    {post.author && <p class="post-card__author">Por {post.author.name}</p>}
  </div>
</article>

<style>
  .post-card {
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
    background: #fff;
  }

  .post-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .post-card__image-link {
    display: block;
    overflow: hidden;
  }

  .post-card img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .post-card:hover img {
    transform: scale(1.03);
  }

  .post-card__body {
    padding: 1.25rem 1.4rem 1.4rem;
  }

  .post-card__date {
    font-size: 0.78rem;
    color: var(--color-muted);
    display: block;
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-card__title {
    font-size: 1.15rem;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .post-card__title a {
    color: var(--color-text);
    transition: color 0.15s;
  }

  .post-card__title a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .post-card__excerpt {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.5;
  }

  .post-card__author {
    font-size: 0.82rem;
    color: var(--color-muted);
  }
</style>
