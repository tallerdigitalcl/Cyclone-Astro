---
import FadeIn from '../ui/FadeIn.astro';
const instagramPosts = [
  {
    title: 'Post destacado RX 1',
    alt: 'Publicacion de Instagram de Cyclone Motos destacando la RX 1',
    src: '/home/instagram/feed/post-01.avif',
  },
  {
    title: 'Post destacado RX 401',
    alt: 'Publicacion de Instagram de Cyclone Motos destacando la RX 401',
    src: '/home/instagram/feed/post-02.avif',
  },
  {
    title: 'Post destacado RA 2',
    alt: 'Publicacion de Instagram de Cyclone Motos destacando la RA 2',
    src: '/home/instagram/feed/post-03.avif',
  },
  {
    title: 'Post destacado aventura',
    alt: 'Publicacion de Instagram de Cyclone Motos mostrando una moto de aventura',
    src: '/home/instagram/feed/post-04.avif',
  },
];

const featureImage = {
  src: '/home/instagram/feature/instagram-feature.avif',
  alt: 'Motocicleta Cyclone en escena urbana al atardecer',
};
---

<section class="instagram-section" aria-labelledby="instagram-section-title">
  <div class="instagram-section__feed-area">
    <div class="instagram-section__container">
      <header class="instagram-section__header">
        <FadeIn type="down">
          <h2 id="instagram-section-title" class="instagram-section__title">Instagram</h2>
        </FadeIn>
      </header>

      <div class="instagram-section__feed" aria-label="Galeria destacada de Instagram">
        {instagramPosts.map((post) => (
          <article class="instagram-section__post">
            <img
              src={post.src}
              alt={post.alt}
              class="instagram-section__post-image"
              width="640"
              height="800"
              loading="lazy"
              decoding="async"
            />
          </article>
        ))}
      </div>
    </div>
  </div>

  <div class="instagram-section__feature">
    <img
      src={featureImage.src}
      alt={featureImage.alt}
      class="instagram-section__feature-image"
      width="1920"
      height="1180"
      loading="lazy"
      decoding="async"
    />
  </div>
</section>

<style>
  .instagram-section {
    @apply bg-white;
  }

  .instagram-section__feed-area {
    @apply relative overflow-hidden;
    padding: var(--section-spacing) 0 2.25rem;
    background:
      linear-gradient(
        90deg,
        #8695a8 0%,
        #8897aa 14%,
        #959ead 28%,
        #98a1b0 46%,
        #9ea7b6 64%,
        #9da7b5 80%,
        #98a2b0 100%
      );
  }

  .instagram-section__container {
    @apply mx-auto;
    max-width: var(--container-max);
    padding: 0 var(--container-padding);
  }

  .instagram-section__header {
    @apply flex justify-center;
    margin-bottom: 2rem;
  }

  .instagram-section__title {
    @apply font-heading text-h2 uppercase text-text font-medium;
  }

  .instagram-section__feed {
    @apply grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .instagram-section__post {
    @apply relative overflow-hidden bg-white/10;
    aspect-ratio: 4 / 5;
    box-shadow: var(--shadow-md);
  }

  .instagram-section__post-image {
    @apply w-full h-full;
    object-fit: cover;
  }

  .instagram-section__feature {
    @apply relative overflow-hidden md:min-h-[24rem];
    background: #d7d1cb;
  }

  .instagram-section__feature::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(26, 28, 28, 1) 0%, rgba(0, 0, 0, 0.28) 20%, rgba(0, 0, 0, 0) 72%);
    pointer-events: none;
  }

  .instagram-section__feature-image {
    @apply w-full h-full;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .instagram-section__feed-area {
      padding-bottom: 2.75rem;
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.74) 0%,
          rgba(255, 255, 255, 0.58) 24%,
          rgba(255, 255, 255, 0.26) 56%,
          rgba(255, 255, 255, 0.1) 80%,
          rgba(255, 255, 255, 0) 100%
        ),
        linear-gradient(
          90deg,
          #697e99 0%,
          #7488a3 12%,
          #8395ac 24%,
          #94a3b8 40%,
          #a6b1c0 58%,
          #b7c0ca 76%,
          #c9ccd1 100%
        );
    }

    .instagram-section__feed {
      gap: 1rem;
    }

    .instagram-section__feature {
      min-height: 36rem;
    }
  }

  @media (min-width: 1024px) {
    .instagram-section__feed {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1rem;
    }

    .instagram-section__feature {
      min-height: 42rem;
    }
  }

  @media (min-width: 1280px) {
    .instagram-section__feed-area {
      background:
        linear-gradient(
          90deg,
          #8493a6 0%,
          #8897aa 10%,
          #959ead 20%,
          #949dac 32%,
          #98a1b0 45%,
          #98a1b0 58%,
          #9ca5b4 74%,
          #97a0af 100%
        );
    }

    .instagram-section__feed {
      gap: 1.1rem;
    }

    .instagram-section__feature {
      min-height: 48rem;
    }
  }
</style>
