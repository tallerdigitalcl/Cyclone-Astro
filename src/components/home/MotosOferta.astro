---
import { urlFor } from '../../lib/sanity';
import type { HomeOffer } from '../../lib/types';
import FadeIn from '../ui/FadeIn.astro';

interface Props {
  ofertas: HomeOffer[];
}

const { ofertas } = Astro.props;
const hasMultipleOffers = ofertas.length > 1;
---

{ofertas.length > 0 && (
  <section class="motos-oferta" aria-labelledby="motos-oferta-title">
    <div class="motos-oferta__container">

      <div class="motos-oferta__intro">
        <FadeIn type="left">
          <h2 id="motos-oferta-title" class="motos-oferta__title">Núestras ultimas ofertas</h2>
        </FadeIn>
        <FadeIn type="zoom-in">
          <a href="/motos" class="motos-oferta__all-link">Ver todas las ofertas</a>
        </FadeIn>
      </div>

      <!-- MOBILE: scroll nativo -->
      <div class="motos-oferta__mobile-slider" id="motos-oferta-mobile" aria-label="Listado de ofertas destacadas">
        {ofertas.map((oferta, index) => {
          const desktopUrl = urlFor(oferta.imagenFondo).width(960).quality(86).auto('format').url();
          const desktopUrl2x = urlFor(oferta.imagenFondo).width(1440).quality(82).auto('format').url();
          const mobileImage = oferta.imagenFondo.mobileImage;
          const mobileUrl = mobileImage?.asset?._ref
            ? urlFor(mobileImage).width(720).quality(84).auto('format').url()
            : desktopUrl;
          const mobileUrl2x = mobileImage?.asset?._ref
            ? urlFor(mobileImage).width(1080).quality(80).auto('format').url()
            : desktopUrl2x;
          const imageAlt = oferta.imagenFondo.alt || mobileImage?.alt || `${oferta.displayName} en oferta`;
          const offerHref = oferta.slug ? `/motos/${oferta.slug}` : '/motos';

          return (
            <a href={offerHref} class="motos-oferta__mobile-card" aria-label={`Ver oferta de ${oferta.displayName}`}>
              <div class="motos-oferta__media">
                <picture>
                  <source media="(max-width: 767px)" srcset={`${mobileUrl} 720w, ${mobileUrl2x} 1080w`} sizes="100vw" />
                  <img class="motos-oferta__image" src={desktopUrl} srcset={`${desktopUrl} 960w, ${desktopUrl2x} 1440w`} sizes="100vw" alt={imageAlt} width="960" height="1200" loading={index === 0 ? 'eager' : 'lazy'} fetchpriority={index === 0 ? 'low' : 'auto'} decoding="async" />
                </picture>
                <div class="motos-oferta__overlay" aria-hidden="true"></div>
              </div>
              <div class="motos-oferta__content">
                <div class="motos-oferta__top">
                  <h3 class="motos-oferta__name">{oferta.displayName}</h3>
                  <span class="motos-oferta__cta">Ver oferta <span aria-hidden="true">&#x2192;</span></span>
                </div>
                <div class="motos-oferta__pricing">
                  {oferta.displayListPrice && <p class="motos-oferta__list-price">Precio Lista Desde: ${oferta.displayListPrice}</p>}
                  {oferta.displayBonus && <p class="motos-oferta__bonus">Bono ${oferta.displayBonus}</p>}
                </div>
              </div>
            </a>
          );
        })}
      </div>

      {hasMultipleOffers && (
        <div class="motos-oferta__dots" id="motos-oferta-dots" aria-label="Paginacion de ofertas">
          {ofertas.map((oferta, index) => (
            <button type="button" class:list={['motos-oferta__dot', index === 0 && 'is-active']} data-offer-dot data-offer-index={index} aria-label={`Ir a la oferta ${index + 1}: ${oferta.displayName}`} aria-pressed={index === 0 ? 'true' : 'false'}></button>
          ))}
        </div>
      )}

      <!-- DESKTOP: grid estatico -->
      <div class="motos-oferta__desktop-grid" aria-label="Listado de ofertas destacadas">
        {ofertas.map((oferta, index) => {
          const desktopUrl = urlFor(oferta.imagenFondo).width(960).quality(86).auto('format').url();
          const desktopUrl2x = urlFor(oferta.imagenFondo).width(1440).quality(82).auto('format').url();
          const imageAlt = oferta.imagenFondo.alt || `${oferta.displayName} en oferta`;
          const offerHref = oferta.slug ? `/motos/${oferta.slug}` : '/motos';

          return (
            <FadeIn type="up">
              <a href={offerHref} class="motos-oferta__desktop-card" aria-label={`Ver oferta de ${oferta.displayName}`}>
                <div class="motos-oferta__media">
                  <img class="motos-oferta__image" src={desktopUrl} srcset={`${desktopUrl} 960w, ${desktopUrl2x} 1440w`} sizes="(min-width: 1280px) 26vw, 29vw" alt={imageAlt} width="960" height="1200" loading={index === 0 ? 'eager' : 'lazy'} fetchpriority={index === 0 ? 'low' : 'auto'} decoding="async" />
                  <div class="motos-oferta__overlay" aria-hidden="true"></div>
                </div>
                <div class="motos-oferta__content">
                  <div class="motos-oferta__top fade-child fade-child--left fade-delay-2">
                    <h3 class="motos-oferta__name">{oferta.displayName}</h3>
                    <span class="motos-oferta__cta">Ver oferta <span aria-hidden="true">&#x2192;</span></span>
                  </div>
                  <div class="motos-oferta__pricing fade-child fade-child--left fade-delay-3">
                    {oferta.displayListPrice && <p class="motos-oferta__list-price">Precio Lista Desde: ${oferta.displayListPrice}</p>}
                    {oferta.displayBonus && <p class="motos-oferta__bonus">Bono ${oferta.displayBonus}</p>}
                  </div>
                </div>
              </a>
            </FadeIn>
          );
        })}
      </div>

    </div>
  </section>
)}

{hasMultipleOffers && (
  <script>
    const slider = document.getElementById('motos-oferta-mobile') as HTMLElement | null;
    const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-offer-dot]'));

    if (slider && dots.length > 0) {
      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          const cards = Array.from(slider.children) as HTMLElement[];
          const card = cards[i];
          if (!card) return;
          slider.scrollTo({ left: card.offsetLeft, behavior: 'smooth' });
        });
      });

      let t: ReturnType<typeof setTimeout>;
      slider.addEventListener('scroll', () => {
        clearTimeout(t);
        t = setTimeout(() => {
          const cards = Array.from(slider.children) as HTMLElement[];
          const mid = slider.scrollLeft + slider.offsetWidth / 2;
          let closest = 0;
          let dist = Infinity;
          cards.forEach((card, i) => {
            const d = Math.abs(card.offsetLeft + card.offsetWidth / 2 - mid);
            if (d < dist) { dist = d; closest = i; }
          });
          dots.forEach((dot, i) => {
            const active = i === closest;
            dot.classList.toggle('is-active', active);
            dot.setAttribute('aria-pressed', String(active));
          });
        }, 50);
      }, { passive: true });
    }
  </script>
)}

<style>
  .motos-oferta {
    @apply relative bg-secondary text-white;
    padding: var(--section-spacing) 0;
  }

  .motos-oferta::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -1px;
    height: 3px;
    background: var(--color-secondary-dark);
    pointer-events: none;
  }

  .motos-oferta__container {
    @apply mx-auto;
    max-width: var(--container-max);
    padding: 0 var(--container-padding);
  }

  .motos-oferta__intro {
    @apply flex flex-col items-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .motos-oferta__title {
    @apply font-heading text-white uppercase text-h2 md:max-w-[8ch];
    font-weight: 700;
  }

  .motos-oferta__all-link {
    @apply inline-flex items-center justify-center no-underline uppercase;
    min-height: 3rem;
    padding: 0.85rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.58);
    background-image: radial-gradient(circle at center, #ffffff 0%, #ffffff 54%, transparent 55%);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 0% 0%;
    color: var(--color-text-light);
    font-family: var(--font-body);
    font-size: var(--text-button);
    font-weight: 700;
    letter-spacing: 0.08em;
    transition: background-size 360ms ease-in-out, border-color var(--transition-base), color var(--transition-base);
  }

  .motos-oferta__all-link:hover {
    background-size: 260% 260%;
    border-color: #ffffff;
    color: #000000;
    text-decoration: none;
  }

  /* --- MOBILE SLIDER --------------------------------------- */
  .motos-oferta__mobile-slider {
    display: flex;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .motos-oferta__mobile-slider::-webkit-scrollbar {
    display: none;
  }

  .motos-oferta__mobile-card {
    @apply relative overflow-hidden no-underline flex flex-col;
    flex-shrink: 0;
    width: 100%;
    min-height: 25rem;
    scroll-snap-align: start;
    background: var(--color-secondary-dark);
    color: var(--color-text-light);
  }

  .motos-oferta__mobile-card:hover { text-decoration: none; }

  /* --- DESKTOP GRID: hidden on mobile ---------------------- */
  .motos-oferta__desktop-grid {
    display: none;
  }

  /* --- DOTS ------------------------------------------------- */
  .motos-oferta__dots {
    @apply flex items-center justify-center;
    gap: 0.25rem;
    margin-top: 0.9rem;
  }

  .motos-oferta__dot {
    @apply relative inline-flex items-center justify-center rounded-full border-0 p-0;
    width: 2.75rem;
    height: 2.75rem;
    background: transparent;
  }

  .motos-oferta__dot::before {
    content: '';
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.42);
    transition: background-color var(--transition-base), transform var(--transition-base);
  }

  .motos-oferta__dot.is-active::before {
    background: #ffffff;
    transform: scale(1.05);
  }

  /* --- SHARED CARD INTERNALS -------------------------------- */
  .motos-oferta__media {
    @apply absolute inset-0;
  }

  .motos-oferta__image {
    @apply block w-full h-full;
    object-fit: cover;
  }

  .motos-oferta__overlay {
    @apply absolute inset-0;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.18) 34%, rgba(0,0,0,0.62) 100%),
      linear-gradient(0deg, rgba(0,0,0,0.32) 0%, rgba(0,0,0,0) 38%);
  }

  .motos-oferta__content {
    @apply relative z-10 flex flex-col justify-between;
    flex: 1;
    padding: 1.5rem;
  }

  .motos-oferta__top {
    @apply flex flex-col;
    gap: 0.5rem;
  }

  .motos-oferta__name {
    @apply font-heading text-white uppercase text-h3;
    font-weight: 700;
    max-width: 8ch;
  }

  .motos-oferta__cta {
    @apply relative inline-flex items-center gap-2 uppercase;
    width: fit-content;
    font-family: var(--font-body);
    font-size: var(--text-button);
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .motos-oferta__cta::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -0.18rem;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .motos-oferta__mobile-card:hover .motos-oferta__cta::after,
  .motos-oferta__desktop-card:hover .motos-oferta__cta::after {
    transform: scaleX(1);
  }

  .motos-oferta__pricing {
    @apply flex flex-col items-end;
    gap: 0.35rem;
    text-align: right;
    overflow: hidden;
  }

  .motos-oferta__list-price {
    @apply font-body text-body-lg;
    color: rgba(255, 255, 255, 0.92);
    white-space: nowrap;
  }

  .motos-oferta__bonus {
    @apply font-heading text-white text-h3;
    font-weight: 700;
  }

  /* --- DESKTOP =1024px -------------------------------------- */
  @media (min-width: 1024px) {
    .motos-oferta__container {
      display: grid;
      grid-template-columns: minmax(14rem, 18rem) minmax(0, 1fr);
      gap: 2.5rem;
      align-items: start;
    }

    .motos-oferta__intro {
      margin-bottom: 0;
      padding-top: 0.5rem;
    }

    .motos-oferta__mobile-slider,
    .motos-oferta__dots {
      display: none;
    }

    .motos-oferta__desktop-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .motos-oferta__desktop-card {
      @apply relative overflow-hidden no-underline flex flex-col;
      min-height: 26rem;
      background: var(--color-secondary-dark);
      color: var(--color-text-light);
    }

    .motos-oferta__desktop-card:hover { text-decoration: none; }
  }

  @media (min-width: 1280px) {
    .motos-oferta__container { gap: 2.75rem; }
    .motos-oferta__desktop-grid { gap: 1.25rem; }
    .motos-oferta__content { padding: 1.7rem; }
  }
</style>
