---
import { urlFor } from '../../lib/sanity';
import type { HomeOffer } from '../../lib/types';

interface Props {
  ofertas: HomeOffer[];
}

const { ofertas } = Astro.props;
const hasMultipleOffers = ofertas.length > 1;
---

{ofertas.length > 0 && (
  <section class="motos-oferta" aria-labelledby="motos-oferta-title">
    <div class="motos-oferta__container">
      <div class="motos-oferta__intro">
        <h2 id="motos-oferta-title" class="motos-oferta__title">Nuestras ultimas ofertas</h2>
        <a href="/motos" class="motos-oferta__all-link">Ver todas las ofertas</a>
      </div>

      <div class="motos-oferta__cards" aria-label="Listado de ofertas destacadas">
        {ofertas.map((oferta, index) => {
          const desktopUrl = urlFor(oferta.imagenFondo).width(960).height(1200).quality(78).auto('format').url();
          const desktopUrl2x = urlFor(oferta.imagenFondo).width(1440).height(1800).quality(72).auto('format').url();
          const mobileImage = oferta.imagenFondo.mobileImage;
          const mobileUrl = mobileImage?.asset?._ref
            ? urlFor(mobileImage).width(720).height(960).quality(76).auto('format').url()
            : desktopUrl;
          const mobileUrl2x = mobileImage?.asset?._ref
            ? urlFor(mobileImage).width(1080).height(1440).quality(70).auto('format').url()
            : desktopUrl2x;
          const imageAlt = oferta.imagenFondo.alt || mobileImage?.alt || `${oferta.displayName} en oferta`;
          const offerHref = oferta.slug ? `/motos/${oferta.slug}` : '/motos';

          return (
            <a
              href={offerHref}
              class="motos-oferta__card"
              aria-label={`Ver oferta de ${oferta.displayName}`}
            >
              <div class="motos-oferta__media">
                <picture>
                  <source
                    media="(max-width: 767px)"
                    srcset={`${mobileUrl} 720w, ${mobileUrl2x} 1080w`}
                    sizes="84vw"
                  />
                  <img
                    class="motos-oferta__image"
                    src={desktopUrl}
                    srcset={`${desktopUrl} 960w, ${desktopUrl2x} 1440w`}
                    sizes="(min-width: 1280px) 26vw, (min-width: 1024px) 29vw, 84vw"
                    alt={imageAlt}
                    width="960"
                    height="1200"
                    loading={index === 0 ? 'eager' : 'lazy'}
                    fetchpriority={index === 0 ? 'low' : 'auto'}
                    decoding="async"
                  />
                </picture>
                <div class="motos-oferta__overlay" aria-hidden="true"></div>
              </div>

              <div class="motos-oferta__content">
                <div class="motos-oferta__top">
                  <h3 class="motos-oferta__name">{oferta.displayName}</h3>
                  <span class="motos-oferta__cta">
                    Ver oferta
                    <span aria-hidden="true" class="motos-oferta__cta-arrow">→</span>
                  </span>
                </div>

                <div class="motos-oferta__pricing">
                  {oferta.displayListPrice && (
                    <p class="motos-oferta__list-price">Precio Lista Desde: ${oferta.displayListPrice}</p>
                  )}
                  {oferta.displayBonus && <p class="motos-oferta__bonus">Bono ${oferta.displayBonus}</p>}
                </div>
              </div>
            </a>
          );
        })}
      </div>

      {hasMultipleOffers && (
        <div class="motos-oferta__dots" id="motos-oferta-dots" aria-label="Paginacion de ofertas">
          {ofertas.map((oferta, index) => (
            <button
              type="button"
              class:list={['motos-oferta__dot', index === 0 && 'is-active']}
              data-offer-dot
              data-offer-index={index}
              aria-label={`Ir a la oferta ${index + 1}: ${oferta.displayName}`}
              aria-pressed={index === 0 ? 'true' : 'false'}
            ></button>
          ))}
        </div>
      )}
    </div>
  </section>
)}

{hasMultipleOffers && (
  <script>
    const offersViewport = document.querySelector('.motos-oferta__cards');
    const offerDots = Array.from(document.querySelectorAll('[data-offer-dot]'));
    const offerCards = Array.from(document.querySelectorAll('.motos-oferta__card'));

    function setActiveOfferDot(activeIndex) {
      offerDots.forEach((dot, index) => {
        const isActive = index === activeIndex;
        dot.classList.toggle('is-active', isActive);
        dot.setAttribute('aria-pressed', String(isActive));
      });
    }

    offerDots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        const targetCard = offerCards[index];
        if (!targetCard) return;

        targetCard.scrollIntoView({
          block: 'nearest',
          inline: 'start',
          behavior: 'smooth',
        });
      });
    });

    if (offersViewport && offerCards.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          const visibleEntry = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

          if (!visibleEntry) return;

          const activeIndex = offerCards.indexOf(visibleEntry.target);
          if (activeIndex >= 0) {
            setActiveOfferDot(activeIndex);
          }
        },
        {
          root: offersViewport,
          threshold: [0.6, 0.75, 0.9],
        }
      );

      offerCards.forEach((card) => observer.observe(card));
    }
  </script>
)}

<style>
  .motos-oferta {
    @apply bg-secondary text-white;
    padding: var(--section-spacing) 0;
  }

  .motos-oferta__container {
    @apply mx-auto;
    max-width: var(--container-max);
    padding: 0 var(--container-padding);
  }

  .motos-oferta__intro {
    @apply flex flex-col items-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .motos-oferta__title {
    @apply font-heading text-white uppercase text-h2 md:max-w-[8ch];
    font-weight: 700;
  }

  .motos-oferta__all-link {
    @apply inline-flex items-center justify-center no-underline uppercase;
    min-height: 3rem;
    padding: 0.85rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.58);
    color: var(--color-text-light);
    font-family: var(--font-body);
    font-size: var(--text-button);
    font-weight: 700;
    letter-spacing: 0.08em;
    transition:
      border-color var(--transition-base),
      background-color var(--transition-base),
      color var(--transition-base);
  }

  .motos-oferta__all-link:hover {
    border-color: rgba(255, 255, 255, 0.86);
    background: rgba(255, 255, 255, 0.08);
    text-decoration: none;
  }

  .motos-oferta__cards {
    @apply flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .motos-oferta__cards::-webkit-scrollbar {
    display: none;
  }

  .motos-oferta__dots {
    @apply flex items-center justify-center;
    gap: 0.25rem;
    margin-top: 0.9rem;
  }

  .motos-oferta__dot {
    @apply relative inline-flex items-center justify-center rounded-full border-0 p-0 transition-opacity duration-200;
    width: 2.75rem;
    height: 2.75rem;
    background: transparent;
  }

  .motos-oferta__dot::before {
    content: '';
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.42);
    transition: background-color var(--transition-base), transform var(--transition-base);
  }

  .motos-oferta__dot.is-active::before {
    background: #ffffff;
    transform: scale(1.05);
  }

  .motos-oferta__card {
    @apply relative overflow-hidden no-underline;
    flex: 0 0 min(84vw, 24rem);
    min-height: 25rem;
    aspect-ratio: 5 / 5;
    scroll-snap-align: start;
    background: var(--color-secondary-dark);
    color: var(--color-text-light);
  }

  .motos-oferta__card:hover {
    text-decoration: none;
  }

  .motos-oferta__media {
    @apply absolute inset-0;
  }

  .motos-oferta__image {
    @apply w-full h-full;
    object-fit: cover;
  }

  .motos-oferta__overlay {
    @apply absolute inset-0;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.18) 34%, rgba(0, 0, 0, 0.62) 100%),
      linear-gradient(0deg, rgba(0, 0, 0, 0.32) 0%, rgba(0, 0, 0, 0) 38%);
  }

  .motos-oferta__content {
    @apply relative z-10 h-full flex flex-col justify-between;
    padding: 1.5rem;
  }

  .motos-oferta__top {
    @apply flex flex-col;
    gap: 0.5rem;
  }

  .motos-oferta__name {
    @apply font-heading text-white uppercase text-h3;
    font-weight: 700;
    max-width: 8ch;
  }

  .motos-oferta__cta {
    @apply inline-flex items-center gap-2 uppercase;
    width: fit-content;
    font-family: var(--font-body);
    font-size: var(--text-button);
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .motos-oferta__cta-arrow {
    font-size: 1rem;
  }

  .motos-oferta__pricing {
    @apply flex flex-col items-end;
    gap: 0.35rem;
    text-align: right;
  }

  .motos-oferta__list-price {
    @apply font-body text-body-lg;
    color: rgba(255, 255, 255, 0.92);
  }

  .motos-oferta__bonus {
    @apply font-heading text-white text-h3;
    font-weight: 700;
  }

  @media (min-width: 1024px) {
    .motos-oferta__container {
      display: grid;
      grid-template-columns: minmax(14rem, 18rem) minmax(0, 1fr);
      gap: 2.5rem;
      align-items: start;
    }

    .motos-oferta__intro {
      margin-bottom: 0;
      padding-top: 0.5rem;
    }

    .motos-oferta__cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      overflow: visible;
      padding-bottom: 0;
      scroll-snap-type: none;
    }

    .motos-oferta__card {
      min-height: 21rem;
      flex-basis: auto;
    }

    .motos-oferta__dots {
      display: none;
    }
  }

  @media (min-width: 1280px) {
    .motos-oferta__container {
      gap: 2.75rem;
    }

    .motos-oferta__cards {
      gap: 1.25rem;
    }

    .motos-oferta__content {
      padding: 1.7rem;
    }
  }
</style>
