---
import { urlFor } from '../../lib/sanity';
import type { Post } from '../../lib/types';
import FadeIn from '../ui/FadeIn.astro';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

const sortedPosts = [...posts].sort((a, b) => {
  const dateA = a.publishedAt ? new Date(a.publishedAt).getTime() : 0;
  const dateB = b.publishedAt ? new Date(b.publishedAt).getTime() : 0;
  return dateB - dateA;
});
const categoryLabels: Record<string, string> = {
  tips: 'Tips',
  eventos: 'Eventos',
  nuevo: 'Nuevo',
};

const categoryCounts = sortedPosts.reduce<Record<string, number>>((counts, post) => {
  if (post.category) {
    counts[post.category] = (counts[post.category] || 0) + 1;
  }

  return counts;
}, {});
const availableCategories = Object.keys(categoryCounts).filter((category) => categoryCounts[category] >= 5);
const filters = [
  { label: 'Todas', value: 'all' },
  ...availableCategories.map((category) => ({ label: categoryLabels[category] || category, value: category })),
];
---

{sortedPosts.length > 0 && (
  <section class="latest-news" aria-labelledby="latest-news-title">
    <div class="latest-news__container">
      <div class="latest-news__header">
        <FadeIn type="left">
        <h2 id="latest-news-title" class="latest-news__title">Noticias</h2>
        </FadeIn>
        <FadeIn type="right">
          <div class="latest-news__filters" aria-label="Categorias destacadas">
            {filters.map((filter, index) => (
              <button
                type="button"
                class:list={['latest-news__filter', index === 0 && 'is-active']}
                data-latest-news-filter={filter.value}
                aria-pressed={index === 0 ? 'true' : 'false'}
              >
                {filter.label}
              </button>
            ))}
          </div>
        </FadeIn>
      </div>

      <div class="latest-news__grid" data-latest-news-grid>
        {sortedPosts.map((post, index) => {
          const image = post.homeImage;
          const mobileImage = image?.mobileImage;
          const desktopUrl = image ? urlFor(image).width(960).quality(88).auto('format').url() : null;
          const desktopUrl2x = image ? urlFor(image).width(1440).quality(84).auto('format').url() : null;
          const mobileUrl = mobileImage?.asset?._ref
            ? urlFor(mobileImage).width(420).quality(86).auto('format').url()
            : desktopUrl;
          const mobileUrl2x = mobileImage?.asset?._ref
            ? urlFor(mobileImage).width(420).quality(74).auto('format').url()
            : desktopUrl2x;
          const imageAlt = mobileImage?.alt || image?.alt || post.homeTitle || post.title;
          const category = post.category ? categoryLabels[post.category] || post.category : null;
          const title = post.homeTitle || post.title;

          return (
            <FadeIn
              type="up"
              class:list={['latest-news__slide', index >= 5 && 'is-hidden', index === 0 && 'latest-news__slide--featured']}
              data-latest-news-card
              data-category={post.category || 'sin-categoria'}
              data-published={post.publishedAt || ''}
            >
              <article class:list={['latest-news__card', index === 0 && 'latest-news__card--featured']}>
                {image && desktopUrl && (
                  <a href={`/noticias/${post.slug}`} class="latest-news__image-link" aria-hidden="true" tabindex="-1">
                    <picture>
                      <source
                        media="(max-width: 767px)"
                        srcset={mobileUrl2x ? `${mobileUrl} 420w, ${mobileUrl2x} 420w` : mobileUrl || undefined}
                        sizes="(max-width: 1023px) 100vw, 33vw"
                      />
                      <img
                        src={desktopUrl}
                        srcset={desktopUrl2x ? `${desktopUrl} 960w, ${desktopUrl2x} 1440w` : undefined}
                        sizes={index === 0 ? '(min-width: 1024px) 32vw, 100vw' : '(min-width: 1024px) 20vw, 100vw'}
                        alt={imageAlt}
                        width="960"
                        height="600"
                        class="latest-news__image"
                        loading={index === 0 ? 'eager' : 'lazy'}
                        fetchpriority={index === 0 ? 'low' : 'auto'}
                        decoding="async"
                      />
                    </picture>
                  </a>
                )}

                <div class="latest-news__body">
                  {category && <p class="latest-news__category fade-child fade-child--left fade-delay-2">{category}</p>}
                  <h3 class="latest-news__card-title fade-child fade-child--left fade-delay-3">
                    <a href={`/noticias/${post.slug}`}>{title}</a>
                  </h3>
                  {post.excerpt && <p class="latest-news__excerpt fade-child fade-child--left fade-delay-3">{post.excerpt}</p>}
                  <a href={`/noticias/${post.slug}`} class="latest-news__cta fade-child fade-child--zoom-in fade-delay-4">Leer mas</a>
                </div>
              </article>
            </FadeIn>
          );
        })}
      </div>
    </div>

    <script>
      const HOME_NEWS_LIMIT = 5;
      const newsCards = Array.from(document.querySelectorAll<HTMLElement>('[data-latest-news-card]'));
      const newsFilters = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-latest-news-filter]'));

      const getCardDate = (card: HTMLElement) => {
        const parsedDate = Date.parse(card.dataset.published || '');
        return Number.isNaN(parsedDate) ? 0 : parsedDate;
      };

      const renderLatestNews = (category = 'all') => {
        const visibleCards = newsCards
          .filter((card) => category === 'all' || card.dataset.category === category)
          .sort((a, b) => getCardDate(b) - getCardDate(a))
          .slice(0, HOME_NEWS_LIMIT);

        const visibleSet = new Set(visibleCards);

        newsCards.forEach((card) => {
          const cardArticle = card.querySelector('.latest-news__card');
          const visibleIndex = visibleCards.indexOf(card);

          card.classList.toggle('is-hidden', !visibleSet.has(card));
          card.classList.toggle('latest-news__slide--featured', visibleIndex === 0);
          cardArticle?.classList.toggle('latest-news__card--featured', visibleIndex === 0);
          card.style.order = visibleIndex >= 0 ? String(visibleIndex) : '99';
        });
      };

      newsFilters.forEach((filter) => {
        filter.addEventListener('click', () => {
          const category = filter.dataset.latestNewsFilter || 'all';

          newsFilters.forEach((item) => {
            const isActive = item === filter;
            item.classList.toggle('is-active', isActive);
            item.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          });

          renderLatestNews(category);
        });
      });

      renderLatestNews();
    </script>
  </section>
)}

<style>
  .latest-news {
    @apply relative bg-secondary text-white;
    padding: var(--section-spacing) 0;
    margin-top: -2px;
    z-index: 1;
  }

  .latest-news__container {
    @apply mx-auto;
    max-width: var(--container-max);
    padding: 0 var(--container-padding);
  }

  .latest-news__header {
    @apply flex flex-col gap-4;
    margin-bottom: 2rem;
  }

  .latest-news__title {
    @apply font-heading text-white uppercase text-h2;
    font-weight: 700;
  }

  .latest-news__filters {
    @apply flex flex-wrap gap-2;
  }

  .latest-news__filter {
    @apply inline-flex items-center justify-center uppercase;
    min-height: 2.5rem;
    padding: 0.65rem 1.15rem;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: transparent;
    color: rgba(255, 255, 255, 0.88);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .latest-news__filter.is-active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #ffffff;
  }

  .latest-news__grid {
    @apply grid;
    gap: 1.75rem;
  }

  :global(.latest-news__slide.is-hidden) {
    display: none;
  }

  .latest-news__card {
    @apply bg-white text-text overflow-hidden;
  }

  .latest-news__image-link {
    @apply block;
  }

  .latest-news__image {
    @apply w-full h-full;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .latest-news__body {
    @apply flex flex-col;
    gap: 0.9rem;
    padding: 1.3rem 1.15rem 1.25rem;
  }

  .latest-news__category {
    @apply font-body uppercase;
    color: var(--color-primary);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
  }

  .latest-news__card-title {
    @apply font-heading uppercase;
    font-size: 1.6rem;
    line-height: 1.05;
    font-weight: 700;
  }

  .latest-news__card-title a {
    color: inherit;
  }

  .latest-news__card-title a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .latest-news__excerpt {
    @apply font-body text-body;
    color: rgba(26, 28, 28, 0.74);
    line-height: 1.55;
  }

  .latest-news__cta {
    @apply relative inline-flex items-center uppercase no-underline;
    width: fit-content;
    margin-top: auto;
    color: var(--color-primary);
    font-family: var(--font-body);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.1em;
  }

  .latest-news__cta::before {
    content: '';
    position: absolute;
    left: 0;
    right: 1.2rem;
    bottom: -0.18rem;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .latest-news__cta::after {
    content: '→';
    margin-left: 0.55rem;
  }

  .latest-news__cta:hover {
    color: var(--color-primary-dark);
    text-decoration: none;
  }

  .latest-news__cta:hover::before {
    transform: scaleX(1);
  }

  @media (min-width: 768px) {
    .latest-news__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.1rem;
    }

    :global(.latest-news__slide--featured) {
      grid-column: 1 / -1;
    }

    :global(.latest-news__slide--featured) .latest-news__card--featured {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.9fr);
    }

    :global(.latest-news__slide--featured) .latest-news__card--featured .latest-news__image {
      aspect-ratio: 16 / 10;
      min-height: 18rem;
    }
  }

  @media (min-width: 1024px) {
    .latest-news__header {
      @apply flex-row items-start justify-between;
    }

    .latest-news__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    :global(.latest-news__slide--featured) {
      grid-column: span 2;
    }

    :global(.latest-news__slide--featured) .latest-news__card--featured {
      height: 100%;
    }
  }
</style>
