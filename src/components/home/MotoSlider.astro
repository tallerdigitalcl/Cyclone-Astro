---
import { urlFor } from '../../lib/sanity';
import type { HomeSliderMoto } from '../../lib/types';
import Button from '../ui/Button.astro';
import FadeIn from '../ui/FadeIn.astro';

interface Props {
  motos: HomeSliderMoto[];
}

const { motos } = Astro.props;
const hasMultipleSlides = motos.length > 1;
---

{motos.length > 0 && (
  <section class="moto-slider" aria-labelledby="moto-slider-title">
    <div class="moto-slider__container">
      <div class="moto-slider__header">
        <FadeIn type="left">
          <h2 id="moto-slider-title" class="moto-slider__title">Elige la moto de tus sueños</h2>
        </FadeIn>

        {hasMultipleSlides && (
          <div class="moto-slider__controls" aria-label="Controles del slider">
            <button
              type="button"
              class="moto-slider__control"
              id="moto-slider-prev"
              aria-label="Ver motos anteriores"
              disabled
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" class="moto-slider__control-icon">
                <path d="m14.7 6.3-1.4-1.4L6.2 12l7.1 7.1 1.4-1.4L9.6 13H20v-2H9.6l5.1-4.7Z" fill="currentColor" />
              </svg>
            </button>
            <button
              type="button"
              class="moto-slider__control moto-slider__control--primary"
              id="moto-slider-next"
              aria-label="Ver motos siguientes"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" class="moto-slider__control-icon">
                <path d="m9.3 17.7 1.4 1.4 7.1-7.1-7.1-7.1-1.4 1.4L14.4 11H4v2h10.4l-5.1 4.7Z" fill="currentColor" />
              </svg>
            </button>
          </div>
        )}
      </div>

      <div class="moto-slider__viewport" id="moto-slider-viewport">
        <div class="moto-slider__track" id="moto-slider-track">
          {motos.map((moto, index) => {
            const imageUrl = urlFor(moto.imagenSliderHome).width(960).quality(86).auto('format').url();
            const imageUrl2x = urlFor(moto.imagenSliderHome).width(1440).quality(82).auto('format').url();
            const imageAlt = moto.imagenSliderHome?.alt || `${moto.displayName} de Cyclone Motos`;

            return (
              <div class="moto-slider__slide">
                <FadeIn type="up">
                <article class="moto-slider__card" aria-labelledby={`moto-slider-card-${moto._id}`}>
                  <div class="moto-slider__media">
                    <img
                      class="moto-slider__image"
                      src={imageUrl}
                      srcset={`${imageUrl} 960w, ${imageUrl2x} 1440w`}
                      sizes="(min-width: 1280px) 33vw, (min-width: 768px) 46vw, 82vw"
                      alt={imageAlt}
                      width="960"
                      height="1120"
                      loading={index < 2 ? 'eager' : 'lazy'}
                      fetchpriority={index < 2 ? 'low' : 'auto'}
                      decoding="async"
                    />
                    <div class="moto-slider__overlay" aria-hidden="true"></div>
                  </div>

                  <div class="moto-slider__content">
                    <h3 id={`moto-slider-card-${moto._id}`} class="moto-slider__name fade-child fade-child--left fade-delay-2">
                      {moto.displayName}
                    </h3>

                    <div class="moto-slider__pricing fade-child fade-child--left fade-delay-3">
                      {moto.displayListPrice && <p class="moto-slider__list-price">{moto.displayListPrice}</p>}
                      {moto.displayPrice && <p class="moto-slider__price">{moto.displayPrice}</p>}
                    </div>

                    <div class="moto-slider__actions fade-child fade-child--zoom-in fade-delay-4">
                      <Button type="button" size="md" class="md:min-w-40">
                        Cotizar
                      </Button>
                      <Button href={`/motos/${moto.slug}`} variant="secondary" size="md" class="md:min-w-40">
                        Ver modelo
                      </Button>
                    </div>
                  </div>
                </article>
                </FadeIn>
              </div>
            );
          })}
        </div>
      </div>

      {hasMultipleSlides && (
        <div class="moto-slider__dots md:hidden" id="moto-slider-dots" aria-label="Paginacion del slider">
          {motos.map((moto, index) => (
            <button
              type="button"
              class:list={['moto-slider__dot', index === 0 && 'is-active']}
              data-slider-dot
              data-slider-index={index}
              aria-label={`Ir a la moto ${index + 1}: ${moto.displayName}`}
              aria-pressed={index === 0 ? 'true' : 'false'}
            ></button>
          ))}
        </div>
      )}
    </div>
  </section>
)}

<script>
  const track = document.getElementById('moto-slider-track') as HTMLElement | null;
  const prevBtn = document.getElementById('moto-slider-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('moto-slider-next') as HTMLButtonElement | null;
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-slider-dot]'));
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.moto-slider__slide'));

  if (track && slides.length > 0) {
    let currentIndex = 0;

    function getSlidesPerView(): number {
      return window.innerWidth >= 992 ? 2 : 1;
    }

    function getMaxIndex(): number {
      return Math.max(0, slides.length - getSlidesPerView());
    }

    function getOffset(index: number): number {
      const gap = parseFloat(getComputedStyle(track!).gap) || 0;
      const slideWidth = slides[0]?.offsetWidth ?? 0;
      return index * (slideWidth + gap);
    }

    function goTo(index: number): void {
      const clamped = Math.max(0, Math.min(getMaxIndex(), index));
      currentIndex = clamped;
      track!.style.transform = `translateX(-${getOffset(clamped)}px)`;
      updateDots();
      updateButtons();
    }

    function updateDots(): void {
      dots.forEach((dot, i) => {
        const active = i === currentIndex;
        dot.classList.toggle('is-active', active);
        dot.setAttribute('aria-pressed', String(active));
      });
    }

    function updateButtons(): void {
      if (prevBtn) prevBtn.disabled = currentIndex === 0;
      if (nextBtn) nextBtn.disabled = currentIndex >= getMaxIndex();
    }

    prevBtn?.addEventListener('click', () => goTo(currentIndex - 1));
    nextBtn?.addEventListener('click', () => goTo(currentIndex + 1));

    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    // ── Touch / swipe support ────────────────────────────────
    const viewport = document.getElementById('moto-slider-viewport');
    if (viewport) {
      let touchStartX = 0;
      let touchStartY = 0;
      let isDragging = false;
      let lockedAxis: 'x' | 'y' | null = null;

      viewport.addEventListener('touchstart', (e: TouchEvent) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        isDragging = false;
        lockedAxis = null;
        // Remove transition so drag feels immediate
        track!.style.transition = 'none';
      }, { passive: true });

      viewport.addEventListener('touchmove', (e: TouchEvent) => {
        const dx = e.touches[0].clientX - touchStartX;
        const dy = e.touches[0].clientY - touchStartY;

        // Lock axis on first meaningful movement
        if (!lockedAxis) {
          if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 4) {
            lockedAxis = 'x';
          } else if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 4) {
            lockedAxis = 'y';
          } else {
            return;
          }
        }

        if (lockedAxis !== 'x') return;

        isDragging = true;
        e.preventDefault();

        const baseOffset = getOffset(currentIndex);
        // Add slight resistance at the edges
        let drag = dx;
        if ((currentIndex === 0 && dx > 0) || (currentIndex >= getMaxIndex() && dx < 0)) {
          drag = dx * 0.25;
        }
        track!.style.transform = `translateX(${-baseOffset + drag}px)`;
      }, { passive: false });

      viewport.addEventListener('touchend', (e: TouchEvent) => {
        if (!isDragging) {
          // Restore transition in case axis was never locked
          track!.style.transition = '';
          return;
        }

        const dx = e.changedTouches[0].clientX - touchStartX;
        const slideWidth = slides[0]?.offsetWidth ?? 0;
        const threshold = slideWidth * 0.25; // 25% of slide width to commit

        // Restore transition before snapping
        track!.style.transition = '';

        if (dx < -threshold) {
          goTo(currentIndex + 1);
        } else if (dx > threshold) {
          goTo(currentIndex - 1);
        } else {
          // Snap back to current
          goTo(currentIndex);
        }
      }, { passive: true });
    }

    // Recalculate position on resize
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        const maxIdx = getMaxIndex();
        if (currentIndex > maxIdx) currentIndex = maxIdx;
        track!.style.transition = 'none';
        track!.style.transform = `translateX(-${getOffset(currentIndex)}px)`;
        requestAnimationFrame(() => {
          track!.style.transition = '';
        });
        updateButtons();
        updateDots();
      }, 150);
    });

    updateButtons();
    updateDots();
  }
</script>

<style>
  .moto-slider {
    @apply relative overflow-hidden;
    z-index: 1;
    --moto-slider-band-gradient: linear-gradient(
      90deg,
      #05788f 0%,
      #1b839c 24%,
      #4d99b1 58%,
      #79b6c9 82%,
      #90c1d5 100%
    );
    padding: 5rem 0 8rem 0;
    background-image:
      linear-gradient(
        180deg,
        #ffffff 0%,
        rgba(255, 255, 255, 0.94) 10%,
        rgba(255, 255, 255, 0.72) 30%,
        rgba(255, 255, 255, 0.28) 70%,
        rgba(255, 255, 255, 0) 100%
      ),
      var(--moto-slider-band-gradient);
    background-position: bottom, bottom;
    background-repeat: no-repeat;
    background-size: 100% 65%, 100% 65%;
  }

  .moto-slider::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 3px;
    background: var(--moto-slider-band-gradient);
    pointer-events: none;
  }

  .moto-slider__container {
    @apply mx-auto;
    max-width: var(--container-max);
    padding: 0 var(--container-padding);
  }

  .moto-slider__header {
    @apply flex items-end justify-between gap-4;
    margin-bottom: 2rem;
  }

  .moto-slider__title {
    @apply font-heading uppercase text-text text-h2;
    font-weight: 700;
  }

  .moto-slider__controls {
    @apply hidden md:flex items-center gap-3 shrink-0;
  }

  .moto-slider__control {
    @apply inline-flex items-center justify-center border transition-colors duration-200;
    overflow: hidden;
    width: 3rem;
    height: 3rem;
    border-color: rgba(214, 0, 15, 0.35);
    background: transparent;
    color: var(--color-primary);
  }

  .moto-slider__control:hover:not(:disabled) {
    border-color: var(--color-primary);
  }

  .moto-slider__control:disabled,
  .moto-slider__control[disabled] {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }

  .moto-slider__control--primary {
    background: var(--color-primary);
    background-image: radial-gradient(circle at center, #ffffff 0%, #ffffff 54%, transparent 55%);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 0% 0%;
    color: var(--color-text-light);
    transition:
      background-size 360ms ease-in-out,
      border-color var(--transition-base),
      color var(--transition-base);
  }

  .moto-slider__control--primary:hover:not(:disabled) {
    background-size: 260% 260%;
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .moto-slider__control-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .moto-slider__viewport {
    overflow: visible;
  }

  .moto-slider__track {
    @apply flex;
    gap: 1rem;
    transition: transform 0.42s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .moto-slider__slide {
    flex-shrink: 0;
    flex-grow: 0;
    width: 100%;
    min-width: 0;
  }

  .moto-slider__card {
    @apply relative overflow-hidden;
    aspect-ratio: 4 / 5;
    background: var(--color-secondary-dark);
  }

  .moto-slider__media {
    @apply absolute inset-0;
  }

  .moto-slider__image {
    @apply block w-full h-full;
    object-fit: cover;
  }

  .moto-slider__overlay {
    @apply absolute inset-0;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.16) 0%, rgba(0, 0, 0, 0.38) 62%, rgba(0, 0, 0, 0.76) 100%),
      linear-gradient(90deg, rgba(0, 0, 0, 0.34) 0%, rgba(0, 0, 0, 0.08) 46%, rgba(0, 0, 0, 0) 100%);
  }

  .moto-slider__content {
    @apply relative z-10 h-full flex flex-col justify-between;
    padding: 1.5rem;
  }

  /* ── Inner element animations ───────────────────────────── */
  /* Handled by FadeIn.astro utilities: fade-child, fade-child--{dir}, fade-delay-{n} */

  .moto-slider__name {
    @apply font-heading uppercase text-white text-h3;
    font-weight: 700;
    max-width: 8ch;
  }

  .moto-slider__pricing {
    @apply flex flex-col;
    gap: 0.3rem;
    margin-top: auto;
  }

  .moto-slider__list-price {
    @apply font-body text-body-lg text-white/75;
    text-decoration: line-through;
    text-decoration-thickness: 1px;
  }

  .moto-slider__price {
    @apply font-heading text-white text-h3;
    font-weight: 700;
  }

  .moto-slider__actions {
    @apply flex flex-wrap gap-3;
    margin-top: 1.5rem;
  }

  .moto-slider__dots {
    @apply flex items-center justify-center;
    gap: 0.25rem;
    margin-top: 0.9rem;
  }

  .moto-slider__dot {
    @apply relative inline-flex items-center justify-center rounded-full border-0 p-0;
    width: 2.75rem;
    height: 2.75rem;
    background: transparent;
  }

  .moto-slider__dot::before {
    content: '';
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 9999px;
    background: rgba(0, 0, 0, 0.22);
    transition: background-color var(--transition-base), transform var(--transition-base);
  }

  .moto-slider__dot.is-active::before {
    background: var(--color-primary);
    transform: scale(1.05);
  }

  @media (min-width: 768px) {
    .moto-slider {
      --moto-slider-band-gradient: linear-gradient(
        90deg,
        #128097 0%,
        #2d8ba0 14%,
        #4193ab 40%,
        #5aa0b9 70%,
        #64a8bf 88%,
        #71b2c6 100%
      );
    }

    .moto-slider__card {
      aspect-ratio: 5 / 4;
    }

    .moto-slider__name {
      max-width: 9ch;
    }

    .moto-slider__actions {
      flex-wrap: nowrap;
    }

  }

  @media (min-width: 992px) {
    .moto-slider__track {
      gap: 1.5rem;
    }

    .moto-slider__slide {
      width: calc(44% - 0.75rem);
      /* width: calc(50%); */
    }

    .moto-slider__dots {
      display: none;
    }

    .moto-slider__card {
      aspect-ratio: 5 / 4;
    }

    .moto-slider__content {
      padding: 2rem;
    }
  }

  @media (min-width: 1280px) {
    .moto-slider {
      --moto-slider-band-gradient: linear-gradient(
        90deg,
        #03778f 0%,
        #138198 10%,
        #27869d 22%,
        #368fa7 34%,
        #4796ad 48%,
        #579fb6 62%,
        #65aac1 78%,
        #6daec6 85%,
        #7db8ce 100%
      );
    }

    .moto-slider__track {
      gap: 2rem;
    }

    .moto-slider__slide {
      /* width: calc(44% - 1rem); */
      width: calc(44% - 1rem);
    }
  }

  @media (min-width: 1536px) {
    .moto-slider {
      --moto-slider-band-gradient: linear-gradient(
        90deg,
        #03778f 0%,
        #057c92 10%,
        #20839b 22%,
        #328ba3 34%,
        #4696ad 48%,
        #59a1b8 62%,
        #6daec6 78%,
        #72b5ca 85%,
        #8ec1d6 100%
      );
    }
  }
</style>
