---
import { urlFor } from '../../lib/sanity';
import type { HomeSliderMoto } from '../../lib/types';
import Button from '../ui/Button.astro';
import FadeIn from '../ui/FadeIn.astro';

interface Props {
  motos: HomeSliderMoto[];
}

const { motos } = Astro.props;
const hasMultipleSlides = motos.length > 1;
---

{motos.length > 0 && (
  <section class="moto-slider" aria-labelledby="moto-slider-title">
    <div class="moto-slider__container">
      <div class="moto-slider__header">
        <FadeIn type="left">
          <h2 id="moto-slider-title" class="moto-slider__title">Elige la moto de tus sueños</h2>
        </FadeIn>

        {hasMultipleSlides && (
          <div class="moto-slider__controls" aria-label="Controles del slider">
            <button
              type="button"
              class="moto-slider__control"
              id="moto-slider-prev"
              aria-label="Ver motos anteriores"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" class="moto-slider__control-icon">
                <path d="m14.7 6.3-1.4-1.4L6.2 12l7.1 7.1 1.4-1.4L9.6 13H20v-2H9.6l5.1-4.7Z" fill="currentColor" />
              </svg>
            </button>
            <button
              type="button"
              class="moto-slider__control moto-slider__control--primary"
              id="moto-slider-next"
              aria-label="Ver motos siguientes"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" class="moto-slider__control-icon">
                <path d="m9.3 17.7 1.4 1.4 7.1-7.1-7.1-7.1-1.4 1.4L14.4 11H4v2h10.4l-5.1 4.7Z" fill="currentColor" />
              </svg>
            </button>
          </div>
        )}
      </div>

      <div class="moto-slider__viewport" id="moto-slider-viewport">
        <div class="moto-slider__track" id="moto-slider-track">
          {motos.map((moto, index) => {
            const imageUrl = urlFor(moto.imagenSliderHome).width(960).quality(86).auto('format').url();
            const imageUrl2x = urlFor(moto.imagenSliderHome).width(1440).quality(82).auto('format').url();
            const imageAlt = moto.imagenSliderHome?.alt || `${moto.displayName} de Cyclone Motos`;

            return (
              <FadeIn type="up" class="moto-slider__slide">
                <article class="moto-slider__card" aria-labelledby={`moto-slider-card-${moto._id}`}>
                  <div class="moto-slider__media">
                    <img
                      class="moto-slider__image"
                      src={imageUrl}
                      srcset={`${imageUrl} 960w, ${imageUrl2x} 1440w`}
                      sizes="(min-width: 1280px) 33vw, (min-width: 768px) 46vw, 82vw"
                      alt={imageAlt}
                      width="960"
                      height="1120"
                      loading={index < 2 ? 'eager' : 'lazy'}
                      fetchpriority={index < 2 ? 'low' : 'auto'}
                      decoding="async"
                    />
                    <div class="moto-slider__overlay" aria-hidden="true"></div>
                  </div>

                  <div class="moto-slider__content">
                    <h3 id={`moto-slider-card-${moto._id}`} class="moto-slider__name fade-child fade-child--left fade-delay-2">
                      {moto.displayName}
                    </h3>

                    <div class="moto-slider__pricing fade-child fade-child--left fade-delay-3">
                      {moto.displayListPrice && <p class="moto-slider__list-price">{moto.displayListPrice}</p>}
                      {moto.displayPrice && <p class="moto-slider__price">{moto.displayPrice}</p>}
                    </div>

                    <div class="moto-slider__actions fade-child fade-child--zoom-in fade-delay-4">
                      <Button type="button" size="md" class="md:min-w-40">
                        Cotizar
                      </Button>
                      <Button href={`/motos/${moto.slug}`} variant="secondary" size="md" class="md:min-w-40">
                        Ver modelo
                      </Button>
                    </div>
                  </div>
                </article>
              </FadeIn>
            );
          })}
        </div>
      </div>

      {hasMultipleSlides && (
        <div class="moto-slider__dots md:hidden" id="moto-slider-dots" aria-label="Paginacion del slider">
          {motos.map((moto, index) => (
            <button
              type="button"
              class:list={['moto-slider__dot', index === 0 && 'is-active']}
              data-slider-dot
              data-slider-index={index}
              aria-label={`Ir a la moto ${index + 1}: ${moto.displayName}`}
              aria-pressed={index === 0 ? 'true' : 'false'}
            ></button>
          ))}
        </div>
      )}
    </div>
  </section>
)}

<script>
  const viewport = document.getElementById('moto-slider-viewport');
  const track = document.getElementById('moto-slider-track');
  const previousButton = document.getElementById('moto-slider-prev');
  const nextButton = document.getElementById('moto-slider-next');

  // Dot navigation (mobile)
  const sliderDots = Array.from(document.querySelectorAll('[data-slider-dot]'));
  const sliderSlides = Array.from(document.querySelectorAll('.moto-slider__slide'));

  let currentIndex = 0;

  function scrollToSlide(index: number) {
    if (!viewport) return;
    const targetSlide = sliderSlides[index] as HTMLElement;
    if (!targetSlide) return;
    const slideRect = targetSlide.getBoundingClientRect();
    const viewportRect = viewport.getBoundingClientRect();
    viewport.scrollTo({
      left: viewport.scrollLeft + slideRect.left - viewportRect.left,
      behavior: 'smooth',
    });
  }

  function scrollSlider(direction: number) {
    const nextIndex = Math.max(0, Math.min(sliderSlides.length - 1, currentIndex + direction));
    scrollToSlide(nextIndex);
  }

  previousButton?.addEventListener('click', () => scrollSlider(-1));
  nextButton?.addEventListener('click', () => scrollSlider(1));

  function setActiveSliderDot(activeIndex: number) {
    sliderDots.forEach((dot, index) => {
      const isActive = index === activeIndex;
      dot.classList.toggle('is-active', isActive);
      dot.setAttribute('aria-pressed', String(isActive));
    });
  }

  sliderDots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      if (!viewport) return;
      const targetSlide = sliderSlides[index] as HTMLElement;
      if (!targetSlide) return;
      const slideRect = targetSlide.getBoundingClientRect();
      const viewportRect = viewport.getBoundingClientRect();
      viewport.scrollTo({
        left: viewport.scrollLeft + slideRect.left - viewportRect.left,
        behavior: 'smooth',
      });
    });
  });

  if (viewport && sliderSlides.length > 0) {
    const dotObserver = new IntersectionObserver(
      (entries) => {
        const visibleEntry = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (!visibleEntry) return;

        const activeIndex = sliderSlides.indexOf(visibleEntry.target as HTMLElement);
        if (activeIndex >= 0) {
          currentIndex = activeIndex;
          setActiveSliderDot(activeIndex);
        }
      },
      {
        root: viewport,
        threshold: [0.6, 0.75, 0.9],
      }
    );

    sliderSlides.forEach((slide) => dotObserver.observe(slide));
  }
</script>

<style>
  .moto-slider {
    @apply relative overflow-hidden;
    --moto-slider-band-gradient: linear-gradient(
      90deg,
      #05788f 0%,
      #1b839c 24%,
      #4d99b1 58%,
      #79b6c9 82%,
      #90c1d5 100%
    );
    padding: 5rem 0 10rem 0;
    background-color: #ffffff;
    background-image:
      linear-gradient(
        180deg,
        #ffffff 0%,
        rgba(255, 255, 255, 0.94) 10%,
        rgba(255, 255, 255, 0.72) 30%,
        rgba(255, 255, 255, 0.28) 70%,
        rgba(255, 255, 255, 0) 100%
      ),
      var(--moto-slider-band-gradient);
    background-position: bottom, bottom;
    background-repeat: no-repeat;
    background-size: 100% 65%, 100% 65%;
  }

  .moto-slider::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 3px;
    background: var(--moto-slider-band-gradient);
    pointer-events: none;
  }

  .moto-slider__container {
    @apply mx-auto;
    max-width: var(--container-max);
    padding: 0 var(--container-padding);
  }

  .moto-slider__header {
    @apply flex items-end justify-between gap-4;
    margin-bottom: 2rem;
  }

  .moto-slider__title {
    @apply font-heading uppercase text-text text-h2;
    font-weight: 700;
  }

  .moto-slider__controls {
    @apply hidden md:flex items-center gap-3 shrink-0;
  }

  .moto-slider__control {
    @apply inline-flex items-center justify-center border transition-colors duration-200;
    overflow: hidden;
    width: 3rem;
    height: 3rem;
    border-color: rgba(214, 0, 15, 0.35);
    background: transparent;
    color: var(--color-primary);
  }

  .moto-slider__control:hover:not(:disabled) {
    border-color: var(--color-primary);
  }

  .moto-slider__control:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .moto-slider__control--primary {
    background: var(--color-primary);
    background-image: radial-gradient(circle at center, #ffffff 0%, #ffffff 54%, transparent 55%);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 0% 0%;
    color: var(--color-text-light);
    transition:
      background-size 360ms ease-in-out,
      border-color var(--transition-base),
      color var(--transition-base);
  }

  .moto-slider__control--primary:hover:not(:disabled) {
    background-size: 260% 260%;
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .moto-slider__control-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .moto-slider__viewport {
    --moto-slider-gap: 1rem;
    --moto-slider-card-width: calc(100% - var(--moto-slider-gap));
    overflow: hidden;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-snap-type: x mandatory;
    padding-bottom: 0.5rem;
    padding-right: 1rem;
  }

  .moto-slider__viewport::-webkit-scrollbar {
    display: none;
  }

  .moto-slider__track {
    @apply flex;
    gap: var(--moto-slider-gap);
  }

  .moto-slider__slide {
    flex: 0 0 var(--moto-slider-card-width);
    scroll-snap-align: start;
  }

  .moto-slider__card {
    @apply relative overflow-hidden;
    min-height: 24rem;
    aspect-ratio: 4 / 4;
    background: var(--color-secondary-dark);
  }

  .moto-slider__media {
    @apply absolute inset-0;
  }

  .moto-slider__image {
    @apply block w-full h-full;
    object-fit: cover;
  }

  .moto-slider__overlay {
    @apply absolute inset-0;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.16) 0%, rgba(0, 0, 0, 0.38) 62%, rgba(0, 0, 0, 0.76) 100%),
      linear-gradient(90deg, rgba(0, 0, 0, 0.34) 0%, rgba(0, 0, 0, 0.08) 46%, rgba(0, 0, 0, 0) 100%);
  }

  .moto-slider__content {
    @apply relative z-10 h-full flex flex-col justify-between;
    padding: 1.5rem;
  }

  /* ── Inner element animations ───────────────────────────── */
  /* Handled by FadeIn.astro utilities: fade-child, fade-child--{dir}, fade-delay-{n} */

  .moto-slider__name {
    @apply font-heading uppercase text-white text-h3;
    font-weight: 700;
    max-width: 8ch;
  }

  .moto-slider__pricing {
    @apply flex flex-col;
    gap: 0.3rem;
    margin-top: auto;
  }

  .moto-slider__list-price {
    @apply font-body text-body-lg text-white/75;
    text-decoration: line-through;
    text-decoration-thickness: 1px;
  }

  .moto-slider__price {
    @apply font-heading text-white text-h3;
    font-weight: 700;
  }

  .moto-slider__actions {
    @apply flex flex-wrap gap-3;
    margin-top: 1.5rem;
  }

  .moto-slider__dots {
    @apply flex items-center justify-center;
    gap: 0.25rem;
    margin-top: 0.9rem;
  }

  .moto-slider__dot {
    @apply relative inline-flex items-center justify-center rounded-full border-0 p-0;
    width: 2.75rem;
    height: 2.75rem;
    background: transparent;
  }

  .moto-slider__dot::before {
    content: '';
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 9999px;
    background: rgba(0, 0, 0, 0.22);
    transition: background-color var(--transition-base), transform var(--transition-base);
  }

  .moto-slider__dot.is-active::before {
    background: var(--color-primary);
    transform: scale(1.05);
  }

  @media (min-width: 768px) {
    .moto-slider {
      --moto-slider-band-gradient: linear-gradient(
        90deg,
        #128097 0%,
        #2d8ba0 14%,
        #4193ab 40%,
        #5aa0b9 70%,
        #64a8bf 88%,
        #71b2c6 100%
      );
    }

    .moto-slider__track {
      gap: var(--moto-slider-gap);
    }

    .moto-slider__card {
      min-height: 28rem;
      aspect-ratio: 5 / 4;
    }

    .moto-slider__name {
      max-width: 9ch;
    }

    .moto-slider__actions {
      flex-wrap: nowrap;
    }

  }

  @media (min-width: 992px) {
    .moto-slider__viewport {
      --moto-slider-gap: 1.5rem;
      --moto-slider-card-width: calc((100% - var(--moto-slider-gap)) / 2);
      padding-right: 0;
    }

    .moto-slider__track {
      gap: var(--moto-slider-gap);
    }

    .moto-slider__card {
      min-height: 30rem;
      aspect-ratio: 5 / 4;
    }

    .moto-slider__content {
      padding: 2rem;
    }
  }

  @media (min-width: 1280px) {
    .moto-slider {
      --moto-slider-band-gradient: linear-gradient(
        90deg,
        #047891 0%,
        #037b93 10%,
        #19839b 22%,
        #28879f 34%,
        #4193ab 48%,
        #56a0b7 62%,
        #6caec6 78%,
        #7ab7cc 85%,
        #8abfd3 100%
      );
    }

    .moto-slider__viewport {
      --moto-slider-gap: 2rem;
      --moto-slider-card-width: calc((100% - var(--moto-slider-gap)) / 2);
    }
  }
  @media (min-width: 1536px) {
    .moto-slider {
      --moto-slider-band-gradient: linear-gradient(
        90deg,
        #026983 0%,
        #05758d 10%,
        #057b95 22%,
        #26869f 34%,
        #4396ac 48%,
        #5ea5bd 62%,
        #79b6ca 78%,
        #8ec1d7 85%,
        #a0c8d5 100%
      );
    }
  }
</style>
