---
import { urlFor } from '../../lib/sanity';
import type { HomeInfoSection } from '../../lib/types';
import Button from '../ui/Button.astro';
import FadeIn from '../ui/FadeIn.astro';

interface Props {
  section?: HomeInfoSection | null;
}

const { section } = Astro.props;

const backgroundImage = section?.imagenFondo
  ? urlFor(section.imagenFondo).width(1800).quality(82).auto('format').url()
  : null;

const backgroundImage2x = section?.imagenFondo
  ? urlFor(section.imagenFondo).width(2800).quality(76).auto('format').url()
  : null;

const mobileBackgroundImage = section?.imagenFondo?.mobileImage?.asset?._ref
  ? urlFor(section.imagenFondo.mobileImage).width(900).quality(80).auto('format').url()
  : backgroundImage;

const mobileBackgroundImage2x = section?.imagenFondo?.mobileImage?.asset?._ref
  ? urlFor(section.imagenFondo.mobileImage).width(1400).quality(74).auto('format').url()
  : backgroundImage2x;

const backgroundAlt =
  section?.imagenFondo?.mobileImage?.alt ||
  section?.imagenFondo?.alt ||
  section?.titulo ||
  'Sección informativa de Cyclone Motos';
---

{section && (
  <section class="info-section" aria-labelledby="info-section-title">
    <article class="info-section__panel">
      <div class="info-section__media" data-info-media style={backgroundImage ? `--info-section-bg: url('${backgroundImage}')` : undefined}>
        {backgroundImage && (
          <picture>
            <source
              media="(max-width: 767px)"
              srcset={
                mobileBackgroundImage2x
                  ? `${mobileBackgroundImage} 900w, ${mobileBackgroundImage2x} 1400w`
                  : mobileBackgroundImage || undefined
              }
              sizes="100vw"
            />
            <img
              class="info-section__image"
              src={backgroundImage}
              srcset={backgroundImage2x ? `${backgroundImage} 1800w, ${backgroundImage2x} 2800w` : undefined}
              sizes="100vw"
              alt={backgroundAlt}
              width="1800"
              height="1000"
              loading="lazy"
              decoding="async"
            />
          </picture>
        )}
      </div>

      <div class="info-section__container">
        <div class="info-section__content" data-info-content>
          <FadeIn type="left">
            <h2 id="info-section-title" class="info-section__title">{section.titulo}</h2>
          </FadeIn>
          <FadeIn type="left">
            <p class="info-section__description">{section.descripcion}</p>
          </FadeIn>

          {section.botonTexto && section.botonUrl && (
            <FadeIn type="left">
              <Button href={section.botonUrl} size="lg">
                {section.botonTexto}
              </Button>
            </FadeIn>
          )}
        </div>
      </div>
    </article>
  </section>
)}

<script>
  const infoSections = document.querySelectorAll<HTMLElement>('.info-section');

  infoSections.forEach((section) => {
    const media = section.querySelector<HTMLElement>('[data-info-media]');
    const content = section.querySelector<HTMLElement>('[data-info-content]');
    const isDesktop = window.matchMedia('(min-width: 768px)').matches;

    if (!content || !isDesktop) return;

    let ticking = false;

    const updateMediaMode = () => {
      const rect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight || 1;
      const shouldUseParallax = rect.top <= 0;
      const exitProgress = Math.min(Math.max((viewportHeight - rect.bottom) / (viewportHeight * 0.75), 0), 1);
      const contentOffset = exitProgress * Math.min(viewportHeight * 0.84, 390);

      media?.classList.toggle('info-section__media--parallax', shouldUseParallax);
      content.style.setProperty('--info-content-parallax-y', `${contentOffset}px`);
      ticking = false;
    };

    const requestUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateMediaMode);
        ticking = true;
      }
    };

    updateMediaMode();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
  });
</script>

<style>
  .info-section {
    @apply relative;
  }

  .info-section__container {
    @apply relative z-10 mx-auto;
    max-width: var(--container-max);
    min-height: inherit;
    padding: 0 var(--container-padding);
  }

  .info-section__panel {
    @apply relative;
    min-height: 77rem;
    background: var(--color-secondary-dark);
    clip-path: inset(0);
  }

  .info-section__media {
    @apply absolute inset-0 overflow-hidden;
  }

  .info-section__media picture {
    position: absolute;
    inset: 0;
    display: block;
  }

  .info-section__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(26, 28, 28, 1) 0%, rgba(0, 0, 0, 0.28) 20%, rgba(0, 0, 0, 0) 72%);
    pointer-events: none;
  }

  .info-section__image {
    @apply w-full h-full;
    object-fit: cover;
    object-position: center;
  }
  .info-section__content {
    @apply sticky z-10 flex flex-col justify-start;
    gap: 1.25rem;
    padding: 3rem 0;
    top: var(--header-height);
    transform: translate3d(0, var(--info-content-parallax-y, 0), 0);
    will-change: transform;
    color: var(--color-text-light);
  }

  .info-section__title {
    @apply font-heading text-white text-h2 uppercase;
    font-weight: 700;
  }

  .info-section__description {
    @apply font-body text-body-lg;
    max-width: 35rem;
    color: rgba(255, 255, 255, 0.82);
  }

  @media (max-width: 767px) {
    .info-section__panel {
      min-height: 28rem;
    }

    .info-section__content {
      @apply relative;
      top: auto;
      justify-content: flex-end;
      max-width: 100%;
      min-height: 28rem;
      padding: 1.5rem;
      transform: none;
      will-change: auto;
    }

    .info-section__media picture {
      inset: 0;
    }

    .info-section__image {
      object-position: center;
    }

    .info-section__title {
      max-width: 100%;
    }
  }

  @media (min-width: 768px) {
    .info-section__media {
      background-image: var(--info-section-bg);
      background-attachment: scroll;
      background-position: center top;
      background-repeat: no-repeat;
      background-size: cover;
    }

    .info-section__media--parallax {
      background-attachment: fixed;
    }

    .info-section__media picture {
      opacity: 0;
      pointer-events: none;
    }
    .info-section__media {
    background-position: center top;
    background-repeat: no-repeat;
    background-size: cover;
    /* sin background-image aquí → el picture queda visible */
  }

  .info-section__media--parallax {
    background-image: var(--info-section-bg);
    background-attachment: fixed;
  }

  .info-section__media--parallax picture {
    opacity: 0;
    pointer-events: none;
  }
  .info-section__media {
    max-height: 100vh;
    height: 100vh;
  }
  .info-section__media--parallax {
    max-height: none;
    height: 100%;
  }
  }
</style>
