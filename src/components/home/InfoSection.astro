---
import { urlFor } from '../../lib/sanity';
import type { HomeInfoSection } from '../../lib/types';
import Button from '../ui/Button.astro';
import FadeIn from '../ui/FadeIn.astro';

interface Props {
  section?: HomeInfoSection | null;
}

const { section } = Astro.props;

const desktopUrl = section?.imagenFondo
  ? urlFor(section.imagenFondo).width(1800).quality(82).auto('format').url()
  : null;

const desktopUrl2x = section?.imagenFondo
  ? urlFor(section.imagenFondo).width(2800).quality(76).auto('format').url()
  : null;

const mobileUrl = section?.imagenFondo?.mobileImage?.asset?._ref
  ? urlFor(section.imagenFondo.mobileImage).width(900).quality(80).auto('format').url()
  : desktopUrl;

const mobileUrl2x = section?.imagenFondo?.mobileImage?.asset?._ref
  ? urlFor(section.imagenFondo.mobileImage).width(1400).quality(74).auto('format').url()
  : desktopUrl2x;

const imageAlt =
  section?.imagenFondo?.mobileImage?.alt ||
  section?.imagenFondo?.alt ||
  section?.titulo ||
  'Sección informativa de Cyclone Motos';
---

{section && (
  <section class="info-section" aria-labelledby="info-section-title">
    <article class="info-section__panel">
      <div class="info-section__media" data-info-media>
        {desktopUrl && (
          <picture>
            <source
              media="(max-width: 767px)"
              srcset={mobileUrl2x ? `${mobileUrl} 900w, ${mobileUrl2x} 1400w` : mobileUrl || undefined}
              sizes="100vw"
            />
            <img
              class="info-section__image"
              data-info-image
              src={desktopUrl}
              srcset={desktopUrl2x ? `${desktopUrl} 1800w, ${desktopUrl2x} 2800w` : undefined}
              sizes="100vw"
              alt={imageAlt}
              width="1800"
              height="1000"
              loading="lazy"
              decoding="async"
            />
          </picture>
        )}
        <div class="info-section__overlay" aria-hidden="true"></div>
      </div>

      <div class="info-section__container">
        <div class="info-section__content" data-info-content>
          <FadeIn type="left">
            <h2 id="info-section-title" class="info-section__title">{section.titulo}</h2>
          </FadeIn>
          <FadeIn type="left">
            <p class="info-section__description">{section.descripcion}</p>
          </FadeIn>

          {section.botonTexto && section.botonUrl && (
            <FadeIn type="left">
              <Button href={section.botonUrl} size="lg">
                {section.botonTexto}
              </Button>
            </FadeIn>
          )}
        </div>
      </div>
    </article>
  </section>
)}

<script>
  // Extra px added to image height to allow parallax travel (same value used in CSS)
  const PARALLAX_EXTRA = 160; // 80px top + 80px bottom
  const PARALLAX_STRENGTH = 0.14;
  const PARALLAX_MAX = PARALLAX_EXTRA / 2;

  document.querySelectorAll<HTMLElement>('.info-section').forEach((section) => {
    const image = section.querySelector<HTMLImageElement>('[data-info-image]');
    const content = section.querySelector<HTMLElement>('[data-info-content]');

    if (!image || !content) return;

    let ticking = false;
    const mq = window.matchMedia('(min-width: 768px)');
    let isDesktop = mq.matches;

    const reset = () => {
      image.style.transform = '';
      content.style.setProperty('--info-content-parallax-y', '0px');
    };

    const update = () => {
      if (!isDesktop) {
        reset();
        ticking = false;
        return;
      }

      const rect = section.getBoundingClientRect();
      const vh = window.innerHeight;

      // Parallax: image moves slower than scroll
      const sectionCenter = rect.top + rect.height / 2;
      const viewportCenter = vh / 2;
      const rawParallax = (sectionCenter - viewportCenter) * PARALLAX_STRENGTH;
      const parallaxY = Math.max(-PARALLAX_MAX, Math.min(PARALLAX_MAX, rawParallax));
      image.style.transform = `translateY(${parallaxY}px)`;

      // Content exit: slides up as section bottom leaves viewport
      const exitProgress = Math.min(Math.max((vh - rect.bottom) / (vh * 0.75), 0), 1);
      const contentOffset = exitProgress * Math.min(vh * 0.84, 390);
      content.style.setProperty('--info-content-parallax-y', `${contentOffset}px`);

      ticking = false;
    };

    const requestUpdate = () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    };

    mq.addEventListener('change', (e) => {
      isDesktop = e.matches;
      requestUpdate();
    });

    update();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate, { passive: true });
  });
</script>

<style>
  .info-section {
    @apply relative;
  }

  .info-section__panel {
    @apply relative;
    /* clip-path clips the parallax image overflow WITHOUT breaking position:sticky on children
       (overflow:hidden would break sticky — this is the correct approach) */
    clip-path: inset(0);
    min-height: 77rem;
    background: var(--color-secondary-dark);
  }

  .info-section__media {
    @apply absolute inset-0;
  }

  .info-section__media picture {
    @apply absolute inset-0 block;
  }

  .info-section__image {
    @apply block w-full;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .info-section__overlay {
    @apply absolute inset-0 pointer-events-none;
    background: linear-gradient(0deg, rgba(26, 28, 28, 1) 0%, rgba(0, 0, 0, 0.28) 20%, rgba(0, 0, 0, 0) 72%);
  }

  .info-section__container {
    @apply relative z-10 mx-auto;
    max-width: var(--container-max);
    min-height: inherit;
    padding: 0 var(--container-padding);
  }

  .info-section__content {
    @apply sticky z-10 flex flex-col justify-start;
    gap: 1.25rem;
    padding: 3rem 0;
    top: var(--header-height);
    transform: translate3d(0, var(--info-content-parallax-y, 0), 0);
    will-change: transform;
    color: var(--color-text-light);
  }

  .info-section__title {
    @apply font-heading text-white text-h2 uppercase;
    font-weight: 700;
  }

  .info-section__description {
    @apply font-body text-body-lg;
    max-width: 35rem;
    color: rgba(255, 255, 255, 0.82);
  }

  /* Desktop: image is taller than container to allow parallax travel */
  @media (min-width: 768px) {
    .info-section__image {
      height: calc(100% + 160px); /* matches PARALLAX_EXTRA in JS */
      margin-top: -80px;          /* center the extra height */
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .info-section__panel {
      min-height: 28rem;
    }

    .info-section__content {
      @apply relative;
      top: auto;
      justify-content: flex-end;
      max-width: 100%;
      min-height: 28rem;
      padding: 1.5rem;
      transform: none;
      will-change: auto;
    }
  }
</style>
