---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { allSlugsQuery, postBySlugQuery, postsQuery } from '../../lib/queries';
import { toHTML } from '@portabletext/to-html';
import type { Post, SanityImage } from '../../lib/types';

const categoryLabels: Record<string, string> = {
  tips: 'Tips',
  eventos: 'Eventos',
  nuevo: 'Nuevo',
};

const escapeHtml = (value = '') =>
  value
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');

const buildImageMarkup = (image: SanityImage, desktopWidth: number, desktopHeight: number) => {
  const desktopUrl = urlFor(image).width(desktopWidth).quality(90).auto('format').url();
  const desktopUrl2x = urlFor(image).width(Math.round(desktopWidth * 1.5)).quality(84).auto('format').url();
  const mobileImage = image.mobileImage?.asset?._ref ? image.mobileImage : image;
  const mobileUrl = urlFor(mobileImage).width(720).quality(88).auto('format').url();
  const mobileUrl2x = urlFor(mobileImage).width(1080).quality(84).auto('format').url();

  return {
    alt: escapeHtml(mobileImage?.alt || image.alt || ''),
    desktopHeight,
    desktopUrl,
    desktopUrl2x,
    desktopWidth,
    mobileUrl,
    mobileUrl2x,
  };
};

const buildCardImage = (image?: SanityImage, title = 'Noticia Cyclone') => {
  if (!image?.asset?._ref) {
    return null;
  }

  const mobileImage = image.mobileImage?.asset?._ref ? image.mobileImage : image;

  return {
    alt: mobileImage?.alt || image.alt || title,
    desktopUrl: urlFor(image).width(620).quality(88).auto('format').url(),
    desktopUrl2x: urlFor(image).width(930).quality(82).auto('format').url(),
    mobileUrl: urlFor(mobileImage).width(720).quality(86).auto('format').url(),
    mobileUrl2x: urlFor(mobileImage).width(1080).quality(80).auto('format').url(),
  };
};

export async function getStaticPaths() {
  const slugs: Array<{ slug: string }> = await sanityClient.fetch(allSlugsQuery);
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post: Post | null = await sanityClient.fetch(postBySlugQuery, { slug });

if (!post) {
  return Astro.redirect('/404');
}

const allPosts: Post[] = await sanityClient.fetch(postsQuery);
const relatedPosts = allPosts
  .filter((item) => item.slug && item.slug !== post.slug)
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);

const heroMode = post.heroDisplayMode || 'featured';
const sliderImages = post.heroImages?.filter((image) => image.asset?._ref) || [];
const useSlider = heroMode === 'slider' && sliderImages.length > 0;
const featuredHeroImage = post.homeImage || sliderImages[0];
const socialImageUrl = featuredHeroImage ? urlFor(featuredHeroImage).width(1200).quality(88).auto('format').url() : undefined;
const categoryLabel = post.category ? categoryLabels[post.category] || post.category : null;

const bodyHTML = post.body
  ? toHTML(post.body, {
      components: {
        types: {
          image: ({ value }) => {
            if (!value?.asset?._ref) {
              return '';
            }

            const imageMarkup = buildImageMarkup(value, 1120, 720);
            const caption = value.caption
              ? `<figcaption class="portable-image__caption">${escapeHtml(value.caption)}</figcaption>`
              : '';

            return `
              <figure class="portable-image">
                <picture>
                  <source
                    media="(max-width: 767px)"
                    srcset="${imageMarkup.mobileUrl} 720w, ${imageMarkup.mobileUrl2x} 1080w"
                    sizes="100vw"
                  />
                  <img
                    src="${imageMarkup.desktopUrl}"
                    srcset="${imageMarkup.desktopUrl} 1120w, ${imageMarkup.desktopUrl2x} 1680w"
                    sizes="(min-width: 1200px) 760px, 100vw"
                    alt="${imageMarkup.alt}"
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
                ${caption}
              </figure>
            `;
          },
        },
        marks: {
          link: ({ children, value }) => {
            const href = value?.href ? escapeHtml(value.href) : '#';
            const rel = value?.blank ? ' rel="noreferrer noopener"' : '';
            const target = value?.blank ? ' target="_blank"' : '';
            return `<a href="${href}"${target}${rel}>${children}</a>`;
          },
        },
      },
    })
  : '';
---

<BaseLayout
  title={`${post.title} | Cyclone Motos`}
  description={post.excerpt}
  image={socialImageUrl}
>
  <article class="post-detail">
    <header class="post-detail__header">
      {categoryLabel && <p class="post-detail__category">{categoryLabel}</p>}
      <h1 class="post-detail__title">{post.title}</h1>
    </header>

    {useSlider ? (
      <section class="post-detail__hero-slider" aria-label="Imagenes principales de la noticia">
        <div class="post-detail__slider-track">
          {sliderImages.map((image, index) => {
            const heroImage = buildImageMarkup(image, 920, 620);

            return (
              <picture class="post-detail__slide">
                <source
                  media="(max-width: 767px)"
                  srcset={`${heroImage.mobileUrl} 720w, ${heroImage.mobileUrl2x} 1080w`}
                  sizes="100vw"
                />
                <img
                  src={heroImage.desktopUrl}
                  srcset={`${heroImage.desktopUrl} 920w, ${heroImage.desktopUrl2x} 1380w`}
                  sizes="(min-width: 1024px) 48vw, 100vw"
                  alt={heroImage.alt || `${post.title} ${index + 1}`}
                  width="920"
                  height="620"
                  loading={index < 2 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </picture>
            );
          })}
        </div>
        {sliderImages.length > 1 && (
          <div class="post-detail__slider-dots" aria-label="Indicadores del slider">
            {sliderImages.map((_, index) => (
              <button
                type="button"
                class:list={['post-detail__slider-dot', index === 0 && 'is-active']}
                aria-label={`Ver imagen ${index + 1}`}
                aria-pressed={index === 0 ? 'true' : 'false'}
                data-post-slider-dot
                data-slide-index={index}
              />
            ))}
          </div>
        )}
      </section>
    ) : (
      featuredHeroImage && (
        <section class="post-detail__featured-wrap" aria-label="Imagen destacada de la noticia">
          {(() => {
            const heroImage = buildImageMarkup(featuredHeroImage, 1440, 760);

            return (
              <picture class="post-detail__featured">
                <source
                  media="(max-width: 767px)"
                  srcset={`${heroImage.mobileUrl} 720w, ${heroImage.mobileUrl2x} 1080w`}
                  sizes="100vw"
                />
                <img
                  src={heroImage.desktopUrl}
                  srcset={`${heroImage.desktopUrl} 1440w, ${heroImage.desktopUrl2x} 2160w`}
                  sizes="(min-width: 1200px) 1120px, 100vw"
                  alt={heroImage.alt || post.title}
                  width="1440"
                  height="760"
                  loading="eager"
                  decoding="async"
                />
              </picture>
            );
          })()}
        </section>
      )
    )}

    <div class="post-detail__share" aria-label="Compartir noticia">
      <button type="button" class="post-detail__share-button" data-share="facebook" aria-label="Compartir en Facebook">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M13.5 21v-7h2.35l.35-2.74H13.5V9.51c0-.79.22-1.33 1.35-1.33h1.44V5.73c-.25-.03-1.1-.11-2.08-.11-2.06 0-3.47 1.26-3.47 3.57v2.07H8.4V14h2.34v7h2.76Z" fill="currentColor" />
        </svg>
      </button>
      <button type="button" class="post-detail__share-button" data-share="instagram" aria-label="Compartir noticia">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7.75 3h8.5A4.75 4.75 0 0 1 21 7.75v8.5A4.75 4.75 0 0 1 16.25 21h-8.5A4.75 4.75 0 0 1 3 16.25v-8.5A4.75 4.75 0 0 1 7.75 3Zm0 1.8A2.95 2.95 0 0 0 4.8 7.75v8.5a2.95 2.95 0 0 0 2.95 2.95h8.5a2.95 2.95 0 0 0 2.95-2.95v-8.5a2.95 2.95 0 0 0-2.95-2.95h-8.5ZM12 7.6A4.4 4.4 0 1 1 7.6 12 4.4 4.4 0 0 1 12 7.6Zm0 1.8A2.6 2.6 0 1 0 14.6 12 2.6 2.6 0 0 0 12 9.4Zm4.65-3.25a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2Z" fill="currentColor" />
        </svg>
      </button>
      <button type="button" class="post-detail__share-button" data-share="copy" aria-label="Copiar enlace">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M8.5 12.8a4.25 4.25 0 0 1 0-6.01l2.47-2.47a4.25 4.25 0 0 1 6.01 6.01l-1.06 1.06-1.41-1.41 1.06-1.06a2.25 2.25 0 1 0-3.18-3.18L9.91 8.2a2.25 2.25 0 0 0 0 3.18l.71.71-1.41 1.41-.71-.7Zm7-1.6a4.25 4.25 0 0 1 0 6.01l-2.47 2.47a4.25 4.25 0 0 1-6.01-6.01l1.06-1.06 1.41 1.41-1.06 1.06a2.25 2.25 0 1 0 3.18 3.18l2.47-2.47a2.25 2.25 0 0 0 0-3.18l-.71-.71 1.41-1.41.71.7Z" fill="currentColor" />
        </svg>
      </button>
    </div>

    <div class="post-detail__content">
      {post.excerpt && <p class="post-detail__excerpt">{post.excerpt}</p>}
      {bodyHTML && <div class="post-detail__body" set:html={bodyHTML} />}
    </div>

    {post.galleryPhotos && post.galleryPhotos.length > 0 && (
      <section class="post-detail__gallery" aria-labelledby="post-gallery-title">
        <h2 id="post-gallery-title" class="post-detail__section-title">Galeria de fotos</h2>
        <div class="post-detail__gallery-grid">
          {post.galleryPhotos.map((image, index) => {
            const galleryImage = buildImageMarkup(image, 520, 360);

            return (
              <button
                type="button"
                class="post-detail__gallery-item"
                aria-label={`Abrir foto ${index + 1} de la galeria`}
                data-post-gallery-open
                data-gallery-index={index}
              >
                <picture>
                  <source
                    media="(max-width: 767px)"
                    srcset={`${galleryImage.mobileUrl} 720w, ${galleryImage.mobileUrl2x} 1080w`}
                    sizes="80vw"
                  />
                  <img
                    src={galleryImage.desktopUrl}
                    srcset={`${galleryImage.desktopUrl} 520w, ${galleryImage.desktopUrl2x} 780w`}
                    sizes="(min-width: 1024px) 25vw, 80vw"
                    alt={galleryImage.alt || `${post.title} ${index + 1}`}
                    width="520"
                    height="360"
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
              </button>
            );
          })}
        </div>
      </section>
    )}

    {post.galleryPhotos && post.galleryPhotos.length > 0 && (
      <dialog id="post-gallery-dialog" class="moto-gallery post-gallery-lightbox" aria-label={`Galeria de fotos de ${post.title}`}>
        <div class="moto-gallery__header">
          <div class="moto-gallery__meta">
            <strong class="moto-gallery__moto-name" data-post-gallery-title>
              {post.galleryPhotos[0]?.alt || post.title}
            </strong>
            <span class="moto-gallery__label">Galeria</span>
          </div>
          <button class="moto-gallery__close" aria-label="Cerrar galeria">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
              <line x1="17" y1="5" x2="5" y2="17" />
              <line x1="5" y1="5" x2="17" y2="17" />
            </svg>
          </button>
        </div>

        <div class="moto-gallery__stage">
          <button class="moto-gallery__arrow moto-gallery__arrow--prev" aria-label="Foto anterior">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="12 3 6 9 12 15" />
            </svg>
          </button>

          <div class="moto-gallery__track">
            {post.galleryPhotos.map((image, index) => {
              const lightboxImage = buildImageMarkup(image, 1600, 1000);

              return (
                <figure
                  class:list={['moto-gallery__slide', index === 0 && 'is-active']}
                  aria-hidden={index !== 0 ? 'true' : undefined}
                  data-gallery-alt={lightboxImage.alt || `${post.title} ${index + 1}`}
                >
                  <picture>
                    <source
                      media="(max-width: 767px)"
                      srcset={`${lightboxImage.mobileUrl} 720w, ${lightboxImage.mobileUrl2x} 1080w`}
                      sizes="100vw"
                    />
                    <img
                      class="moto-gallery__img"
                      src={lightboxImage.desktopUrl}
                      srcset={`${lightboxImage.desktopUrl} 1600w, ${lightboxImage.desktopUrl2x} 2400w`}
                      sizes="100vw"
                      alt={lightboxImage.alt || `${post.title} ${index + 1}`}
                      loading={index === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  </picture>
                </figure>
              );
            })}
          </div>

          <button class="moto-gallery__arrow moto-gallery__arrow--next" aria-label="Siguiente foto">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 3 12 9 6 15" />
            </svg>
          </button>
        </div>

        {post.galleryPhotos.length > 1 && (
          <div class="moto-gallery__dots" role="tablist" aria-label="Navegacion de galeria">
            {post.galleryPhotos.map((_, index) => (
              <button
                class:list={['moto-gallery__dot', index === 0 && 'is-active']}
                data-post-lightbox-dot
                data-gallery-index={index}
                role="tab"
                aria-label={`Foto ${index + 1}`}
                aria-selected={index === 0 ? 'true' : 'false'}
              ></button>
            ))}
          </div>
        )}
      </dialog>
    )}

    {relatedPosts.length > 0 && (
      <section class="post-detail__more" aria-labelledby="more-news-title">
        <h2 id="more-news-title" class="post-detail__more-title">Más noticias</h2>
        <div class="post-detail__more-grid">
          {relatedPosts.map((relatedPost) => {
            const image = buildCardImage(relatedPost.homeImage, relatedPost.homeTitle || relatedPost.title);
            const relatedCategory = relatedPost.category
              ? categoryLabels[relatedPost.category] || relatedPost.category
              : null;

            return (
              <article class="more-card">
                {image && (
                  <a href={`/noticias/${relatedPost.slug}`} class="more-card__image-link" tabindex="-1" aria-hidden="true">
                    <picture>
                      <source
                        media="(max-width: 767px)"
                        srcset={`${image.mobileUrl} 720w, ${image.mobileUrl2x} 1080w`}
                        sizes="100vw"
                      />
                      <img
                        src={image.desktopUrl}
                        srcset={`${image.desktopUrl} 620w, ${image.desktopUrl2x} 930w`}
                        sizes="(min-width: 1024px) 30vw, 100vw"
                        alt={image.alt}
                        width="620"
                        height="380"
                        loading="lazy"
                        decoding="async"
                      />
                    </picture>
                  </a>
                )}
                <div class="more-card__body">
                  {relatedCategory && <p class="more-card__category">{relatedCategory}</p>}
                  <h3 class="more-card__title">
                    <a href={`/noticias/${relatedPost.slug}`}>{relatedPost.homeTitle || relatedPost.title}</a>
                  </h3>
                  {relatedPost.excerpt && <p class="more-card__excerpt">{relatedPost.excerpt}</p>}
                  <a href={`/noticias/${relatedPost.slug}`} class="more-card__read-more">
                    Leer más <span aria-hidden="true">-&gt;</span>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    )}
  </article>

  <script>
    const copyToClipboard = async (value) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(value);
        return;
      }

      const input = document.createElement('textarea');
      input.value = value;
      input.setAttribute('readonly', '');
      input.style.position = 'fixed';
      input.style.opacity = '0';
      document.body.appendChild(input);
      input.select();
      document.execCommand('copy');
      input.remove();
    };

    document.querySelectorAll('[data-share]').forEach((button) => {
      button.addEventListener('click', async () => {
        const shareType = button.getAttribute('data-share');
        const shareUrl = window.location.href;
        const shareTitle = document.title;

        if (shareType === 'facebook') {
          window.open(
            `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`,
            '_blank',
            'noopener,noreferrer,width=720,height=520'
          );
          return;
        }

        if (shareType === 'instagram' && navigator.share) {
          await navigator.share({ title: shareTitle, url: shareUrl });
          return;
        }

        await copyToClipboard(shareUrl);
        button.classList.add('is-copied');
        window.setTimeout(() => button.classList.remove('is-copied'), 1400);
      });
    });

    const postSliderTrack = document.querySelector('.post-detail__slider-track');
    const postSliderSlides = Array.from(document.querySelectorAll('.post-detail__slide'));
    const postSliderDots = Array.from(document.querySelectorAll('[data-post-slider-dot]'));

    if (postSliderTrack && postSliderSlides.length > 1 && postSliderDots.length > 1) {
      const getTrackPaddingLeft = () => Number.parseFloat(window.getComputedStyle(postSliderTrack).paddingLeft) || 0;
      const getMaxScroll = () => Math.max(0, postSliderTrack.scrollWidth - postSliderTrack.clientWidth);

      const setActiveDot = (activeIndex) => {
        postSliderDots.forEach((dot, index) => {
          const isActive = index === activeIndex;
          dot.classList.toggle('is-active', isActive);
          dot.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      };

      const updateActiveDot = () => {
        const maxScroll = getMaxScroll();
        const progress = maxScroll > 0 ? postSliderTrack.scrollLeft / maxScroll : 0;
        const activeIndex = Math.min(
          postSliderDots.length - 1,
          Math.max(0, Math.round(progress * (postSliderDots.length - 1)))
        );

        setActiveDot(activeIndex);
      };

      postSliderDots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          const paddingLeft = getTrackPaddingLeft();
          const slide = postSliderSlides[index];
          const maxScroll = getMaxScroll();
          const targetLeft = index === postSliderSlides.length - 1
            ? maxScroll
            : Math.max(0, slide.offsetLeft - paddingLeft);

          setActiveDot(index);
          postSliderTrack.scrollTo({
            left: targetLeft,
            behavior: 'smooth',
          });
        });
      });

      postSliderTrack.addEventListener('scroll', () => window.requestAnimationFrame(updateActiveDot), { passive: true });
      updateActiveDot();
    }

    const postGalleryDialog = document.getElementById('post-gallery-dialog');
    const postGalleryOpenButtons = Array.from(document.querySelectorAll('[data-post-gallery-open]'));

    if (postGalleryDialog && postGalleryOpenButtons.length > 0) {
      const slides = Array.from(postGalleryDialog.querySelectorAll('.moto-gallery__slide'));
      const dots = Array.from(postGalleryDialog.querySelectorAll('[data-post-lightbox-dot]'));
      const galleryTitle = postGalleryDialog.querySelector('[data-post-gallery-title]');
      let current = 0;

      const goTo = (index) => {
        if (!slides.length) return;
        slides[current]?.classList.remove('is-active');
        slides[current]?.setAttribute('aria-hidden', 'true');
        dots[current]?.classList.remove('is-active');
        dots[current]?.setAttribute('aria-selected', 'false');

        current = ((index % slides.length) + slides.length) % slides.length;

        slides[current]?.classList.add('is-active');
        slides[current]?.removeAttribute('aria-hidden');
        dots[current]?.classList.add('is-active');
        dots[current]?.setAttribute('aria-selected', 'true');
        if (galleryTitle) {
          galleryTitle.textContent = slides[current]?.getAttribute('data-gallery-alt') || '';
        }
      };

      const openGallery = (index) => {
        goTo(index);
        postGalleryDialog.showModal();
        document.documentElement.style.setProperty('overflow', 'hidden');
      };

      postGalleryOpenButtons.forEach((button) => {
        button.addEventListener('click', () => {
          openGallery(Number(button.getAttribute('data-gallery-index')) || 0);
        });
      });

      postGalleryDialog.querySelector('.moto-gallery__close')?.addEventListener('click', () => postGalleryDialog.close());
      postGalleryDialog.querySelector('.moto-gallery__arrow--prev')?.addEventListener('click', () => goTo(current - 1));
      postGalleryDialog.querySelector('.moto-gallery__arrow--next')?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((dot, index) => dot.addEventListener('click', () => goTo(index)));

      postGalleryDialog.addEventListener('close', () => {
        document.documentElement.style.removeProperty('overflow');
      });

      postGalleryDialog.addEventListener('click', (event) => {
        if (event.target === postGalleryDialog) postGalleryDialog.close();
      });

      postGalleryDialog.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowLeft') goTo(current - 1);
        if (event.key === 'ArrowRight') goTo(current + 1);
      });

      let touchStartX = 0;
      postGalleryDialog.addEventListener('touchstart', (event) => {
        touchStartX = event.touches[0].clientX;
      }, { passive: true });
      postGalleryDialog.addEventListener('touchend', (event) => {
        const delta = touchStartX - event.changedTouches[0].clientX;
        if (Math.abs(delta) > 50) goTo(delta > 0 ? current + 1 : current - 1);
      }, { passive: true });
    }
  </script>

  <style>
  .post-detail {
    padding: calc(var(--header-height, 72px) + clamp(2.5rem, 5vw, 4.5rem)) 0 clamp(5rem, 9vw, 8rem);
    background: #ffffff;
    color: var(--color-text);
    overflow-x: hidden;
  }

  .post-detail__header,
  .post-detail__content,
  .post-detail__gallery,
  .post-detail__more {
    width: min(100%, var(--container-max));
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .post-detail__header {
    max-width: 52rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
    text-align: center;
  }

  .post-detail__category {
    margin: 0 0 0.7rem;
    font-family: var(--font-body);
    font-size: var(--text-button);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .post-detail__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: 700;
    line-height: var(--leading-heading);
    letter-spacing: -0.035em;
    color: #101827;
  }

  .post-detail__hero-slider {
    --post-slider-left-offset: max(var(--container-padding), calc((100vw - var(--container-max)) / 2 + var(--container-padding)));
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-bottom: 1.3rem;
  }

  .post-detail__slider-track {
    display: flex;
    gap: 1.25rem;
    width: 100%;
    box-sizing: border-box;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    padding-left: var(--post-slider-left-offset);
    padding-right: var(--container-padding);
    scrollbar-width: none;
  }

  .post-detail__slider-track::-webkit-scrollbar {
    display: none;
  }

  .post-detail__slider-dots {
    display: flex;
    justify-content: center;
    gap: 0.55rem;
    width: min(100%, var(--container-max));
