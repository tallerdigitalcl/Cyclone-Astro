---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { allSlugsQuery, postBySlugQuery, postsQuery } from '../../lib/queries';
import { toHTML } from '@portabletext/to-html';
import type { Post, SanityImage } from '../../lib/types';

const categoryLabels: Record<string, string> = {
  tips: 'Tips',
  eventos: 'Eventos',
  nuevo: 'Nuevo',
};

const escapeHtml = (value = '') =>
  value
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');

const buildImageMarkup = (image: SanityImage, desktopWidth: number, desktopHeight: number) => {
  const desktopUrl = urlFor(image).width(desktopWidth).quality(90).auto('format').url();
  const desktopUrl2x = urlFor(image).width(Math.round(desktopWidth * 1.5)).quality(84).auto('format').url();
  const mobileImage = image.mobileImage?.asset?._ref ? image.mobileImage : image;
  const mobileUrl = urlFor(mobileImage).width(720).quality(88).auto('format').url();
  const mobileUrl2x = urlFor(mobileImage).width(1080).quality(84).auto('format').url();

  return {
    alt: escapeHtml(mobileImage?.alt || image.alt || ''),
    desktopHeight,
    desktopUrl,
    desktopUrl2x,
    desktopWidth,
    mobileUrl,
    mobileUrl2x,
  };
};

const buildCardImage = (image?: SanityImage, title = 'Noticia Cyclone') => {
  if (!image?.asset?._ref) {
    return null;
  }

  const mobileImage = image.mobileImage?.asset?._ref ? image.mobileImage : image;

  return {
    alt: mobileImage?.alt || image.alt || title,
    desktopUrl: urlFor(image).width(620).quality(88).auto('format').url(),
    desktopUrl2x: urlFor(image).width(930).quality(82).auto('format').url(),
    mobileUrl: urlFor(mobileImage).width(720).quality(86).auto('format').url(),
    mobileUrl2x: urlFor(mobileImage).width(1080).quality(80).auto('format').url(),
  };
};

export async function getStaticPaths() {
  const slugs: Array<{ slug: string }> = await sanityClient.fetch(allSlugsQuery);
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post: Post | null = await sanityClient.fetch(postBySlugQuery, { slug });

if (!post) {
  return Astro.redirect('/404');
}

const allPosts: Post[] = await sanityClient.fetch(postsQuery);
const relatedPosts = allPosts
  .filter((item) => item.slug && item.slug !== post.slug)
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);

const heroMode = post.heroDisplayMode || 'featured';
const sliderImages = post.heroImages?.filter((image) => image.asset?._ref) || [];
const useSlider = heroMode === 'slider' && sliderImages.length > 0;
const featuredHeroImage = post.homeImage || sliderImages[0];
const socialImageUrl = featuredHeroImage ? urlFor(featuredHeroImage).width(1200).quality(88).auto('format').url() : undefined;
const categoryLabel = post.category ? categoryLabels[post.category] || post.category : null;

const bodyHTML = post.body
  ? toHTML(post.body, {
      components: {
        types: {
          image: ({ value }) => {
            if (!value?.asset?._ref) {
              return '';
            }

            const imageMarkup = buildImageMarkup(value, 1120, 720);
            const caption = value.caption
              ? `<figcaption class="portable-image__caption">${escapeHtml(value.caption)}</figcaption>`
              : '';

            return `
              <figure class="portable-image">
                <picture>
                  <source
                    media="(max-width: 767px)"
                    srcset="${imageMarkup.mobileUrl} 720w, ${imageMarkup.mobileUrl2x} 1080w"
                    sizes="100vw"
                  />
                  <img
                    src="${imageMarkup.desktopUrl}"
                    srcset="${imageMarkup.desktopUrl} 1120w, ${imageMarkup.desktopUrl2x} 1680w"
                    sizes="(min-width: 1200px) 760px, 100vw"
                    alt="${imageMarkup.alt}"
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
                ${caption}
              </figure>
            `;
          },
        },
        marks: {
          link: ({ children, value }) => {
            const href = value?.href ? escapeHtml(value.href) : '#';
            const rel = value?.blank ? ' rel="noreferrer noopener"' : '';
            const target = value?.blank ? ' target="_blank"' : '';
            return `<a href="${href}"${target}${rel}>${children}</a>`;
          },
        },
      },
    })
  : '';
---

<BaseLayout
  title={`${post.title} | Cyclone Motos`}
  description={post.excerpt}
  image={socialImageUrl}
>
  <article class="post-detail">
    <header class="post-detail__header">
      {categoryLabel && <p class="post-detail__category">{categoryLabel}</p>}
      <h1 class="post-detail__title">{post.title}</h1>
    </header>

    {useSlider ? (
      <section class="post-detail__hero-slider" aria-label="Imagenes principales de la noticia">
        <div class="post-detail__slider-track">
          {sliderImages.map((image, index) => {
            const heroImage = buildImageMarkup(image, 920, 620);

            return (
              <picture class="post-detail__slide">
                <source
                  media="(max-width: 767px)"
                  srcset={`${heroImage.mobileUrl} 720w, ${heroImage.mobileUrl2x} 1080w`}
                  sizes="100vw"
                />
                <img
                  src={heroImage.desktopUrl}
                  srcset={`${heroImage.desktopUrl} 920w, ${heroImage.desktopUrl2x} 1380w`}
                  sizes="(min-width: 1024px) 48vw, 100vw"
                  alt={heroImage.alt || `${post.title} ${index + 1}`}
                  width="920"
                  height="620"
                  loading={index < 2 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </picture>
            );
          })}
        </div>
      </section>
    ) : (
      featuredHeroImage && (
        <section class="post-detail__featured-wrap" aria-label="Imagen destacada de la noticia">
          {(() => {
            const heroImage = buildImageMarkup(featuredHeroImage, 1440, 760);

            return (
              <picture class="post-detail__featured">
                <source
                  media="(max-width: 767px)"
                  srcset={`${heroImage.mobileUrl} 720w, ${heroImage.mobileUrl2x} 1080w`}
                  sizes="100vw"
                />
                <img
                  src={heroImage.desktopUrl}
                  srcset={`${heroImage.desktopUrl} 1440w, ${heroImage.desktopUrl2x} 2160w`}
                  sizes="(min-width: 1200px) 1120px, 100vw"
                  alt={heroImage.alt || post.title}
                  width="1440"
                  height="760"
                  loading="eager"
                  decoding="async"
                />
              </picture>
            );
          })()}
        </section>
      )
    )}

    <div class="post-detail__share" aria-label="Compartir noticia">
      <button type="button" class="post-detail__share-button" data-share="facebook" aria-label="Compartir en Facebook">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M13.5 21v-7h2.35l.35-2.74H13.5V9.51c0-.79.22-1.33 1.35-1.33h1.44V5.73c-.25-.03-1.1-.11-2.08-.11-2.06 0-3.47 1.26-3.47 3.57v2.07H8.4V14h2.34v7h2.76Z" fill="currentColor" />
        </svg>
      </button>
      <button type="button" class="post-detail__share-button" data-share="instagram" aria-label="Compartir noticia">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7.75 3h8.5A4.75 4.75 0 0 1 21 7.75v8.5A4.75 4.75 0 0 1 16.25 21h-8.5A4.75 4.75 0 0 1 3 16.25v-8.5A4.75 4.75 0 0 1 7.75 3Zm0 1.8A2.95 2.95 0 0 0 4.8 7.75v8.5a2.95 2.95 0 0 0 2.95 2.95h8.5a2.95 2.95 0 0 0 2.95-2.95v-8.5a2.95 2.95 0 0 0-2.95-2.95h-8.5ZM12 7.6A4.4 4.4 0 1 1 7.6 12 4.4 4.4 0 0 1 12 7.6Zm0 1.8A2.6 2.6 0 1 0 14.6 12 2.6 2.6 0 0 0 12 9.4Zm4.65-3.25a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2Z" fill="currentColor" />
        </svg>
      </button>
      <button type="button" class="post-detail__share-button" data-share="copy" aria-label="Copiar enlace">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M8.5 12.8a4.25 4.25 0 0 1 0-6.01l2.47-2.47a4.25 4.25 0 0 1 6.01 6.01l-1.06 1.06-1.41-1.41 1.06-1.06a2.25 2.25 0 1 0-3.18-3.18L9.91 8.2a2.25 2.25 0 0 0 0 3.18l.71.71-1.41 1.41-.71-.7Zm7-1.6a4.25 4.25 0 0 1 0 6.01l-2.47 2.47a4.25 4.25 0 0 1-6.01-6.01l1.06-1.06 1.41 1.41-1.06 1.06a2.25 2.25 0 1 0 3.18 3.18l2.47-2.47a2.25 2.25 0 0 0 0-3.18l-.71-.71 1.41-1.41.71.7Z" fill="currentColor" />
        </svg>
      </button>
    </div>

    <div class="post-detail__content">
      {post.excerpt && <p class="post-detail__excerpt">{post.excerpt}</p>}
      {bodyHTML && <div class="post-detail__body" set:html={bodyHTML} />}
    </div>

    {post.galleryPhotos && post.galleryPhotos.length > 0 && (
      <section class="post-detail__gallery" aria-labelledby="post-gallery-title">
        <h2 id="post-gallery-title" class="post-detail__section-title">Galeria de fotos</h2>
        <div class="post-detail__gallery-grid">
          {post.galleryPhotos.map((image, index) => {
            const galleryImage = buildImageMarkup(image, 520, 360);

            return (
              <picture class="post-detail__gallery-item">
                <source
                  media="(max-width: 767px)"
                  srcset={`${galleryImage.mobileUrl} 720w, ${galleryImage.mobileUrl2x} 1080w`}
                  sizes="50vw"
                />
                <img
                  src={galleryImage.desktopUrl}
                  srcset={`${galleryImage.desktopUrl} 520w, ${galleryImage.desktopUrl2x} 780w`}
                  sizes="(min-width: 1024px) 25vw, 50vw"
                  alt={galleryImage.alt || `${post.title} ${index + 1}`}
                  width="520"
                  height="360"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
            );
          })}
        </div>
      </section>
    )}

    {relatedPosts.length > 0 && (
      <section class="post-detail__more" aria-labelledby="more-news-title">
        <h2 id="more-news-title" class="post-detail__more-title">Más noticias</h2>
        <div class="post-detail__more-grid">
          {relatedPosts.map((relatedPost) => {
            const image = buildCardImage(relatedPost.homeImage, relatedPost.homeTitle || relatedPost.title);
            const relatedCategory = relatedPost.category
              ? categoryLabels[relatedPost.category] || relatedPost.category
              : null;

            return (
              <article class="more-card">
                {image && (
                  <a href={`/noticias/${relatedPost.slug}`} class="more-card__image-link" tabindex="-1" aria-hidden="true">
                    <picture>
                      <source
                        media="(max-width: 767px)"
                        srcset={`${image.mobileUrl} 720w, ${image.mobileUrl2x} 1080w`}
                        sizes="100vw"
                      />
                      <img
                        src={image.desktopUrl}
                        srcset={`${image.desktopUrl} 620w, ${image.desktopUrl2x} 930w`}
                        sizes="(min-width: 1024px) 30vw, 100vw"
                        alt={image.alt}
                        width="620"
                        height="380"
                        loading="lazy"
                        decoding="async"
                      />
                    </picture>
                  </a>
                )}
                <div class="more-card__body">
                  {relatedCategory && <p class="more-card__category">{relatedCategory}</p>}
                  <h3 class="more-card__title">
                    <a href={`/noticias/${relatedPost.slug}`}>{relatedPost.homeTitle || relatedPost.title}</a>
                  </h3>
                  {relatedPost.excerpt && <p class="more-card__excerpt">{relatedPost.excerpt}</p>}
                  <a href={`/noticias/${relatedPost.slug}`} class="more-card__read-more">
                    Leer más <span aria-hidden="true">-&gt;</span>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    )}
  </article>

  <script>
    const copyToClipboard = async (value) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(value);
        return;
      }

      const input = document.createElement('textarea');
      input.value = value;
      input.setAttribute('readonly', '');
      input.style.position = 'fixed';
      input.style.opacity = '0';
      document.body.appendChild(input);
      input.select();
      document.execCommand('copy');
      input.remove();
    };

    document.querySelectorAll('[data-share]').forEach((button) => {
      button.addEventListener('click', async () => {
        const shareType = button.getAttribute('data-share');
        const shareUrl = window.location.href;
        const shareTitle = document.title;

        if (shareType === 'facebook') {
          window.open(
            `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`,
            '_blank',
            'noopener,noreferrer,width=720,height=520'
          );
          return;
        }

        if (shareType === 'instagram' && navigator.share) {
          await navigator.share({ title: shareTitle, url: shareUrl });
          return;
        }

        await copyToClipboard(shareUrl);
        button.classList.add('is-copied');
        window.setTimeout(() => button.classList.remove('is-copied'), 1400);
      });
    });
  </script>

  <style>
  .post-detail {
    padding: calc(var(--header-height, 72px) + clamp(2.5rem, 5vw, 4.5rem)) 0 clamp(5rem, 9vw, 8rem);
    background: #ffffff;
    color: var(--color-text);
  }

  .post-detail__header,
  .post-detail__content,
  .post-detail__gallery,
  .post-detail__more {
    width: min(100%, var(--container-max));
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .post-detail__header {
    max-width: 52rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
    text-align: center;
  }

  .post-detail__category {
    margin: 0 0 0.7rem;
    font-family: var(--font-body);
    font-size: var(--text-button);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .post-detail__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: 700;
    line-height: var(--leading-heading);
    letter-spacing: -0.035em;
    color: #101827;
  }

  .post-detail__hero-slider {
    width: min(100%, var(--container-max));
    margin-inline: auto;
    overflow: visible;
    padding-inline: var(--container-padding);
    margin-bottom: 1.3rem;
  }

  .post-detail__slider-track {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
  }

  .post-detail__slide {
    display: block;
    flex: 0 0 min(58rem, 62%);
    min-width: 0;
    overflow: hidden;
    scroll-snap-align: start;
  }

  .post-detail__slide img,
  .post-detail__featured img {
    display: block;
    width: 100%;
    height: clamp(22rem, 34vw, 32rem);
    object-fit: cover;
  }

  .post-detail__featured-wrap {
    width: min(100%, var(--container-max));
    margin: 0 auto 1.3rem;
    padding-inline: var(--container-padding);
  }

  .post-detail__featured {
    display: block;
    overflow: hidden;
  }

  .post-detail__share {
    display: flex;
    justify-content: center;
    gap: 0.45rem;
    width: min(100%, var(--container-max));
    margin: 0 auto clamp(1.8rem, 4vw, 2.8rem);
    padding-inline: var(--container-padding);
  }

  .post-detail__share-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--color-primary);
    border-radius: 999px;
    background: var(--color-primary);
    color: #ffffff;
    cursor: pointer;
    transition:
      background-color var(--transition-base),
      color var(--transition-base),
      transform var(--transition-base);
  }

  .post-detail__share-button:hover,
  .post-detail__share-button.is-copied {
    background: #ffffff;
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  .post-detail__share-button svg {
    width: 1rem;
    height: 1rem;
  }

  .post-detail__content {
    max-width: 54rem;
  }

  .post-detail__excerpt {
    margin: 0 0 1.7rem;
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    line-height: var(--leading-body);
    color: rgba(26, 28, 28, 0.78);
  }

  .post-detail__body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--color-text);
  }

  .post-detail__body :global(h2),
  .post-detail__body :global(h3),
  .post-detail__body :global(h4) {
    margin: clamp(1.8rem, 4vw, 2.5rem) 0 0.85rem;
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: var(--leading-subheading);
    letter-spacing: -0.03em;
    color: var(--color-text);
  }

  .post-detail__body :global(h2) {
    font-size: var(--text-h3);
  }

  .post-detail__body :global(h3) {
    font-size: var(--text-h4);
  }

  .post-detail__body :global(h4) {
    font-size: var(--text-body-lg);
  }

  .post-detail__body :global(p),
  .post-detail__body :global(ul),
  .post-detail__body :global(ol),
  .post-detail__body :global(blockquote),
  .post-detail__body :global(pre) {
    margin-bottom: 1.2rem;
  }

  .post-detail__body :global(ul),
  .post-detail__body :global(ol) {
    padding-left: 1.35rem;
  }

  .post-detail__body :global(li) {
    margin-bottom: 0.45rem;
  }

  .post-detail__body :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .post-detail__body :global(blockquote) {
    padding: 0.8rem 0 0.8rem 1.15rem;
    border-left: 3px solid var(--color-primary);
    color: var(--color-text-muted);
  }

  .post-detail__body :global(code) {
    padding: 0.12rem 0.28rem;
    border-radius: 0.2rem;
    background: rgba(26, 28, 28, 0.08);
  }

  .post-detail__body :global(pre) {
    overflow-x: auto;
    padding: 1.1rem 1.25rem;
    background: #121517;
    color: #ffffff;
  }

  .post-detail__body :global(.portable-image) {
    margin: clamp(2rem, 5vw, 3rem) 0;
  }

  .post-detail__body :global(.portable-image img) {
    display: block;
    width: 100%;
    height: auto;
  }

  .post-detail__body :global(.portable-image__caption) {
    margin-top: 0.65rem;
    font-size: var(--text-body-sm);
    color: var(--color-text-muted);
  }

  .post-detail__gallery {
    margin-top: clamp(2.5rem, 6vw, 4rem);
  }

  .post-detail__section-title,
  .post-detail__more-title {
    margin: 0 0 1.4rem;
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 700;
    line-height: var(--leading-subheading);
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .post-detail__gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .post-detail__gallery-item {
    display: block;
    overflow: hidden;
  }

  .post-detail__gallery-item img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    height: auto;
    object-fit: cover;
  }

  .post-detail__more {
    margin-top: clamp(3rem, 7vw, 5rem);
  }

  .post-detail__more-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2.2vw, 1.6rem);
  }

  .more-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid rgba(26, 28, 28, 0.08);
    box-shadow: 0 1rem 2.35rem rgba(26, 28, 28, 0.07);
  }

  .more-card__image-link {
    display: block;
    overflow: hidden;
  }

  .more-card__image-link:hover {
    text-decoration: none;
  }

  .more-card img {
    display: block;
    width: 100%;
    aspect-ratio: 5 / 3.15;
    height: auto;
    object-fit: cover;
  }

  .more-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.15rem;
  }

  .more-card__category {
    margin: 0 0 0.6rem;
    font-family: var(--font-body);
    font-size: var(--text-button);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .more-card__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    font-weight: 700;
    line-height: var(--leading-subheading);
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }

  .more-card__title a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .more-card__title a:hover {
    color: var(--color-primary);
  }

  .more-card__excerpt {
    display: -webkit-box;
    margin: 0.8rem 0 1.1rem;
    overflow: hidden;
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-compact);
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .more-card__read-more {
    display: inline-flex;
    width: fit-content;
    gap: 0.45rem;
    margin-top: auto;
    font-family: var(--font-body);
    font-size: var(--text-button);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    text-decoration: none;
  }

  .more-card__read-more:hover {
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }

  @media (max-width: 1023px) {
    .post-detail__slide {
      flex-basis: 82%;
    }

    .post-detail__slide img,
    .post-detail__featured img {
      height: clamp(18rem, 52vw, 28rem);
    }

    .post-detail__gallery-grid,
    .post-detail__more-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 639px) {
    .post-detail {
      padding-top: calc(var(--header-height, 72px) + 2.5rem);
    }

    .post-detail__header,
