---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { motosQuery } from '../../lib/queries';
import { fetchPromobilityModelo } from '../../lib/promobility';
import type { Moto, PromobilityMotoModel, SanityImage } from '../../lib/types';

interface CatalogMoto extends Moto {
  apiModel?: PromobilityMotoModel | null;
  displayName: string;
  cardImage?: SanityImage;
}

const motos = await sanityClient.fetch<Moto[]>(motosQuery);

const apiEntries = await Promise.all(
  motos.map(async (moto) => {
    if (!moto.apiMotoId) {
      return [moto._id, null] as const;
    }

    try {
      return [moto._id, await fetchPromobilityModelo(moto.apiMotoId)] as const;
    } catch (error) {
      console.warn(
        `No se pudo consultar Promobility para la moto ${moto.apiMotoId}:`,
        error instanceof Error ? error.message : error
      );
      return [moto._id, null] as const;
    }
  })
);

const apiByMotoId = new Map(apiEntries);
const catalogMotos: CatalogMoto[] = motos
  .filter((moto) => moto.slug)
  .map((moto) => {
    const apiModel = apiByMotoId.get(moto._id);

    return {
      ...moto,
      apiModel,
      displayName: apiModel?.modelo || moto.modelo || moto.nombre,
      cardImage: moto.fotoHeader || moto.imagenPrincipal || moto.imagenSliderHome,
    };
  });

const buildMotoImage = (image?: SanityImage, name = 'Motocicleta Cyclone') => {
  if (!image?.asset?._ref) {
    return null;
  }

  const mobileImage = image.mobileImage?.asset?._ref ? image.mobileImage : image;
  const sourceImage = mobileImage || image;
  return {
    alt: mobileImage?.alt || image.alt || name,
    desktopUrl: urlFor(sourceImage).width(760).quality(90).auto('format').url(),
    desktopUrl2x: urlFor(sourceImage).width(1140).quality(84).auto('format').url(),
    mobileUrl: urlFor(mobileImage).width(620).quality(88).auto('format').url(),
    mobileUrl2x: urlFor(mobileImage).width(930).quality(82).auto('format').url(),
  };
};
---

<BaseLayout
  title="Nuestros modelos | Cyclone Motos"
  description="Conoce todos los modelos de motocicletas Cyclone disponibles en Chile."
>
  <main class="motos-page">
    <section class="motos-catalog" aria-labelledby="motos-catalog-title">
      <div class="motos-catalog__container">
        <header class="motos-catalog__header">
          <h1 id="motos-catalog-title" class="motos-catalog__title">
            Nuestros <span>modelos</span>
          </h1>

          <nav class="motos-catalog__tabs" aria-label="Filtro de modelos">
            <a href="/motos/" class="motos-catalog__tab is-active" aria-current="page">Todas</a>
          </nav>
        </header>

        {catalogMotos.length > 0 ? (
          <div class="motos-catalog__grid">
            {catalogMotos.map((moto) => {
              const image = buildMotoImage(moto.cardImage, moto.displayName);

              return (
                <article class="motos-catalog__card">
                  <h2 class="motos-catalog__card-title">{moto.displayName}</h2>

                  <div class="motos-catalog__image-wrap">
                    {image ? (
                      <picture>
                        <source
                          media="(max-width: 767px)"
                          srcset={`${image.mobileUrl} 620w, ${image.mobileUrl2x} 930w`}
                          sizes="(min-width: 640px) 48vw, 100vw"
                        />
                        <img
                          src={image.desktopUrl}
                          srcset={`${image.desktopUrl} 760w, ${image.desktopUrl2x} 1140w`}
                          sizes="(min-width: 1280px) 360px, (min-width: 768px) 30vw, 100vw"
                          alt={image.alt}
                          width="760"
                          height="520"
                          loading="lazy"
                          decoding="async"
                        />
                      </picture>
                    ) : (
                      <div class="motos-catalog__image-placeholder" aria-hidden="true" />
                    )}
                  </div>

                  <div class="motos-catalog__actions">
                    <Button
                      href={`/motos/${moto.slug}`}
                      variant="outline"
                      size="sm"
                      class="motos-catalog__button"
                      fullWidth
                    >
                      Ver modelo
                    </Button>
                    <Button
                      href="#"
                      size="sm"
                      class="motos-catalog__button"
                      fullWidth
                    >
                      Cotizar
                    </Button>
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <p class="motos-catalog__empty">No hay modelos disponibles en este momento.</p>
        )}
      </div>
    </section>
  </main>

  <style>
    .motos-page {
      background: #ffffff;
      color: var(--color-text);
    }

    .motos-catalog {
      min-height: 100vh;
      padding: calc(var(--header-height, 72px) + clamp(2.5rem, 5vw, 4.5rem)) var(--container-padding) clamp(5rem, 9vw, 8rem);
    }

    .motos-catalog__container {
      width: min(100%, var(--container-max));
      margin: 0 auto;
    }

    .motos-catalog__header {
      margin-bottom: clamp(2rem, 4vw, 3.25rem);
    }

    .motos-catalog__title {
      margin: 0 0 clamp(2rem, 4vw, 3rem);
      font-family: var(--font-heading);
      font-size: var(--text-h2);
      font-weight: 700;
      line-height: var(--leading-heading);
      letter-spacing: -0.035em;
      text-transform: uppercase;
      color: #101827;
    }

    .motos-catalog__title span {
      color: var(--color-primary);
    }

    .motos-catalog__tabs {
      display: flex;
      align-items: center;
      gap: clamp(2rem, 5vw, 5rem);
      border-bottom: 1px solid rgba(26, 28, 28, 0.08);
    }

    .motos-catalog__tab {
      position: relative;
      display: inline-flex;
      padding: 0 0 0.85rem;
      font-family: var(--font-body);
      font-size: var(--text-button);
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-text);
      text-decoration: none;
    }

    .motos-catalog__tab::after {
      content: '';
      position: absolute;
      right: 0;
      bottom: -1px;
      left: 0;
      height: 2px;
      background: var(--color-primary);
      transform: scaleX(0);
      transform-origin: center;
      transition: transform var(--transition-base);
    }

    .motos-catalog__tab.is-active {
      color: var(--color-primary);
    }

    .motos-catalog__tab.is-active::after,
    .motos-catalog__tab:hover::after {
      transform: scaleX(1);
    }

    .motos-catalog__grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: clamp(1rem, 2vw, 1.6rem);
    }

    .motos-catalog__card {
      display: grid;
      grid-template-rows: auto 1fr auto;
      min-height: 26rem;
      padding: clamp(1.5rem, 2.5vw, 2rem);
      background: #ffffff;
      border: 1px solid rgba(26, 28, 28, 0.12);
      box-shadow: 0 1.15rem 2.4rem rgba(26, 28, 28, 0.08);
      transition:
        border-color var(--transition-base),
        box-shadow var(--transition-base);
    }

    .motos-catalog__card:hover {
      border-color: rgba(214, 0, 15, 0.42);
      box-shadow: 0 1.35rem 2.8rem rgba(26, 28, 28, 0.12);
    }

    .motos-catalog__card-title {
      margin: 0;
      font-family: var(--font-heading);
      font-size: var(--text-h4);
      font-weight: 700;
      line-height: var(--leading-subheading);
      letter-spacing: -0.03em;
      text-transform: uppercase;
      color: var(--color-text);
    }

    .motos-catalog__image-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 15rem;
      padding: 1rem 0;
    }

    .motos-catalog__image-wrap picture {
      display: block;
      width: 100%;
    }

    .motos-catalog__image-wrap img {
      display: block;
      width: 100%;
      height: auto;
      max-height: 16rem;
      object-fit: contain;
    }

    .motos-catalog__image-placeholder {
      width: 100%;
      height: 13rem;
      background:
        linear-gradient(135deg, rgba(26, 28, 28, 0.06), rgba(26, 28, 28, 0.02)),
        #f5f5f5;
    }

    .motos-catalog__actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .motos-catalog__button {
      min-height: 2.75rem;
    }

    .motos-catalog__empty {
      font-family: var(--font-body);
      font-size: var(--text-body);
      line-height: var(--leading-body);
      color: var(--color-text-muted);
    }

    @media (max-width: 1023px) {
      .motos-catalog__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 639px) {
      .motos-catalog {
        padding-inline: 1.1rem;
      }

      .motos-catalog__tabs {
        gap: 2rem;
        overflow-x: auto;
      }

      .motos-catalog__grid {
        grid-template-columns: 1fr;
      }

      .motos-catalog__card {
        min-height: auto;
      }

      .motos-catalog__actions {
        gap: 0.75rem;
      }
    }
  </style>
</BaseLayout>
