---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import MotoCta from '../../components/motos/MotoCta.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { motoBySlugQuery, allMotoSlugsQuery } from '../../lib/queries';
import { fetchPromobilityModelo, normalizePrice } from '../../lib/promobility';
import type { Moto, PromobilityMotoModel } from '../../lib/types';

export async function getStaticPaths() {
  const slugs = await sanityClient.fetch<{ slug: string }[]>(allMotoSlugsQuery);
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const moto = await sanityClient.fetch<Moto>(motoBySlugQuery, { slug });

if (!moto) {
  return Astro.redirect('/motos');
}

let apiModel: PromobilityMotoModel | null = null;

if (moto.apiMotoId) {
  try {
    apiModel = await fetchPromobilityModelo(moto.apiMotoId);
  } catch (error) {
    console.warn(
      `No se pudo consultar Promobility para la moto ${moto.apiMotoId}:`,
      error instanceof Error ? error.message : error
    );
  }
}

const additionalFeatures = moto.caracteristicasAdicionales ?? [];
const infoSection = moto.zonaInformativa;
const ctaFinal = moto.ctaFinal;
const galleryImages = (moto.galeriaFotos ?? []).map((img) => ({
  url: urlFor(img).width(1920).quality(88).auto('format').url(),
  alt: img.alt || moto.nombre,
}));
// Color images: map by nombre (matches API color.name) → desktop + mobile URL
const colorImagesForClient = (moto.colores ?? [])
  .filter((c) => c.imagen?.asset?._ref)
  .map((c) => ({
    nombre: c.nombre,
    desktop: urlFor(c.imagen).width(1500).quality(86).auto('format').url(),
    mobile: urlFor(c.imagen.mobileImage?.asset?._ref ? c.imagen.mobileImage : c.imagen).width(920).quality(82).auto('format').url(),
    alt: c.imagen.mobileImage?.alt || c.imagen.alt || `${moto.nombre} color ${c.nombre}`,
  }));
const technicalSheetUrl = moto.fichaTecnica?.asset?.url;
const sequenceFrames = (moto.scrollSequenceFrames ?? [])
  .filter((frame) => frame.asset?._ref)
  .sort((a, b) => (a.grado ?? 0) - (b.grado ?? 0));
const hasSequenceHero = sequenceFrames.length > 0;
const initialFrame = sequenceFrames.at(-1);
const modelName = apiModel?.modelo || moto.nombre;
const showGiantName = moto.mostrarNombreGigante !== false;
const displayListPrice = normalizePrice(apiModel?.precio_lista);
const displayBonusPrice = normalizePrice(apiModel?.precio);
const heroIcons = moto.heroImagenes ?? [];
const quoteImageSource = initialFrame?.mobileImage?.asset?._ref
  ? initialFrame.mobileImage
  : initialFrame || (moto.fotoHeader?.mobileImage?.asset?._ref ? moto.fotoHeader.mobileImage : moto.fotoHeader);
const quoteImage = quoteImageSource?.asset?._ref
  ? urlFor(quoteImageSource).width(1100).quality(88).auto('format').url()
  : undefined;
const quoteImageAlt = quoteImageSource?.alt || initialFrame?.alt || moto.fotoHeader?.alt || modelName;
const quoteModelData = apiModel
  ? JSON.stringify({
      id: apiModel.id,
      modelo: apiModel.modelo,
      precio: apiModel.precio,
      precio_lista: apiModel.precio_lista,
      bono: apiModel.bono,
      colors: apiModel.colors ?? [],
    })
  : undefined;
const quoteColorImages = JSON.stringify(colorImagesForClient.map((color) => ({
  name: color.nombre,
  desktop: color.desktop,
  mobile: color.mobile,
  alt: color.alt,
})));
const sequenceFramesForClient = sequenceFrames.map((frame) => ({
  desktop: urlFor(frame).width(1500).quality(86).auto('format').url(),
  mobile: urlFor(frame.mobileImage?.asset?._ref ? frame.mobileImage : frame).width(920).quality(82).auto('format').url(),
}));
const finalStats = [
  { value: apiModel?.cilindrada, label: 'Cilindrada', suffix: 'cc' },
  { value: apiModel?.peso, label: 'Peso', suffix: 'kg' },
  { value: apiModel?.altura_asiento, label: 'Altura del asiento', suffix: 'mm' },
  { value: apiModel?.tank_capacity, label: 'Capacidad estanque', suffix: 'L' },
].filter((stat) => stat.value);

function formatStatValue(value?: string | null, suffix?: string) {
  if (!value) return '';
  const cleanValue = String(value).replace(/[^\d.,]/g, '').trim() || String(value).trim();
  return suffix && !String(value).toLowerCase().includes(suffix.toLowerCase()) ? `${cleanValue} ${suffix}` : cleanValue;
}
---

<BaseLayout
  title={`${moto.nombre} | Cyclone Motos`}
  description={moto.descripcion ?? `Conoce la ${moto.nombre}, disponible en Cyclone Motos.`}
  image={moto.imagenPrincipal ? urlFor(moto.imagenPrincipal).width(1200).quality(86).auto('format').url() : undefined}
>
  {hasSequenceHero && initialFrame && (
    <section class="moto-sequence" data-moto-sequence data-sequence-dwell="50" aria-labelledby="moto-sequence-title">
      <div class="moto-sequence__stage">
        <div class="moto-sequence__background" aria-hidden="true">
          <picture>
            <source media="(max-width: 767px)" srcset="/moto/hero-mobile.webp"/>
            <img class="moto-sequence__background-image" src="/moto/hero.webp" alt="" width="1600" height="950" loading="eager" decoding="async" fetchpriority="high"/>
          </picture>
          {showGiantName && <span class="moto-sequence__ghost">{modelName}</span>}
        </div>

        <div class="moto-sequence__media">
          <img
            class="moto-sequence__image"
            src={urlFor(initialFrame).width(1500).quality(86).auto('format').url()}
            alt={initialFrame.alt || `${modelName} de Cyclone Motos`}
            width="1500"
            height="950"
            loading="eager"
            fetchpriority="high"
            decoding="sync"
          />
        </div>

        <div class="moto-sequence__initial">
          <h1 id="moto-sequence-title" class="moto-sequence__initial-title">{modelName}</h1>
          {displayListPrice && <p class="moto-sequence__list-price">Precio lista desde ${displayListPrice}</p>}
          {displayBonusPrice && (
            <p class="moto-sequence__bonus">
              <span>Precio bono:</span>
              <strong>${displayBonusPrice}</strong>
            </p>
          )}
          <Button
            type="button"
            size="lg"
            paddingX="4rem"
            paddingXMobile="2rem"
            data-open-quote
            data-quote-moto-id={moto.apiMotoId}
            data-quote-model={modelName}
            data-quote-image={quoteImage}
            data-quote-image-alt={quoteImageAlt}
            data-quote-model-data={quoteModelData}
            data-quote-color-images={quoteColorImages}
          >
            Cotiza aquí
          </Button>
        </div>

        <div class="moto-sequence__icons" aria-label="Certificaciones">
          {heroIcons.length > 0 ? (
            heroIcons.map((icon) => {
              const iconUrl = icon.asset?.url || urlFor(icon).width(96).quality(88).auto('format').url();

              return (
                <img
                  src={iconUrl}
                  alt={icon.alt || ''}
                  width="64"
                  height="64"
                  loading="eager"
                  decoding="async"
                />
              );
            })
          ) : (
            <>
              <span class="moto-sequence__icon-fallback">
                <strong>e3</strong>
                <small>Euro 3</small>
              </span>
              <span class="moto-sequence__icon-fallback">
                <strong>ABS</strong>
                <small>Frenos ABS</small>
              </span>
            </>
          )}
        </div>

        <div class="moto-sequence__final">
          {apiModel?.colors && apiModel.colors.length > 0 && (
            <ul class="moto-sequence__colors is-locked" aria-label="Colores disponibles">
              {apiModel.colors.slice(0, 6).map((color, index) => (
                <li data-color-name={color.name} style={`--item-index: ${index}; --item-total: ${Math.min(apiModel?.colors?.length ?? 1, 6) - 1}`}>
                  <span
                    class:list={[
                      'moto-sequence__color',
                      index === 0 ? 'is-active' : '',
                    ]}
                    style={`--color-swatch: ${color.color || '#d8d8d8'}`}
                  ></span>
                  <span class="moto-sequence__color-name">{color.name}</span>
                </li>
              ))}
            </ul>
          )}

          {apiModel?.colors && apiModel.colors.length > 0 && (
            <select class="moto-sequence__color-select" aria-label="Seleccionar color">
              {apiModel.colors.slice(0, 6).map((color, index) => (
                <option value={index}>{color.name}</option>
              ))}
            </select>
          )}

          {finalStats.length > 0 && (
            <div class="moto-sequence__specs" aria-label="Datos técnicos principales">
              {finalStats.map((stat, index) => (
                <div class="moto-sequence__spec" style={`--item-index: ${index}; --item-total: ${finalStats.length - 1}`}>
                  <strong>{formatStatValue(stat.value, stat.suffix)}</strong>
                  <span>{stat.label}</span>
                </div>
              ))}
            </div>
          )}

          <div class="moto-sequence__final-bar">
            <h2 class="moto-sequence__final-title a">{modelName}</h2>
            <div class="moto-sequence__final-action">
              {displayBonusPrice && (
                <p>
                  <span>Precio bono:</span>
                  <strong>${displayBonusPrice}</strong>
                </p>
              )}
              <Button
                type="button"
                size="lg"
                paddingX="4rem"
                paddingXMobile="2rem"
                data-open-quote
                data-quote-moto-id={moto.apiMotoId}
                data-quote-model={modelName}
                data-quote-image={quoteImage}
                data-quote-image-alt={quoteImageAlt}
                data-quote-model-data={quoteModelData}
                data-quote-color-images={quoteColorImages}
              >
                Cotiza aquí
              </Button>
            </div>
          </div>
        </div>

        <script type="application/json" class="moto-sequence__frames" set:html={JSON.stringify(sequenceFramesForClient)} />
        {colorImagesForClient.length > 0 && (
          <script type="application/json" class="moto-sequence__color-images" set:html={JSON.stringify(colorImagesForClient)} />
        )}
      </div>
    </section>
  )}

  {additionalFeatures.length > 0 && (
    <section class="moto-features" aria-labelledby="moto-features-title">
      <div class="moto-features__container">
        <h2 id="moto-features-title" class="moto-features__title">
          Características adicionales
        </h2>

        <div class="moto-features__grid">
          {additionalFeatures.map((feature, index) => {
            const desktopImage = urlFor(feature.imagen).width(560).quality(86).auto('format').url();
            const desktopImage2x = urlFor(feature.imagen).width(840).quality(80).auto('format').url();
            const mobileSource = feature.imagen.mobileImage?.asset?._ref ? feature.imagen.mobileImage : feature.imagen;
            const mobileImage = urlFor(mobileSource).width(420).quality(84).auto('format').url();
            const mobileImage2x = urlFor(mobileSource).width(310).quality(85).auto('format').url();
            const imageAlt = feature.imagen.mobileImage?.alt || feature.imagen.alt || feature.titulo;

            return (
              <article class="moto-features__card">
                <picture>
                  <source
                    media="(max-width: 767px)"
                    srcset={`${mobileImage} 420w, ${mobileImage2x} 640w`}
                    sizes="(min-width: 480px) 45vw, 90vw"
                  />
                  <img
                    class="moto-features__image"
                    src={desktopImage}
                    srcset={`${desktopImage} 560w, ${desktopImage2x} 840w`}
                    sizes="(min-width: 1280px) 19vw, (min-width: 768px) 22vw, 90vw"
                    alt={imageAlt}
                    width="560"
                    height="700"
                    loading={index < 4 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </picture>

                <div class="moto-features__content">
                  <h3 class="moto-features__name">{feature.titulo}</h3>
                  <p class="moto-features__detail">{feature.detalle}</p>
                </div>
              </article>
            );
          })}
        </div>

        {technicalSheetUrl && (
          <div class="moto-features__actions">
            <Button href={technicalSheetUrl} target="_blank" size="lg">
              Ver ficha técnica
            </Button>
          </div>
        )}
      </div>
    </section>
  )}

  {infoSection?.imagenFondo && (
    <section class="moto-info" aria-labelledby="moto-info-title">
      <picture class="moto-info__media">
        {(() => {
          const desktopImage = urlFor(infoSection.imagenFondo).width(1800).quality(84).auto('format').url();
          const desktopImage2x = urlFor(infoSection.imagenFondo).width(2600).quality(76).auto('format').url();
          const mobileSource = infoSection.imagenFondo.mobileImage?.asset?._ref
            ? infoSection.imagenFondo.mobileImage
            : infoSection.imagenFondo;
          const mobileImage = urlFor(mobileSource).width(820).quality(82).auto('format').url();
          const mobileImage2x = urlFor(mobileSource).width(1200).quality(76).auto('format').url();
          const imageAlt = infoSection.imagenFondo.mobileImage?.alt || infoSection.imagenFondo.alt || infoSection.titulo;

          return (
            <>
              <source
                media="(max-width: 767px)"
                srcset={`${mobileImage} 820w, ${mobileImage2x} 1200w`}
                sizes="100vw"
              />
              <img
                class="moto-info__image"
                src={desktopImage}
                srcset={`${desktopImage} 1800w, ${desktopImage2x} 2600w`}
                sizes="100vw"
                alt={imageAlt}
                width="1800"
                height="980"
                loading="lazy"
                decoding="async"
              />
            </>
          );
        })()}
      </picture>

      <div class="moto-info__overlay" aria-hidden="true"></div>

      <div class="moto-info__container">
        <div class="moto-info__content">
          <h2 id="moto-info-title" class="moto-info__title">{infoSection.titulo}</h2>
          <p class="moto-info__description">{infoSection.descripcion}</p>
        </div>
      </div>
    </section>
  )}

  {ctaFinal?.imagenFondo?.asset?._ref && (
    <MotoCta
      titulo={ctaFinal.titulo}
      imagenFondo={ctaFinal.imagenFondo}
      hasGallery={galleryImages.length > 0}
    />
  )}

  {galleryImages.length > 0 && (
    <dialog id="moto-gallery-dialog" class="moto-gallery" aria-label={`Galería de fotos de ${moto.nombre}`}>
      <div class="moto-gallery__header">
        <div class="moto-gallery__meta">
          <strong class="moto-gallery__moto-name">{moto.nombre}</strong>
          <span class="moto-gallery__label">Galería</span>
        </div>
        <button class="moto-gallery__close" aria-label="Cerrar galería">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
            <line x1="17" y1="5" x2="5" y2="17" />
            <line x1="5" y1="5" x2="17" y2="17" />
          </svg>
        </button>
      </div>

      <div class="moto-gallery__stage">
        <button class="moto-gallery__arrow moto-gallery__arrow--prev" aria-label="Foto anterior">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="12 3 6 9 12 15" />
          </svg>
        </button>

        <div class="moto-gallery__track">
          {galleryImages.map((img, i) => (
            <figure
              class:list={['moto-gallery__slide', { 'is-active': i === 0 }]}
              aria-hidden={i !== 0 ? 'true' : undefined}
            >
              <img
                class="moto-gallery__img"
                src={img.url}
                alt={img.alt}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </figure>
          ))}
        </div>

        <button class="moto-gallery__arrow moto-gallery__arrow--next" aria-label="Siguiente foto">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 3 12 9 6 15" />
          </svg>
        </button>
      </div>

      {galleryImages.length > 1 && (
        <div class="moto-gallery__dots" role="tablist" aria-label="Navegación de galería">
          {galleryImages.map((_, i) => (
            <button
              class:list={['moto-gallery__dot', { 'is-active': i === 0 }]}
              data-gallery-index={i}
              role="tab"
              aria-label={`Foto ${i + 1}`}
              aria-selected={i === 0 ? 'true' : 'false'}
            ></button>
          ))}
        </div>
      )}
    </dialog>
  )}
</BaseLayout>

<script>
  const sequenceSections = document.querySelectorAll<HTMLElement>('[data-moto-sequence]');

  sequenceSections.forEach((section) => {
    const stage = section.querySelector<HTMLElement>('.moto-sequence__stage');
    const image = section.querySelector<HTMLImageElement>('.moto-sequence__image');
    const framesNode = section.querySelector<HTMLScriptElement>('.moto-sequence__frames');

    if (!stage || !image || !framesNode?.textContent) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const frames = JSON.parse(framesNode.textContent) as { desktop: string; mobile: string }[];
    const useMobileFrames = window.matchMedia('(max-width: 767px)').matches;
    const frameUrls = frames.map((frame) => (useMobileFrames ? frame.mobile : frame.desktop));

    if (!frameUrls.length) return;

    const preloadFrame = (src: string) => {
      const preloadedImage = new Image();
      preloadedImage.decoding = 'async';
      preloadedImage.src = src;
    };

    frameUrls.slice(0, 4).forEach(preloadFrame);

    if (prefersReducedMotion) {
      image.src = frameUrls[0];
      section.style.setProperty('--sequence-progress', '1');
      section.classList.add('is-done');
      section.querySelector<HTMLElement>('.moto-sequence__colors')?.classList.remove('is-locked');
      return;
    }

    let activeFrame = -1;
    let ticking = false;

    const updateSequence = () => {
      const rect = section.getBoundingClientRect();
      const totalScrollable = Math.max(1, section.offsetHeight - window.innerHeight);
      // Reserve last N vh as "dwell" at final state — animation completes before end of scroll
      const dwellVh = parseFloat(section.dataset.sequenceDwell || '0');
      const animDistance = Math.max(1, totalScrollable - (dwellVh * window.innerHeight / 100));
      const progress = Math.min(1, Math.max(0, -rect.top / animDistance));
      const frameIndex = Math.round((1 - progress) * (frameUrls.length - 1));

      section.style.setProperty('--sequence-progress', progress.toFixed(3));
      section.classList.toggle('is-done', progress >= 0.6);

      if (frameIndex !== activeFrame) {
        activeFrame = frameIndex;
        image.src = frameUrls[frameIndex];
        const nextFrame = frameUrls[Math.max(0, frameIndex - 1)];

        if (nextFrame) {
          preloadFrame(nextFrame);
        }

        const colorsList = section.querySelector<HTMLElement>('.moto-sequence__colors');
        colorsList?.classList.toggle('is-locked', frameIndex !== 0);
      }

      ticking = false;
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(updateSequence);
    };

    updateSequence();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);

    // Scale ghost text so it fits within 90% of screen height when rotated
    if (useMobileFrames) {
      const ghost = section.querySelector<HTMLElement>('.moto-sequence__ghost');
      if (ghost) {
        ghost.style.fontSize = '';
        requestAnimationFrame(() => {
          const textWidth = ghost.scrollWidth;
          const maxSpan = window.innerHeight * 0.9;
          if (textWidth > maxSpan) {
            const currentSize = parseFloat(getComputedStyle(ghost).fontSize);
            ghost.style.fontSize = `${currentSize * (maxSpan / textWidth)}px`;
          }
        });
      }
    }
  });

  // Color selection
  document.querySelectorAll<HTMLElement>('.moto-sequence__colors').forEach((colorsList) => {
    const section = colorsList.closest<HTMLElement>('[data-moto-sequence]');
    const select = colorsList.closest('.moto-sequence__final')?.querySelector<HTMLSelectElement>('.moto-sequence__color-select');
    const seqImage = section?.querySelector<HTMLImageElement>('.moto-sequence__image');
    const colorImagesNode = section?.querySelector<HTMLScriptElement>('.moto-sequence__color-images');
    const colorImages: { nombre: string; desktop: string; mobile: string }[] =
      colorImagesNode?.textContent ? JSON.parse(colorImagesNode.textContent) : [];
    const useMobile = window.matchMedia('(max-width: 767px)').matches;

    const swapColorImage = (colorName: string) => {
      if (!seqImage || !colorImages.length) return;
      const match = colorImages.find((c) => c.nombre.trim().toLowerCase() === colorName.trim().toLowerCase());
      if (match) {
        seqImage.src = useMobile ? match.mobile : match.desktop;
      }
    };

    const setActive = (index: number) => {
      const items = Array.from(colorsList.querySelectorAll<HTMLElement>('[data-color-name]'));
      colorsList.querySelectorAll('.moto-sequence__color').forEach((el, i) => {
        el.classList.toggle('is-active', i === index);
      });
      const colorName = items[index]?.dataset.colorName ?? '';
      swapColorImage(colorName);
    };

    colorsList.addEventListener('click', (e) => {
      const item = (e.target as Element).closest<HTMLElement>('[data-color-name]');
      if (!item) return;
      const items = Array.from(colorsList.querySelectorAll<HTMLElement>('[data-color-name]'));
      const index = items.indexOf(item);
      setActive(index);
      if (select) select.value = String(index);
    });

    if (select) {
      select.addEventListener('change', () => {
        setActive(Number(select.value));
      });
    }
  });

  // ── Gallery lightbox ──────────────────────────────────────
  const galleryDialog = document.getElementById('moto-gallery-dialog') as HTMLDialogElement | null;
  const openBtn = document.querySelector<HTMLElement>('.js-open-gallery');

  if (galleryDialog && openBtn) {
    const slides = Array.from(galleryDialog.querySelectorAll<HTMLElement>('.moto-gallery__slide'));
    const dots = Array.from(galleryDialog.querySelectorAll<HTMLButtonElement>('.moto-gallery__dot'));
    let current = 0;

    const goTo = (index: number) => {
      if (!slides.length) return;
      slides[current]?.classList.remove('is-active');
      slides[current]?.setAttribute('aria-hidden', 'true');
      dots[current]?.classList.remove('is-active');
      dots[current]?.setAttribute('aria-selected', 'false');
      current = ((index % slides.length) + slides.length) % slides.length;
      slides[current]?.classList.add('is-active');
      slides[current]?.removeAttribute('aria-hidden');
      dots[current]?.classList.add('is-active');
      dots[current]?.setAttribute('aria-selected', 'true');
    };

    openBtn.addEventListener('click', () => {
      goTo(0);
      galleryDialog.showModal();
      document.documentElement.style.setProperty('overflow', 'hidden');
    });

    galleryDialog.querySelector('.moto-gallery__close')?.addEventListener('click', () => galleryDialog.close());
    galleryDialog.querySelector('.moto-gallery__arrow--prev')?.addEventListener('click', () => goTo(current - 1));
    galleryDialog.querySelector('.moto-gallery__arrow--next')?.addEventListener('click', () => goTo(current + 1));

    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    galleryDialog.addEventListener('close', () => {
      document.documentElement.style.removeProperty('overflow');
    });

    galleryDialog.addEventListener('click', (e) => {
      if (e.target === galleryDialog) galleryDialog.close();
    });

    galleryDialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') goTo(current - 1);
      if (e.key === 'ArrowRight') goTo(current + 1);
    });

    let touchStartX = 0;
    galleryDialog.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    galleryDialog.addEventListener('touchend', (e) => {
      const delta = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(delta) > 50) goTo(delta > 0 ? current + 1 : current - 1);
    }, { passive: true });
  }
</script>

<style>
  .moto-sequence {
    --sequence-progress: 0;
    position: relative;
    height: 255vh; /* +50vh dwell at final state */
    background: #eaeaea;
  }

  .moto-sequence__stage {
    position: sticky;
    top: 0;
    min-height: 100vh;
    overflow: hidden;
    background: #EAEAEA;
  }

  .moto-sequence__background {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .moto-sequence__background-image {
    position: absolute;
    top: 0;
    left: 0;
    width: auto;
    height: 100%;
    max-width: none;
    object-fit: contain;
    object-position: left center;
    opacity: calc(1 - var(--sequence-progress));
  }

  .moto-sequence__ghost {
    position: absolute;
    top: 55%;
    left: 50%;
    font-family: var(--font-heading);
    font-size: 100dvh;
    font-weight: 900;
    line-height: 0.82;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, calc(0.195 * (1 - var(--sequence-progress))));
    text-transform: uppercase;
    transform: translate(-50%, -50%);
    transition: opacity 120ms linear;
    user-select: none;
  }

  .moto-sequence__media {
    position: absolute;
    z-index: 2;
    left: calc(-4vw + (var(--sequence-progress) * 54vw));
    top: calc(100% - (var(--sequence-progress) * 56%));
    width: calc(clamp(42rem, 78vw, 74rem) - (var(--sequence-progress) * clamp(9rem, 24vw, 22rem)));
    max-width: 74rem;
    min-width: 0;
    transform:
      translateX(calc(var(--sequence-progress) * -50%))
      translateY(calc(-100% + (var(--sequence-progress) * 50%)));
    filter: drop-shadow(0 2.75rem 2.2rem rgba(8, 18, 24, calc(0.2 + var(--sequence-progress) * 0.08)));
  }

  .moto-sequence__image {
    display: block;
    width: 100%;
    height: auto;
    user-select: none;
    pointer-events: none;
  }

  .moto-sequence__initial {
    position: absolute;
    z-index: 5;
    top: 22%;
    right: max(var(--container-padding), calc((100% - var(--container-max)) / 2));
    padding-right: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    width: min(32rem, 38vw);
    text-align: right;
    color: var(--color-text);
    opacity: calc(1 - (var(--sequence-progress) * 1.65));
    transform: translateX(calc(var(--sequence-progress) * 2rem));
  }

  .moto-sequence.is-done .moto-sequence__initial {
    pointer-events: none;
  }

  .moto-sequence__initial-title {
    @apply font-heading uppercase;
    color: var(--color-text);
    font-size: clamp(3rem, 5.2vw, 5.25rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.06em;
  }

  .moto-sequence__list-price {
    @apply font-body uppercase;
    margin-top: 1.25rem;
    color: var(--color-text);
    font-size: var(--text-body);
    letter-spacing: 0.04em;
  }

  .moto-sequence__bonus {
    @apply font-heading uppercase flex flex-col items-start md:items-end;
    gap: 0.25rem;
    margin: 1rem 0 1.5rem;
    color: var(--color-text);
  }

  .moto-sequence__bonus span {
    font-size: var(--text-body);
    font-weight: 800;
  }

  .moto-sequence__bonus strong {
    font-size: var(--text-h3);
    line-height: 1;
  }

  .moto-sequence__icons {
    position: absolute;
    z-index: 6;
    right: max(var(--container-padding), calc((100% - var(--container-max)) / 2));
    padding-right: 1.5rem;
    bottom: 3.75rem;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    opacity: calc(1 - (var(--sequence-progress) * 1.8));
    pointer-events: none;
  }

  .moto-sequence__icons img {
    width: 4.75rem;
    height: 4.75rem;
    object-fit: contain;
  }

  .moto-sequence__icon-fallback {
    display: grid;
    place-items: center;
    width: 4.25rem;
    min-height: 3.75rem;
    color: var(--color-text);
    text-align: center;
  }

  .moto-sequence__icon-fallback strong {
    @apply font-heading uppercase;
    font-size: 1.85rem;
    font-weight: 900;
    line-height: 0.85;
    letter-spacing: -0.08em;
  }

  .moto-sequence__icon-fallback small {
    @apply font-body uppercase;
    margin-top: 0.2rem;
    font-size: 0.5rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .moto-sequence__final {
    position: absolute;
    inset: 0;
    z-index: 4;
    opacity: calc((var(--sequence-progress) - 0.44) * 1.8);
    pointer-events: none;
  }

  .moto-sequence__colors {
    position: absolute;
    left: max(var(--container-padding), calc((100% - var(--container-max)) / 2) + 1.5rem);
    top: 50%;
    transform: translateY(-50%);
    width: 8rem;
    height: 20rem;
    padding: 0;
    margin: 0;
    list-style: none;
    pointer-events: auto;
    transition: opacity 400ms ease;
  }

  .moto-sequence__colors.is-locked {
    opacity: 0.25;
    pointer-events: none;
  }

  .moto-sequence__colors li {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    min-height: 1.4rem;
    /* Distribución dinámica con curvatura:
       - top: distribuye uniformemente de 0% a 100%
       - left: máximo indent (2.05rem) en extremos, 0 en el centro
         fórmula: 2.05rem × 2 × |index − total/2| / total            */
    top: calc(var(--item-index) * 100% / max(var(--item-total), 1));
    left: calc(2.05rem * 2 * abs(var(--item-index) - var(--item-total) / 2) / max(var(--item-total), 1));
    transform: translateY(-50%);
  }

  /* Caso especial: un único color → centrado verticalmente, sin indent */
  .moto-sequence__colors li:only-child {
    top: 50%;
    left: 0;
  }

  .moto-sequence__color {
    display: block;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 9999px;
    background: var(--color-swatch);
    border: 1px solid rgba(26, 28, 28, 0.22);
    box-shadow: 0 0.2rem 0.5rem rgba(26, 28, 28, 0.28), 0 0 0 1px rgba(26, 28, 28, 0.1);
    cursor: pointer;
    transition: transform 180ms ease;
  }

  .moto-sequence__color:hover {
    transform: scale(1.2);
  }

  .moto-sequence__color-select {
    display: none;
  }

  .moto-sequence__color.is-active {
    outline: 2px solid rgba(26, 28, 28, 0.12);
    outline-offset: 0.18rem;
  }

  .moto-sequence__color-name {
    @apply font-body uppercase font-semibold;
    display: none;
    color: var(--color-text);
    font-size: var(--text-body-sm);
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .moto-sequence__color.is-active + .moto-sequence__color-name {
    display: block;
  }

  .moto-sequence__specs {
    position: absolute;
    right: max(var(--container-padding), calc((100% - var(--container-max)) / 2) + 1.5rem);
    top: 50%;
    transform: translateY(-50%);
    width: 12rem;
    height: 20rem;
    padding-left: 0;
  }

  .moto-sequence__spec {
    position: absolute;
    display: grid;
    gap: 0.2rem;
    min-width: 12rem;
    padding-left: 1.5rem;
    transform: translateY(-50%);
  }

  .moto-sequence__spec:nth-of-type(1) {
    top: 0%;
    left: 0.95rem;
  }

  .moto-sequence__spec:nth-of-type(2) {
    top: 33.333%;
    left: 3.45rem;
  }

  .moto-sequence__spec:nth-of-type(3) {
    top: 66.666%;
    left: 3.45rem;
  }

  .moto-sequence__spec:nth-of-type(4) {
    top: 100%;
    left: 0.95rem;
  }

  .moto-sequence__spec::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 9999px;
    background: var(--color-primary);
  }

  .moto-sequence__spec strong {
    @apply font-heading;
    color: var(--color-text);
    font-size: var(--text-h4);
    font-weight: 700;
    line-height: 1;
  }

  .moto-sequence__spec span {
    @apply font-body uppercase;
    color: var(--color-primary);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .moto-sequence__final-bar {
    position: absolute;
    left: max(var(--container-padding), calc((100% - var(--container-max)) / 2) + 1.5rem);
    right: max(var(--container-padding), calc((100% - var(--container-max)) / 2) + 1.5rem);
    bottom: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .moto-sequence__final-title {
    @apply font-heading uppercase;
    color: var(--color-text);
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.06em;
  }

  .moto-sequence__final-action {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    pointer-events: none;
  }

  .moto-sequence.is-done .moto-sequence__final-action {
    pointer-events: auto;
  }

  .moto-sequence__final-action p {
    @apply font-heading uppercase;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    color: var(--color-text);
  }

  .moto-sequence__final-action span {
    @apply font-body;
    font-size: var(--text-body);
    font-weight: 800;
  }

  .moto-sequence__final-action strong {
    font-size: var(--text-h3);
    line-height: 1;
  }

  .moto-info {
    @apply relative overflow-hidden;
    background: var(--color-secondary-dark);
    margin-top: -2px;
    z-index: 1;
  }

  .moto-info__media,
  .moto-info__image {
    @apply absolute inset-0 h-full w-full;
  }

  .moto-info__image {
    object-fit: cover;
    object-position: bottom;
  }

  .moto-info__overlay {
    @apply absolute inset-0;
    background:
      linear-gradient(180deg, rgba(16, 17, 17, 1) 0%, rgba(0, 0, 0, 0) 30%);
  }

  .moto-info__container {
    @apply relative z-10 mx-auto flex items-center;
    height:55rem;
    max-width: var(--container-max);
    padding-inline: var(--container-padding); 
  }

  .moto-info__content {
    margin-left: auto;
    max-width: 36rem;
    text-align: center;
    color: var(--color-text-light);
  }

  .moto-info__title {
    @apply font-heading uppercase text-white text-h2 text-end;
    font-weight: 700;
    text-shadow: 0 0.25rem 1.5rem rgba(0, 0, 0, 0.28);
  }

  .moto-info__description {
    @apply font-body text-body-lg text-end;
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.92);
    font-weight: 700;
    line-height: 1.45;
    text-shadow: 0 0.2rem 1rem rgba(0, 0, 0, 0.34);
  }

  .moto-features {
    @apply relative overflow-hidden;
    padding: 4.25rem 0 3.75rem;
    background: var(--color-secondary-dark);
    color: var(--color-text-light);
  }

  .moto-features__container {
    @apply mx-auto;
    max-width: var(--container-max);
    padding: 0 var(--container-padding);
  }

  .moto-features__title {
    @apply font-heading text-center uppercase text-white text-h2;
    font-weight: 700;
    margin-bottom: 2.5rem;
  }

  .moto-features__grid {
    @apply grid;
    gap: 0.65rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .moto-features__card {
    @apply relative overflow-hidden;
    background: #0f1111;
    aspect-ratio: 4 / 5;
  }

  .moto-features__image {
    @apply h-full w-full;
    object-fit: cover;
    transition: transform 520ms ease;
  }

  .moto-features__card:hover .moto-features__image {
    transform: scale(1.035);
  }

  .moto-features__content {
    @apply absolute inset-x-0 bottom-0;
    padding: 2.5rem 1rem 1rem;
    background: linear-gradient(0deg, rgba(15, 17, 17, 0.9) 0%, rgba(15, 17, 17, 0) 100%);
    text-align: center;
    opacity: 0;
    transform: translateY(0.5rem);
    transition:
      opacity var(--transition-base),
      transform var(--transition-base);
  }

  .moto-features__card:hover .moto-features__content,
  .moto-features__card:focus-within .moto-features__content {
    opacity: 1;
    transform: translateY(0);
  }

  .moto-features__name {
    @apply font-heading uppercase text-white;
    font-size: var(--text-body-lg);
    font-weight: 400;
  }

  .moto-features__detail {
    @apply font-body;
    margin-top: 0.35rem;
    color: rgba(255, 255, 255, 1);
    font-size: var(--text-body-lg);
  }

  .moto-features__actions {
    @apply flex justify-center;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .moto-features {
      padding: 4.75rem 0 4.25rem;
    }

    .moto-features__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (min-width: 1181px) and (max-width: 1600px) {
    .moto-sequence__media {
      left: calc(-3vw + (var(--sequence-progress) * 52vw));
      width: calc(clamp(36rem, 62vw, 68rem) - (var(--sequence-progress) * clamp(7rem, 18vw, 16rem)));
      top: calc(100% - (var(--sequence-progress) * 56%));
    }
  }

  @media (min-width: 768px) and (max-width: 1180px) {
    .moto-sequence__media {
        left: calc(-21vw + (var(--sequence-progress) * 68vw));
        width: calc(clamp(48rem, 125vw, 90rem) - (var(--sequence-progress) * clamp(33rem, 49vw, 30rem)));
        top: calc(100% - (var(--sequence-progress) * 54%));
    }

    
  }

  @media (min-width:981) and (max-width:1180px){
    .moto-sequence__initial {
      right: max(var(--container-padding), calc((100% - var(--container-max)) / 2));
      width: min(25rem, 36vw);
    }
  }

  @media (max-width: 980px) {
    .moto-sequence {
      height: 230vh; /* +50vh dwell at final state */
    }

    .moto-sequence__stage {
      min-height: 100svh;
    }

    .moto-sequence__background-image {
      width: auto;
      height: 100%;
      object-position: top center;
    }

    .moto-sequence__ghost {
      top: 50%;
      left: 50%;
      right: auto;
      font-size: min(40dvh, 90vw);
      transform: translate(-50%, -50%) rotate(270deg);
      transform-origin: center center;
      white-space: nowrap;
    }

    .moto-sequence__media {
      left: calc(-37vw + (var(--sequence-progress) * 87vw));
      top: calc(105% - (var(--sequence-progress) * 60%));
      width: calc(175vw - (var(--sequence-progress) * 73vw));
      min-width: 0;
    }

    .moto-sequence__initial {
      top: calc(var(--header-height) + 2rem);
      left: max(var(--container-padding), calc((100% - var(--container-max)) / 2));
      right: auto;
      bottom: auto;
      width: auto;
      max-width: calc(100% - (var(--container-padding) * 2));
      align-items: flex-start;
      text-align: left;
      color: white;
    }

    .moto-sequence__initial-title {
      font-size: clamp(3.25rem, 17vw, 5rem);
      color: white;
    }

    .moto-sequence__list-price,
    .moto-sequence__bonus {
      color: white;
    }

    .moto-sequence__icons {
      display: none;
    }

    .moto-sequence__icons img {
      width: 3rem;
      height: 3rem;
    }

    .moto-sequence__icon-fallback {
      width: 3.4rem;
      min-height: 3rem;
    }

    .moto-sequence__icon-fallback strong {
      font-size: 1.45rem;
    }

    .moto-sequence__colors {
      left: 0;
      right: 0;
      top: auto;
      bottom: 28%;
      transform: none;
      width: 100%;
      height: auto;
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      pointer-events: auto;
      z-index: 10;
    }

    .moto-sequence__color-name {
      display: none !important;
    }

    .moto-sequence__colors li {
      position: static;
      transform: none;
    }

    .moto-sequence__colors li:nth-child(1),
    .moto-sequence__colors li:nth-child(2),
    .moto-sequence__colors li:nth-child(3),
    .moto-sequence__colors li:nth-child(4),
    .moto-sequence__colors li:nth-child(5),
    .moto-sequence__colors li:nth-child(6) {
      top: auto;
      left: auto;
    }

    .moto-sequence__color-select {
      display: none;
    }

    .moto-sequence__specs {
      left: var(--container-padding);
      right: var(--container-padding);
      right: auto;
      top: 14%;
      bottom: auto;
      transform: none;
      width: calc(100% - (var(--container-padding) * 2));
      height: auto;
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      padding-left: 0;
    }

    .moto-sequence__spec {
      position: static;
      transform: none;
      padding-left: 0;
      min-width: 0;
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.15rem;
      border-left: 1px solid rgba(26, 28, 28, 0.1);
      padding: 0 0.5rem;
    }

    .moto-sequence__spec:first-child {
      border-left: none;
      padding-left: 0;
    }

    .moto-sequence__spec::before {
      display: none;
    }

    .moto-sequence__spec:nth-of-type(1),
    .moto-sequence__spec:nth-of-type(2),
    .moto-sequence__spec:nth-of-type(3),
    .moto-sequence__spec:nth-of-type(4) {
      top: auto;
      left: auto;
    }

    .moto-sequence__final-bar {
      left: var(--container-padding);
      right: var(--container-padding);
      bottom: 2rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .moto-sequence__final-action {
      width: 100%;
      justify-content: space-between;
      gap: 1rem;
    }

    .moto-sequence__final-action p {
      flex-direction: column;
      gap: 0.2rem;
    }

    .moto-info__overlay {
      background:
      linear-gradient(180deg, rgba(16, 17, 17, 1) 0%, rgba(0, 0, 0, 0) 30%),
      linear-gradient(180deg, rgba(26, 28, 28, 0.18) 0%, rgba(26, 28, 28, 0.46) 100%),
      linear-gradient(90deg, rgba(26, 28, 28, 0.06) 0%, rgba(26, 28, 28, 0.46) 48%, rgba(26, 28, 28, 0.62) 100%);
    }

    .moto-info__container {
      max-height: 80dvh;
      align-items: flex-end;
      padding-bottom: 2.25rem;
    }

    .moto-info__content {
      margin-left: 0;
      max-width: 100%;
      text-align: left;
    }

    .moto-features__content {
      opacity: 1;
      transform: none;
    }
  }

  /* ── Gallery lightbox ──────────────────────────────────── */
  .moto-gallery {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    background: rgba(10, 10, 10, 0.65);
    border: none;
    backdrop-filter: blur(24px) saturate(0.6);
    -webkit-backdrop-filter: blur(24px) saturate(0.6);
    display: none;
    flex-direction: column;
  }

  .moto-gallery[open] {
    display: flex;
  }

  .moto-gallery::backdrop {
    background: rgba(0, 0, 0, 0.14);
  }

  .moto-gallery__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1.25rem 1.5rem 1rem;
    flex-shrink: 0;
  }

  .moto-gallery__meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .moto-gallery__moto-name {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: 900;
    color: white;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .moto-gallery__label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.45);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .moto-gallery__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 9999px;
    color: white;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 200ms;
  }

  .moto-gallery__close:hover {
    background: rgba(255, 255, 255, 0.18);
  }

  .moto-gallery__stage {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    min-height: 0;
  }

  .moto-gallery__track {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .moto-gallery__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 1rem 3.75rem 1.5rem;
    opacity: 0;
    transition: opacity 280ms ease;
    pointer-events: none;
  }

  .moto-gallery__slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .moto-gallery__img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }

  .moto-gallery__arrow {
    position: absolute;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
