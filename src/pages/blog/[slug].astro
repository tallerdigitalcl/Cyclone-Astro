---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { postBySlugQuery, allSlugsQuery } from '../../lib/queries';
import { toHTML } from '@portabletext/to-html';
import type { Post } from '../../lib/types';

export async function getStaticPaths() {
  const slugs: Array<{ slug: string }> = await sanityClient.fetch(allSlugsQuery);
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post: Post | null = await sanityClient.fetch(postBySlugQuery, { slug });

if (!post) {
  return Astro.redirect('/404');
}

const bodyHTML = post.body ? toHTML(post.body) : '';

const mainImageUrl = post.mainImage
  ? urlFor(post.mainImage).width(1200).height(630).auto('format').url()
  : undefined;

const formattedDate = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('es-CL', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout
  title={`${post.title} | Astro Cyclone`}
  description={post.excerpt}
  image={mainImageUrl}
>
  <article class="post">
    <div class="container">
      <header class="post__header">
        <h1 class="post__title">{post.title}</h1>
        <div class="post__meta">
          {post.author && <span>Por <strong>{post.author.name}</strong></span>}
          {formattedDate && (
            <time datetime={post.publishedAt}>{formattedDate}</time>
          )}
        </div>
      </header>

      {mainImageUrl && (
        <img
          src={mainImageUrl}
          alt={post.mainImage?.alt ?? post.title}
          width="1200"
          height="630"
          class="post__image"
        />
      )}

      <div class="post__body" set:html={bodyHTML} />

      <div class="post__back">
        <a href="/blog">← Volver al blog</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .post__header {
    margin-bottom: 2rem;
  }

  .post__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .post__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .post__image {
    width: 100%;
    height: auto;
    border-radius: 0.75rem;
    margin-bottom: 2.5rem;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
  }

  /* Estilos para el contenido generado por Portable Text */
  .post__body :global(h2) { font-size: 1.6rem; margin: 2.5rem 0 0.75rem; letter-spacing: -0.02em; }
  .post__body :global(h3) { font-size: 1.3rem; margin: 2rem 0 0.6rem; }
  .post__body :global(h4) { font-size: 1.1rem; margin: 1.75rem 0 0.5rem; }
  .post__body :global(p) { margin-bottom: 1.4rem; }
  .post__body :global(ul),
  .post__body :global(ol) { padding-left: 1.75rem; margin-bottom: 1.4rem; }
  .post__body :global(li) { margin-bottom: 0.4rem; }
  .post__body :global(strong) { font-weight: 700; }
  .post__body :global(em) { font-style: italic; }
  .post__body :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: 0.5rem 0 0.5rem 1.25rem;
    margin: 1.75rem 0;
    color: var(--color-muted);
    font-style: italic;
  }
  .post__body :global(img) {
    border-radius: 0.5rem;
    margin: 1.75rem 0;
    width: 100%;
  }
  .post__body :global(a) { color: var(--color-primary); text-decoration: underline; }
  .post__body :global(code) {
    background: #f3f4f6;
    padding: 0.2em 0.45em;
    border-radius: 0.3em;
    font-size: 0.875em;
    font-family: 'Fira Code', 'Cascadia Code', monospace;
  }
  .post__body :global(pre) {
    background: #1e1e2e;
    color: #cdd6f4;
    padding: 1.25rem 1.5rem;
    border-radius: 0.6rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.88rem;
    line-height: 1.6;
  }
  .post__body :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }
  .post__body :global(hr) {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2.5rem 0;
  }

  .post__back {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
  }

  .post__back a {
    font-weight: 600;
  }
</style>
