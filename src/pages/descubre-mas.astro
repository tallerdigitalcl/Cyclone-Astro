---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import { sanityClient, urlFor } from '../lib/sanity';
import { descubreMasPageQuery } from '../lib/queries';
import type { DescubreMasPage, SanityImage } from '../lib/types';

const fallbackContent: Omit<DescubreMasPage, '_id' | 'imagenFondo'> & { imagenFondo?: SanityImage } = {
  titulo: 'La marca PREMIUM del Grupo Zonsen',
  tituloDestacado: 'aterriza en Europa',
  descripcion:
    'Somos Cyclone Motor y llevamos mas de 30 anos de la mano del Grupo Zonsen ofreciendo soluciones de movilidad. Nos apasiona innovar y explorar nuevos horizontes.\nCada modelo Cyclone es un ejemplo de diseno puro y funcional.',
  descripcionInferior:
    'Tomamos las aventuras de referencia y lo transformamos en un estilo propio, convirtiendonos en una marca autentica y sin complejos.',
  textoGrandeInferior: 'Que nos dices?\nTe subes a la aventura con Cyclone?',
  botonTexto: 'Conocer todos los concesionarios',
  botonUrl: '/concesionarios',
};

let pageContent: DescubreMasPage | null = null;

try {
  pageContent = await sanityClient.fetch<DescubreMasPage | null>(descubreMasPageQuery);
} catch (error) {
  console.error('[DescubreMas] Error fetching Sanity content:', error);
}

const content = {
  ...fallbackContent,
  ...pageContent,
};

const desktopImage = content.imagenFondo?.asset ? urlFor(content.imagenFondo).width(1920).quality(86).format('webp').url() : '';
const mobileImage = content.imagenFondo?.mobileImage?.asset
  ? urlFor(content.imagenFondo.mobileImage).width(900).quality(84).format('webp').url()
  : desktopImage;
const desktopDimensions = content.imagenFondo?.dimensions;
const mobileDimensions = content.imagenFondo?.mobileImage?.dimensions || desktopDimensions;
const desktopRatio = desktopDimensions?.width && desktopDimensions?.height
  ? `${desktopDimensions.width} / ${desktopDimensions.height}`
  : '16 / 9';
const mobileRatio = mobileDimensions?.width && mobileDimensions?.height
  ? `${mobileDimensions.width} / ${mobileDimensions.height}`
  : desktopRatio;
const descripcionLines = content.descripcion.split('\n').map((line) => line.trim()).filter(Boolean);
const descripcionInferiorLines = content.descripcionInferior.split('\n').map((line) => line.trim()).filter(Boolean);
const textoGrandeLines = content.textoGrandeInferior.split('\n').map((line) => line.trim()).filter(Boolean);
---

<BaseLayout
  title="Descubre más - Cyclone Motos"
  description={descripcionLines[0] || 'Descubre mas sobre Cyclone Motos.'}
>
  <main class="discover-page">
    <section
      class="discover-hero"
      style={`--discover-bg-desktop: url('${desktopImage}'); --discover-bg-mobile: url('${mobileImage}'); --discover-ratio-desktop: ${desktopRatio}; --discover-ratio-mobile: ${mobileRatio};`}
      aria-labelledby="discover-title"
    >
      <div class="discover-hero__container">
        <div class="discover-hero__content">
          <h1 id="discover-title" class="discover-hero__title">
            {content.titulo}
            {content.tituloDestacado && <span>{content.tituloDestacado}</span>}
          </h1>

          <div class="discover-hero__description">
            {descripcionLines.map((line) => <p>{line}</p>)}
          </div>
        </div>
      </div>
    </section>

    <section class="discover-cta" aria-label="Invitacion Cyclone">
      <div class="discover-cta__inner">
        <div class="discover-cta__description">
          {descripcionInferiorLines.map((line) => <p>{line}</p>)}
        </div>

        <h2 class="discover-cta__title">
          {textoGrandeLines.map((line) => <span>{line}</span>)}
        </h2>

        <Button href={content.botonUrl} size="wide" class="discover-cta__button">
          {content.botonTexto}
        </Button>
      </div>
    </section>
  </main>

  <style>
    .discover-page {
      background: #171b1c;
      color: var(--color-text-light);
    }

    .discover-hero {
      position: relative;
      aspect-ratio: var(--discover-ratio-desktop);
      min-height: 42rem;
      max-height: none;
      padding: calc(var(--header-height, 72px) + clamp(2.5rem, 5.8vw, 5rem)) 1.5rem clamp(4rem, 10vw, 8rem);
      background-image:
        linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0%, rgba(255, 255, 255, 0) 28%, rgba(23, 27, 28, 0) 72%, #171b1c 100%),
        var(--discover-bg-desktop);
      background-position: center top;
      background-size: cover;
      background-repeat: no-repeat;
      color: #101827;
    }

    .discover-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(255, 255, 255, 0.42) 0%, rgba(255, 255, 255, 0.16) 38%, rgba(255, 255, 255, 0) 68%);
      pointer-events: none;
    }

    .discover-hero::after {
      content: '';
      position: absolute;
      right: 0;
      bottom: 0;
      left: 0;
      height: 10%;
      background: linear-gradient(0deg, #171b1c 0%, rgba(23, 27, 28, 0) 100%);
      pointer-events: none;
    }

    .discover-hero__container {
      position: relative;
      z-index: 1;
      width: min(100%, var(--container-max));
      height: 100%;
      padding-inline:1.5rem;
      margin: 0 auto;
    }

    .discover-hero__content {
      position: relative;
    }

    .discover-hero__title {
      @apply text-white md:text-black;
      margin: 0;
      font-family: var(--font-heading);
      font-size: clamp(2rem, 4.1vw, 3.6rem);
      font-weight: 700;
      line-height: 1.08;
      letter-spacing: -0.04em;
    }

    .discover-hero__title span {
      display: block;
      color: var(--color-primary);
    }

    .discover-hero__description {
      display: grid;
      gap: 0.7rem;
      width: min(100%, 30rem);
      margin-top: clamp(2rem, 5vw, 4rem);
      font-family: var(--font-body);
      font-size: var(--text-body);
      line-height: var(--leading-body);
      color: #101010;
    }

    .discover-hero__description p,
    .discover-cta__description p {
      margin: 0;
    }
    .discover-hero__description p{
      @apply text-white md:text-black;
    }

    .discover-cta {
      position: relative;
      margin-top: -1px;
      padding: clamp(2rem, 5vw, 3.7rem) 1.5rem clamp(4rem, 7vw, 5.4rem);
      background: #171b1c;
      text-align: center;
    }

    .discover-cta__inner {
      width: min(100%, var(--container-max));
      margin: 0 auto;
    }

    .discover-cta__description {
      display: grid;
      gap: 0.2rem;
      width: min(100%, 28rem);
      margin: 0 auto clamp(1.5rem, 3vw, 2rem);
      font-family: var(--font-body);
      font-size: var(--text-small);
      line-height: var(--leading-body);
      color: rgba(255, 255, 255, 0.88);
    }

    .discover-cta__title {
      display: grid;
      gap: 0.15rem;
      margin: 0 0 clamp(1.7rem, 3.2vw, 2.35rem);
      font-family: var(--font-heading);
      font-size: clamp(2rem, 3.7vw, 3.1rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.04em;
      color: #ffffff;
    }

    .discover-cta__title span {
      display: block;
    }

    :global(.discover-cta__button) {
      margin-inline: auto;
    }

    @media (max-width: 767px) {
      .discover-hero {
        aspect-ratio: var(--discover-ratio-mobile);
        min-height: 38rem;
        padding-inline: 1.1rem;
        background-image:
          linear-gradient(180deg, rgba(255, 255, 255, 0.28) 0%, rgba(255, 255, 255, 0.04) 42%, #171b1c 100%),
          var(--discover-bg-mobile);
        background-position: center top;
      }

      .discover-hero::before {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.38) 0%, rgba(255, 255, 255, 0.08) 44%, rgba(255, 255, 255, 0) 72%);
      }

      .discover-hero::after {
        height: 12%;
      }

      .discover-hero__description {
        width: min(100%, 24rem);
      }
    }
  </style>
</BaseLayout>
