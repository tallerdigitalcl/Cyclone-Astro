---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { sanityClient } from '../lib/sanity';
import { postsQuery } from '../lib/queries';
import type { Post } from '../lib/types';

const posts: Post[] = await sanityClient.fetch(postsQuery);
const recentPosts = posts.slice(0, 3);
---

<BaseLayout
  title="Inicio | Astro Cyclone"
  description="Bienvenido a nuestro sitio web"
>
  <section class="hero">
    <div class="container">
      <h1>Bienvenido a Astro Cyclone</h1>
      <p>Sitio web de alto rendimiento construido con Astro y Sanity CMS</p>
    </div>
  </section>

  {recentPosts.length > 0 && (
    <section class="recent-posts">
      <div class="container">
        <h2>Últimas entradas</h2>
        <div class="posts-grid">
          {recentPosts.map(post => <PostCard post={post} />)}
        </div>
        <div class="view-all">
          <a href="/blog">Ver todas las entradas →</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: 6rem 0;
    text-align: center;
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--color-muted);
    max-width: 480px;
    margin: 0 auto;
  }

  .recent-posts {
    padding: 4rem 0;
  }

  .recent-posts h2 {
    font-size: 1.75rem;
    margin-bottom: 2rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .view-all {
    margin-top: 2.5rem;
    text-align: center;
  }

  .view-all a {
    font-size: 1rem;
    font-weight: 600;
  }
</style>
