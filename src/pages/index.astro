---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import MotoSlider from '../components/home/MotoSlider.astro';
import InfoSection from '../components/home/InfoSection.astro';
import MotosOferta from '../components/home/MotosOferta.astro';
import InstagramSection from '../components/home/InstagramSection.astro';
import LatestNews from '../components/home/LatestNews.astro';
import { buildHomeOffers, buildHomeSliderMotos } from '../lib/promobility';
import { sanityClient, urlFor } from '../lib/sanity';
import {
  motosHomeSliderQuery,
  ofertasHomeQuery,
  motosConFotoOfertaQuery,
  postsQuery,
  heroSlidesQuery,
  homeInfoSectionQuery,
} from '../lib/queries';
import type { HomeInfoSection, HomeOffer, HomeSliderMoto, Moto, Oferta, Post, HeroSlide } from '../lib/types';

const [heroSlides, motosSliderSanity, homeInfoSection, ofertasSanity, fallbackMotosSanity, posts] = await Promise.all([
  sanityClient.fetch<HeroSlide[]>(heroSlidesQuery),
  sanityClient.fetch<Moto[]>(motosHomeSliderQuery),
  sanityClient.fetch<HomeInfoSection | null>(homeInfoSectionQuery),
  sanityClient.fetch<Oferta[]>(ofertasHomeQuery),
  sanityClient.fetch<Oferta[]>(motosConFotoOfertaQuery),
  sanityClient.fetch<Post[]>(postsQuery),
]);

const motosSlider: HomeSliderMoto[] = await buildHomeSliderMotos(motosSliderSanity);
const ofertas: HomeOffer[] = await buildHomeOffers(ofertasSanity, fallbackMotosSanity);
const ultimasNoticias = posts.slice(0, 5);

const heroLcpImage = heroSlides[0]?.imagen
  ? urlFor(heroSlides[0].imagen).width(1600).quality(85).auto('format').url()
  : undefined;
---

<BaseLayout
  title="Cyclone Motos - Tu mejor aliado sobre dos ruedas"
  description="Cyclone, es la marca insigne del Grupo Zonsen, el cual se ha transformado en el fabricante #1 en China de motocicletas. Destacándose por su calidad en cada uno de sus desarrollos, esta marca llega a Chile para posicionarse como una de las mejores en cada uno de sus segmentos. Cyclone Chile"
  heroImageUrl={heroLcpImage}
>
  <Hero slides={heroSlides} />
  <MotoSlider motos={motosSlider} />
  <InfoSection section={homeInfoSection} />
  <MotosOferta ofertas={ofertas} />
  <InstagramSection />
  <LatestNews posts={ultimasNoticias} />
</BaseLayout>
