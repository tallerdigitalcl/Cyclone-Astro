---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { sanityClient } from '../../lib/sanity';
import { postsQuery } from '../../lib/queries';
import type { Post } from '../../lib/types';

const posts: Post[] = await sanityClient.fetch(postsQuery);
---

<BaseLayout
  title="Noticias | Cyclone Motos"
  description="Ultimas noticias, eventos, tips y novedades de Cyclone Motos."
>
  <section class="blog-index" aria-labelledby="blog-index-title">
    <div class="blog-index__container">
      <header class="blog-index__header">
        <p class="blog-index__eyebrow">Actualidad Cyclone</p>
        <h1 id="blog-index-title" class="blog-index__title">Noticias</h1>
        <p class="blog-index__intro">
          Revisa eventos, novedades y consejos pensados para la comunidad Cyclone.
        </p>
      </header>

      {posts.length > 0 ? (
        <div class="blog-index__grid">
          {posts.map((post) => <PostCard post={post} />)}
        </div>
      ) : (
        <p class="blog-index__empty">No hay noticias publicadas aun.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-index {
    padding: var(--section-spacing) 0;
    background: var(--color-bg);
  }

  .blog-index__container {
    @apply mx-auto;
    max-width: var(--container-max);
    padding: 0 var(--container-padding);
  }

  .blog-index__header {
    max-width: 44rem;
    margin-bottom: 2.5rem;
  }

  .blog-index__eyebrow {
    @apply font-body uppercase;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    margin-bottom: 0.7rem;
  }

  .blog-index__title {
    @apply font-heading text-h2;
    color: var(--color-text);
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }

  .blog-index__intro {
    @apply font-body text-body-lg;
    color: rgba(26, 28, 28, 0.76);
    line-height: 1.6;
  }

  .blog-index__grid {
    @apply grid;
    gap: 1.75rem;
  }

  .blog-index__empty {
    @apply font-body text-body-lg;
    color: var(--color-muted);
    padding: 3rem 0;
  }

  @media (min-width: 768px) {
    .blog-index__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1200px) {
    .blog-index__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
    }
  }
</style>
